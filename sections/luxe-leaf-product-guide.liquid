{%- doc -%}
  Premium product page accordions: origin, tasting notes, and brewing guide.
  Uses product metafields when set, otherwise infers content from product tags.
{%- enddoc -%}

{%- liquid
  assign product = section.settings.product | default: product
  if product == blank
    assign product = closest.product
  endif

  assign tea_type = 'premium'
  assign tag_handles = product.tags | join: ',' | downcase

  if tag_handles contains 'green-tea' or tag_handles contains 'green tea'
    assign tea_type = 'green'
  elsif tag_handles contains 'oolong'
    assign tea_type = 'oolong'
  elsif tag_handles contains 'pu-erh' or tag_handles contains 'puerh' or tag_handles contains 'pu erh'
    assign tea_type = 'puerh'
  elsif tag_handles contains 'black-tea' or tag_handles contains 'black tea'
    assign tea_type = 'black'
  endif

  assign origin = product.metafields.custom.origin.value | default: product.metafields.custom.origin
  assign tasting = product.metafields.custom.tasting_notes.value | default: product.metafields.custom.tasting_notes
  assign brewing = product.metafields.custom.brewing_guide.value | default: product.metafields.custom.brewing_guide

  case tea_type
    when 'green'
      assign default_origin = '<p>Hand-harvested premium loose leaf green tea from renowned gardens in Zhejiang Province. Whole leaves selected for their bright aroma, sweet finish, and classic needle shape.</p>'
      assign default_tasting = '<p><strong>Aroma:</strong> Fresh grass, chestnut, and spring florals<br><strong>Palate:</strong> Clean, sweet, lightly vegetal<br><strong>Finish:</strong> Smooth and lingering</p>'
      assign default_brewing = '<p><strong>Leaf:</strong> 3g per 150ml water<br><strong>Water:</strong> 175–185°F (80–85°C)<br><strong>Time:</strong> 1–2 minutes<br><strong>Re-steeps:</strong> 3–4 infusions</p>'
    when 'oolong'
      assign default_origin = '<p>Artisan-roasted oolong from Fujian and Taiwan-style gardens. Rolled leaves crafted to balance floral aroma with a rich, layered cup.</p>'
      assign default_tasting = '<p><strong>Aroma:</strong> Orchid, honey, and toasted grain<br><strong>Palate:</strong> Rounded, creamy, gently sweet<br><strong>Finish:</strong> Soft and persistent</p>'
      assign default_brewing = '<p><strong>Leaf:</strong> 4g per 150ml water<br><strong>Water:</strong> 195–205°F (90–96°C)<br><strong>Time:</strong> 2–3 minutes<br><strong>Re-steeps:</strong> 4–6 infusions</p>'
    when 'puerh'
      assign default_origin = '<p>Aged loose leaf pu-erh from Yunnan Province. Selected for depth, smoothness, and the rich character that develops across multiple steeps.</p>'
      assign default_tasting = '<p><strong>Aroma:</strong> Earth, dark cocoa, dried fruit<br><strong>Palate:</strong> Deep, mellow, naturally sweet<br><strong>Finish:</strong> Warm and long</p>'
      assign default_brewing = '<p><strong>Leaf:</strong> 4–5g per 150ml water<br><strong>Water:</strong> 205–212°F (96–100°C)<br><strong>Time:</strong> 20–30 seconds (rinse), then 2–3 minutes<br><strong>Re-steeps:</strong> 6–8 infusions</p>'
    when 'black'
      assign default_origin = '<p>Premium black loose leaf tea from established growing regions. Whole leaves chosen for fragrance, body, and a polished, copper-bright liquor.</p>'
      assign default_tasting = '<p><strong>Aroma:</strong> Malty, cocoa, dried fruit<br><strong>Palate:</strong> Full-bodied, smooth, gently brisk<br><strong>Finish:</strong> Clean and satisfying</p>'
      assign default_brewing = '<p><strong>Leaf:</strong> 3g per 150ml water<br><strong>Water:</strong> 200–212°F (93–100°C)<br><strong>Time:</strong> 3–4 minutes<br><strong>Re-steeps:</strong> 2–3 infusions</p>'
    else
      assign default_origin = '<p>Curated premium loose leaf tea, selected for aroma, clarity, and the kind of cup that rewards slow sipping. Origin and harvest details are listed on every lot we release.</p>'
      assign default_tasting = '<p><strong>Aroma:</strong> Layered and inviting<br><strong>Palate:</strong> Balanced, clean, and expressive<br><strong>Finish:</strong> Smooth with a lingering sweetness</p>'
      assign default_brewing = '<p><strong>Leaf:</strong> 3g per 150ml water<br><strong>Water:</strong> 185–205°F depending on tea style<br><strong>Time:</strong> 1–3 minutes<br><strong>Re-steeps:</strong> Quality loose leaf can be re-steeped multiple times</p>'
  endcase

  assign title_downcase = product.title | downcase
  if title_downcase contains 'yunnan' and title_downcase contains 'ctc'
    assign default_origin = '<p>Yunnan CTC black tea from high-elevation gardens in Yunnan Province, China. Crush-tear-curl processing delivers bold strength and fast infusion — the style pro brewers reach for in milk tea and chai.</p>'
    assign default_tasting = '<p><strong>Aroma:</strong> Earthy, malty, slightly peppery<br><strong>Palate:</strong> Full-bodied, deep reddish liquor, robust<br><strong>Finish:</strong> Smooth with lingering malt — holds dairy and ice well</p>'
    assign default_brewing = '<p><strong>Hot cup:</strong> 3g per 150ml · 205–212°F · 3–4 minutes<br><strong>Milk tea / chai batch:</strong> 50g per 2L · just off boil · steep 10–15 minutes · strain · add milk and sweetener<br><strong>Tip:</strong> CTC brews faster than whole leaf — taste at 8 minutes for bubble tea batches.</p>'
  endif
  if title_downcase contains 'fujian' and title_downcase contains 'black'
    assign default_origin = '<p>Handpicked Fujian black tea from misty highland gardens in Fujian Province, China. Carefully oxidized whole leaf prized for natural sweetness in specialty blends.</p>'
    assign default_tasting = '<p><strong>Aroma:</strong> Honey, light florals, soft cocoa<br><strong>Palate:</strong> Mellow, sweet, balanced<br><strong>Finish:</strong> Clean and aromatic — rounds out bolder blend partners</p>'
    assign default_brewing = '<p><strong>Hot cup:</strong> 3g per 150ml · 200–205°F · 3 minutes<br><strong>Blending:</strong> Use 20–40% Fujian with Assam or Yunnan CTC for softer, sweeter milk tea<br><strong>Re-steeps:</strong> 2–3 infusions</p>'
  endif
  if title_downcase contains 'falling snow'
    assign default_origin = '<p><strong>Premium loose leaf tea</strong> — selected for a smooth, clean cup that carries delicate floral scent beautifully.<br><br><strong>Rare Sibao Jasmine Flowers</strong> — handpicked at full bloom and traditionally layered with tea leaves over multiple scenting cycles. No artificial flavors, fragrance oils, or shortcuts.</p>'
    assign default_tasting = '<p><strong>Aroma:</strong> Fresh jasmine blossoms with an elegant floral bouquet<br><strong>Palate:</strong> Smooth, naturally sweet, and delicately floral<br><strong>Body:</strong> Light to medium-bodied with a silky mouthfeel<br><strong>Finish:</strong> Clean, refreshing, and beautifully lingering</p>'
    assign default_brewing = '<p><strong>Leaf:</strong> 2–3g (1 teaspoon) per 150ml<br><strong>Water:</strong> 80–85°C (176–185°F) — avoid boiling water<br><strong>Steep:</strong> 2–3 minutes<br><strong>Re-steeps:</strong> 2–4 infusions<br><strong>Tip:</strong> Lower temperature preserves the most delicate Sibao jasmine aroma.</p>'
  endif
  if title_downcase contains 'jasmine'
    assign default_origin = '<p><strong>Yunnan Maojian green tea</strong> — spring-harvested needle leaves from mist-covered Yunnan mountains, selected for a vibrant, clean cup and smooth finish.<br><br><strong>Guangxi jasmine blossoms</strong> — handpicked at peak bloom and layered with the tea through a traditional multi-round scenting process. No artificial flavors or oils.</p>'
    assign default_tasting = '<p><strong>Aroma:</strong> Fresh jasmine blossoms with an elegant floral bouquet<br><strong>Palate:</strong> Smooth, lightly sweet, fresh vegetal notes balanced by delicate jasmine<br><strong>Body:</strong> Light to medium-bodied<br><strong>Finish:</strong> Clean, crisp, refreshing, and beautifully lingering</p>'
    assign default_brewing = '<p><strong>Leaf:</strong> 2–3g (1 teaspoon) per 150ml<br><strong>Water:</strong> 80–85°C (175–185°F) — avoid boiling water<br><strong>Steep:</strong> 2–3 minutes<br><strong>Re-steeps:</strong> 2–3 infusions<br><strong>Tip:</strong> Lower temperature preserves the most delicate floral aroma.</p>'
  endif
  if title_downcase contains 'peach'
    assign default_origin = '<p><strong>Jinxuan Milk Oolong</strong> — carefully selected Taiwanese-style oolong prized for its naturally creamy texture, buttery smooth finish, and delicate floral aroma.<br><br>The premium oolong base is complemented with a soft, juicy peach fragrance that enhances — never masks — the tea&rsquo;s authentic character.</p>'
    assign default_tasting = '<p><strong>Aroma:</strong> Fresh, ripe peaches with elegant floral notes<br><strong>Palate:</strong> Smooth creamy oolong with naturally sweet peach flavor<br><strong>Body:</strong> Medium-bodied with a silky texture<br><strong>Finish:</strong> Clean, mellow, floral, and pleasantly lingering</p>'
    assign default_brewing = '<p><strong>Leaf:</strong> 3–5g per 150ml<br><strong>Water:</strong> 90–95°C (194–203°F)<br><strong>Steep:</strong> 3–4 minutes<br><strong>Re-steeps:</strong> 3–5 infusions<br><strong>Tip:</strong> Excellent hot, iced, or as a peach milk tea and bubble tea base.</p>'
  endif
  if title_downcase contains 'chatramue' or title_downcase contains 'thai tea mix'
    assign default_origin = '<p><strong>ChaTraMue</strong> — Thailand&rsquo;s iconic tea brand since 1945, crafted from carefully selected tea leaves for the bold flavor and signature aroma behind authentic Thai iced tea and milk tea.<br><br><strong>Country of origin:</strong> Thailand · 400g loose leaf mix</p>'
    assign default_tasting = '<p><strong>Aroma:</strong> Warm, inviting tea fragrance with subtle sweetness<br><strong>Palate:</strong> Bold, smooth, and beautifully balanced<br><strong>Body:</strong> Medium to full-bodied<br><strong>Finish:</strong> Clean, mellow, and pleasantly lingering</p>'
    assign default_brewing = '<p><strong>Leaf:</strong> 2g per 200ml water<br><strong>Water:</strong> 95–100°C (203–212°F)<br><strong>Steep:</strong> 3–5 minutes · strain before serving<br><strong>Thai iced tea:</strong> Brew strong, sweeten, pour over ice with condensed or evaporated milk<br><strong>Storage:</strong> Cool, dry place · reseal after opening · best within 6 months</p>'
  endif
  if title_downcase contains 'mocastar'
    assign default_origin = '<p><strong>Mocastar Blend Tea 金裝大排檔</strong> — a premium Hong Kong-style loose leaf black tea blend inspired by the iconic <strong>Cha Chaan Teng (茶餐廳)</strong> tradition. Crafted for the bold strength and silky smoothness behind authentic silk stocking milk tea.</p>'
    assign default_tasting = '<p><strong>Aroma:</strong> Rich black tea with warm roasted notes<br><strong>Palate:</strong> Bold, smooth, and beautifully balanced<br><strong>Body:</strong> Full-bodied with a silky mouthfeel<br><strong>Finish:</strong> Clean, rich, and pleasantly lingering — holds up beautifully with milk</p>'
    assign default_brewing = '<p><strong>Leaf:</strong> 8–10g per 500ml water<br><strong>Water:</strong> 95–100°C (203–212°F)<br><strong>Steep:</strong> 5–8 minutes · strain thoroughly<br><strong>Hong Kong milk tea:</strong> Add evaporated milk or sweetened condensed milk — serve hot or over ice<br><strong>Tip:</strong> Brew strong for the classic Cha Chaan Teng character</p>'
  endif

  if origin == blank
    assign origin_html = default_origin
    assign origin_is_default = true
  else
    assign origin_html = origin | metafield_tag
    assign origin_is_default = false
  endif

  if tasting == blank
    assign tasting_html = default_tasting
    assign tasting_is_default = true
  else
    assign tasting_html = tasting | metafield_tag
    assign tasting_is_default = false
  endif

  if brewing == blank
    assign brewing_html = default_brewing
  else
    assign brewing_html = brewing | metafield_tag
  endif

  # Keep tasting notes available for conversion even when a description exists.
  # Only hide generic origin copy when the description already covers the story.
  assign show_origin = true
  assign show_tasting = true
  if product.description != blank and origin_is_default
    assign show_origin = false
  endif

  assign free_ship_label = settings.free_shipping_threshold | default: 5000 | money
  assign trust_line = section.settings.trust_line
  if trust_line == blank or trust_line contains 'over $50'
    assign trust_line = 'Packed fresh to order · Premium loose leaf tea · Free Canada-wide shipping over ' | append: free_ship_label
  endif

  assign tea_collection_handle = ''
  assign tea_guide_url = '/blogs/tea-guides/how-to-brew-loose-leaf-tea'
  assign tea_collection_label = 'Shop premium loose leaf tea'

  case tea_type
    when 'green'
      assign tea_collection_handle = 'green-tea'
      assign tea_collection_label = 'Shop premium green tea'
    when 'oolong'
      assign tea_collection_handle = 'oolong'
      assign tea_guide_url = '/blogs/tea-guides/best-oolong-teas-for-beginners'
      assign tea_collection_label = 'Shop premium oolong tea'
    when 'puerh'
      assign tea_collection_handle = 'pu-erh'
      assign tea_collection_label = 'Shop premium pu-erh tea'
    when 'black'
      assign tea_collection_handle = 'black-tea'
      assign tea_collection_label = 'Shop premium black tea'
  endcase

  if tea_collection_handle != blank
    assign tea_collection = collections[tea_collection_handle]
    if tea_collection.url != blank
      assign tea_collection_url = tea_collection.url
    else
      assign tea_collection_url = '/collections/' | append: tea_collection_handle
    endif
  else
    assign tea_collection_url = '/collections/all'
  endif
-%}

<section
  class="luxe-product-guide section section--page-width spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
  aria-label="Brewing guide and tasting notes"
>
  <div class="luxe-product-guide__trust">
    <span class="luxe-product-guide__trust-icon" aria-hidden="true">{%- render 'luxe-leaf-icon', name: 'cup', class: 'luxe-icon--sm' -%}</span>
    {{ trust_line }}
  </div>

  <div class="luxe-product-guide__accordion accordion accordion--caret accordion--dividers">
    <details class="luxe-product-guide__row" {% if section.settings.open_brewing %}open{% endif %}>
      <summary class="luxe-product-guide__summary">
        <span>How to brew</span>
      </summary>
      <div class="luxe-product-guide__content rte">{{ brewing_html }}</div>
    </details>

    {%- if show_origin -%}
      <details class="luxe-product-guide__row">
        <summary class="luxe-product-guide__summary">
          <span>Origin & harvest</span>
        </summary>
        <div class="luxe-product-guide__content rte">{{ origin_html }}</div>
      </details>
    {%- endif -%}

    {%- if show_tasting -%}
      <details class="luxe-product-guide__row">
        <summary class="luxe-product-guide__summary">
          <span>Tasting notes</span>
        </summary>
        <div class="luxe-product-guide__content rte">{{ tasting_html }}</div>
      </details>
    {%- endif -%}
  </div>

  <div class="luxe-product-guide__links">
    <a href="{{ tea_collection_url }}" class="luxe-product-guide__link luxe-link-with-icon">
      {{ tea_collection_label }}
      {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
    </a>
    <a href="{{ tea_guide_url }}" class="luxe-product-guide__link luxe-link-with-icon">
      Read the brewing guide
      {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
    </a>
    <a href="/pages/faq" class="luxe-product-guide__link luxe-link-with-icon">
      View FAQ
      {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
    </a>
  </div>
</section>

{% stylesheet %}
  .luxe-product-guide {
    padding-block: 8px 32px;
  }

  .luxe-product-guide__trust {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    padding: 12px 16px;
    border-radius: 8px;
    background: #f8f6f0;
    color: #1b4332;
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }

  .luxe-product-guide__trust-icon {
    flex-shrink: 0;
  }

  .luxe-product-guide__row {
    border-top: 1px solid rgb(27 67 50 / 0.12);
  }

  .luxe-product-guide__row:last-child {
    border-bottom: 1px solid rgb(27 67 50 / 0.12);
  }

  .luxe-product-guide__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    cursor: pointer;
    font-weight: 600;
    list-style: none;
  }

  .luxe-product-guide__summary::-webkit-details-marker {
    display: none;
  }

  .luxe-product-guide__content {
    padding-bottom: 16px;
    color: rgb(27 67 50 / 0.88);
    line-height: 1.65;
  }

  .luxe-product-guide__content p {
    margin: 0 0 10px;
  }

  .luxe-product-guide__links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid rgb(27 67 50 / 0.12);
  }

  .luxe-product-guide__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: #1b4332;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .luxe-product-guide__link:hover {
    text-decoration: underline;
  }

  @media screen and (min-width: 750px) {
    .luxe-product-guide {
      padding-block-start: 0.5rem;
    }

    .luxe-product-guide__accordion {
      width: 100%;
      max-width: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf product guide",
  "tag": "section",
  "class": "luxe-product-guide-section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "autofill": true
    },
    {
      "type": "text",
      "id": "trust_line",
      "label": "Trust line",
      "default": "Packed fresh to order · Premium loose leaf tea · Free Canada-wide shipping over $50"
    },
    {
      "type": "checkbox",
      "id": "open_brewing",
      "label": "Open brewing guide by default",
      "default": true
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf product guide"
    }
  ]
}
{% endschema %}
