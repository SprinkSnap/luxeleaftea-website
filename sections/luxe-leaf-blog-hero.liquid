<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style luxe-leaf-blog-hero"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="luxe-leaf-blog-hero__inner page-width">
    <p class="luxe-leaf-blog-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="luxe-leaf-blog-hero__heading">{{ section.settings.heading }}</h1>
    <div class="luxe-leaf-blog-hero__text rte">{{ section.settings.text }}</div>
  </div>
</div>

{% stylesheet %}
  .luxe-leaf-blog-hero {
    padding-block: var(--padding-xl) var(--padding-lg);
  }

  .luxe-leaf-blog-hero__inner {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }

  .luxe-leaf-blog-hero__eyebrow {
    margin: 0 0 var(--margin-sm);
    font-size: var(--font-size--xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-primary-rgb));
  }

  .luxe-leaf-blog-hero__heading {
    margin: 0 0 var(--margin-md);
    font-family: var(--font-heading--family);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    line-height: 1.15;
    color: rgb(var(--color-foreground-heading-rgb));
  }

  .luxe-leaf-blog-hero__text {
    font-size: var(--font-size--md);
    line-height: 1.65;
    color: rgb(var(--color-foreground-rgb) / 0.85);
  }

  .luxe-leaf-blog-hero__text p {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf blog hero",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Tea guides"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium loose leaf tea guides"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro",
      "default": "<p>Brewing tips, origin stories, and buying guides for green tea, oolong, pu-erh, and black tea — written for everyday tea drinkers.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf blog hero"
    }
  ]
}
{% endschema %}
