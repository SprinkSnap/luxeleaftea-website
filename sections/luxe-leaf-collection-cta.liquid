<section
  class="luxe-collection-cta section section--page-width spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="luxe-collection-cta__box">
    <p class="luxe-collection-cta__eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="luxe-collection-cta__heading">{{ section.settings.heading }}</h2>
    <p class="luxe-collection-cta__text">{{ section.settings.text }}</p>
    <div class="luxe-collection-cta__actions">
      <a href="{{ section.settings.primary_link }}" class="button luxe-collection-cta__button">
        {{ section.settings.primary_label }}
      </a>
      {%- if section.settings.secondary_label != blank -%}
        <a href="{{ section.settings.secondary_link }}" class="button button-secondary luxe-collection-cta__button-secondary">
          {{ section.settings.secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .luxe-collection-cta {
    padding-block: 32px 48px;
  }

  .luxe-collection-cta__box {
    padding: 36px 28px;
    border-radius: 12px;
    background: linear-gradient(135deg, #1b4332 0%, #0d2818 100%);
    color: #f8f6f0;
    text-align: center;
  }

  .luxe-collection-cta__eyebrow {
    margin: 0 0 10px;
    color: #c9a227;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .luxe-collection-cta__heading {
    margin: 0 0 12px;
    font-size: clamp(1.35rem, 2.5vw, 1.85rem);
    line-height: 1.2;
  }

  .luxe-collection-cta__text {
    margin: 0 0 24px;
    color: rgb(248 246 240 / 0.85);
    line-height: 1.6;
    max-width: 36rem;
    margin-inline: auto;
  }

  .luxe-collection-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .luxe-collection-cta__button {
    background: #c9a227;
    border-color: #c9a227;
    color: #1a1a1a;
  }

  .luxe-collection-cta__button-secondary {
    border-color: #f8f6f0 !important;
    color: #f8f6f0 !important;
    background: transparent !important;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf collection CTA",
  "tag": "section",
  "class": "luxe-collection-cta-section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Need help choosing?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New to premium loose leaf tea?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Read our brewing guides or explore the full collection — every tea ships with guidance and is packed fresh to order."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button",
      "default": "Shop all teas"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button",
      "default": "Tea guides"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf collection CTA",
      "settings": {
        "primary_link": "shopify://collections/all",
        "secondary_link": "/blogs/tea-guides"
      }
    }
  ]
}
{% endschema %}
