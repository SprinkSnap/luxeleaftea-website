
{%- capture luxe_scope_check -%}
  {%- render 'luxe-leaf-page-scope-check', page_scope: section.settings.page_scope -%}
{%- endcapture -%}
{%- assign luxe_scope_check = luxe_scope_check | strip -%}
{%- if luxe_scope_check == 'show' -%}

{%- liquid
  assign story_image = section.settings.image
  if story_image == blank
    assign story_image_url = 'luxe-leaf-green-tea-product.png' | asset_url
    assign story_alt = 'Premium loose leaf green tea — Luxe Leaf Tea'
  else
    assign story_image_url = story_image | image_url: width: 800
    assign story_alt = story_image.alt | default: section.settings.heading
  endif
-%}

<section
  class="luxe-about section section--page-width spacing-style"
  id="our-story"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="luxe-about__grid">
    <div class="luxe-about__content">
      <p class="luxe-about__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="luxe-about__heading">{{ section.settings.heading }}</h2>
      <div class="luxe-about__text rte">{{ section.settings.text }}</div>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="button luxe-about__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="luxe-about__media">
      {%- if story_image != blank -%}
        {{
          story_image
          | image_url: width: 800
          | image_tag: loading: 'lazy', alt: story_alt, class: 'luxe-about__image', widths: '400, 600, 800'
        }}
      {%- else -%}
        <img
          src="{{ story_image_url }}"
          alt="{{ story_alt | escape }}"
          width="800"
          height="800"
          loading="lazy"
          class="luxe-about__image"
        >
      {%- endif -%}
      {%- if section.settings.image_caption != blank -%}
        <p class="luxe-about__caption">{{ section.settings.image_caption }}</p>
      {%- endif -%}
    </div>

    <div class="luxe-about__cards" role="list">
      {% for block in section.blocks %}
        <article class="luxe-about__card" role="listitem" {{ block.shopify_attributes }}>
          <p class="luxe-about__card-title">{{ block.settings.title }}</p>
          <p class="luxe-about__card-text">{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{%- endif -%}

{% stylesheet %}
  .luxe-about {
    padding-block: 56px;
  }

  .luxe-about__grid {
    display: grid;
    gap: 40px;
  }

  @media screen and (min-width: 990px) {
    .luxe-about__grid {
      grid-template-columns: 1.05fr 0.85fr 1fr;
      align-items: start;
      gap: 40px;
    }
  }

  .luxe-about__eyebrow {
    margin: 0 0 12px;
    color: #c9a227;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .luxe-about__heading {
    margin: 0 0 20px;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.15;
  }

  .luxe-about__text {
    color: rgb(27 67 50 / 0.88);
    font-size: 1rem;
    line-height: 1.7;
  }

  .luxe-about__text p {
    margin: 0 0 16px;
  }

  .luxe-about__button {
    margin-top: 24px;
    background: #1b4332;
    border-color: #1b4332;
    border-radius: 999px;
  }

  .luxe-about__media {
    position: relative;
    border-radius: 0.85rem;
    overflow: hidden;
    box-shadow: var(--luxe-shadow-soft, 0 4px 16px rgb(27 67 50 / 0.08));
  }

  .luxe-about__image {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .luxe-about__caption {
    margin: 0;
    padding: 0.75rem 0.9rem;
    background: var(--luxe-cream, #f8f6f0);
    font-size: 0.8125rem;
    line-height: 1.45;
    color: rgb(27 67 50 / 0.72);
    text-align: center;
  }

  .luxe-about__cards {
    display: grid;
    gap: 16px;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .luxe-about__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .luxe-about__card {
    padding: 24px;
    border: 1px solid rgb(27 67 50 / 0.12);
    border-radius: 8px;
    background: linear-gradient(180deg, rgb(248 246 240 / 0.8), rgb(255 255 255 / 0.9));
  }

  .luxe-about__card-title {
    margin: 0 0 8px;
    color: #1b4332;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .luxe-about__card-text {
    margin: 0;
    color: rgb(27 67 50 / 0.88);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf about story",
  "tag": "section",
  "class": "luxe-about-section",
  "settings": [
    {
      "type": "select",
      "id": "page_scope",
      "label": "Show on",
      "options": [
        { "value": "any", "label": "Any page (homepage, etc.)" },
        { "value": "about", "label": "About page only" },
        { "value": "contact", "label": "Contact page only" },
        { "value": "about_or_contact", "label": "About or Contact page" },
        { "value": "general", "label": "Other pages only (not About/Contact)" }
      ],
      "default": "any"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tea leaves worth slowing down for"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Luxe Leaf Tea sources drinkable premium loose-leaf teas from China's most respected growing regions — Longjing, Fujian, Yunnan, and beyond. Every lot is selected for aroma, clarity, and the kind of cup that turns a daily ritual into something special.</p><p>We work directly with trusted gardens and pack fresh to order, so what arrives at your door is ready to brew — not sitting on a shelf.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read our full story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story image"
    },
    {
      "type": "text",
      "id": "image_caption",
      "label": "Image caption",
      "default": "Whole leaves that unfurl in the cup — richer flavor, better re-steeps."
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "trust_point",
      "name": "Trust point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Origin first"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Teas labeled by region, harvest, and style — so you know exactly what you're buying."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf about story",
      "blocks": [
        {
          "type": "trust_point",
          "settings": {
            "title": "Origin first",
            "text": "Teas labeled by region, harvest, and style — so you know exactly what you're buying."
          }
        },
        {
          "type": "trust_point",
          "settings": {
            "title": "Loose leaf only",
            "text": "Whole leaves that unfurl in the cup — richer flavor, better re-steeps, no dusty bags."
          }
        },
        {
          "type": "trust_point",
          "settings": {
            "title": "Packed fresh",
            "text": "Sealed after you order to protect aroma and keep every cup vibrant."
          }
        },
        {
          "type": "trust_point",
          "settings": {
            "title": "Brewing guidance",
            "text": "Every tea ships with temperature, timing, and gram tips — confidence from the first sip."
          }
        }
      ]
    }
  ]
}
{% endschema %}
