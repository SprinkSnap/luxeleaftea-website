{%- doc -%}
  About page hero — boutique tea room story with AboutPage JSON-LD.
{%- enddoc -%}

{%- liquid
  assign hero_image = section.settings.image
  if hero_image == blank
    assign hero_image_url = 'luxe-leaf-tea-assortment-hero.png' | asset_url
    assign hero_alt = 'Premium loose leaf tea at Luxe Leaf Tea'
  else
    assign hero_image_url = hero_image | image_url: width: 1200
    assign hero_alt = hero_image.alt | default: section.settings.heading
  endif

  assign shop_tea_url = routes.all_products_collection_url
  if collections.all != blank and collections.all.url != blank
    assign shop_tea_url = collections.all.url
  endif

  assign contact_url = pages['contact'].url | default: '/pages/contact'

  assign page_url = shop.url | append: page.url
  assign page_desc = section.settings.intro | strip_html | truncate: 300
-%}

<section
  class="luxe-about-page section section--page-width spacing-style"
  id="about-hero"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="luxe-about-page__layout">
    <div class="luxe-about-page__copy">
      <p class="luxe-about-page__eyebrow">
        {%- render 'luxe-leaf-icon', name: 'leaf', class: 'luxe-icon--sm' -%}
        {{ section.settings.eyebrow }}
      </p>
      <h1 class="luxe-about-page__heading">{{ section.settings.heading }}</h1>
      <div class="luxe-about-page__intro rte">{{ section.settings.intro }}</div>

      <ul class="luxe-about-page__pillars list-unstyled" role="list">
        {%- for block in section.blocks -%}
          <li class="luxe-about-page__pillar" {{ block.shopify_attributes }}>
            <span class="luxe-about-page__pillar-icon" aria-hidden="true">
              {%- render 'luxe-leaf-icon', name: block.settings.icon, class: 'luxe-icon--sm' -%}
            </span>
            <div>
              <strong>{{ block.settings.title }}</strong>
              <span>{{ block.settings.text }}</span>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      <div class="luxe-about-page__actions">
        <a href="{{ section.settings.primary_link | default: shop_tea_url }}" class="button luxe-about-page__cta">
          {{ section.settings.primary_label }}
        </a>
        {%- if section.settings.secondary_label != blank -%}
          <a href="{{ section.settings.secondary_link | default: contact_url }}" class="button button-secondary luxe-about-page__cta-secondary">
            {{ section.settings.secondary_label }}
          </a>
        {%- endif -%}
      </div>

      <p class="luxe-about-page__trust-line">{{ section.settings.trust_line }}</p>
    </div>

    <div class="luxe-about-page__visual">
      {%- if section.settings.image != blank -%}
        {{
          hero_image
          | image_url: width: 1200
          | image_tag: loading: 'eager', fetchpriority: 'high', alt: hero_alt, class: 'luxe-about-page__image', widths: '600, 900, 1200'
        }}
      {%- else -%}
        <img
          src="{{ hero_image_url }}"
          alt="{{ hero_alt | escape }}"
          width="1200"
          height="900"
          loading="eager"
          fetchpriority="high"
          class="luxe-about-page__image"
        >
      {%- endif -%}
      <div class="luxe-about-page__badge">
        {%- render 'luxe-leaf-icon', name: 'cup', class: 'luxe-icon--sm' -%}
        {{ section.settings.badge_text }}
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": {{ section.settings.heading | json }},
    "description": {{ page_desc | json }},
    "url": {{ page_url | json }},
    "isPartOf": {
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }}
    },
    "mainEntity": {
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "description": {{ page_desc | json }},
      "knowsAbout": ["Premium loose leaf tea", "Chinese tea", "Green tea", "Oolong tea", "Pu-erh tea", "Black tea"]
    }
  }
</script>

{% stylesheet %}
  .luxe-about-page {
    padding-block: 2.5rem 3rem;
    background: linear-gradient(180deg, var(--luxe-cream, #f8f6f0) 0%, #fff 100%);
  }

  .luxe-about-page__layout {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media screen and (min-width: 900px) {
    .luxe-about-page__layout {
      grid-template-columns: 1.05fr 0.95fr;
      gap: 3rem;
    }
  }

  .luxe-about-page__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 0.75rem;
    color: var(--luxe-gold, #c9a227);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .luxe-about-page__heading {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.1;
    color: var(--luxe-jade, #1b4332);
  }

  .luxe-about-page__intro {
    margin: 0 0 1.35rem;
    color: rgb(var(--luxe-jade-rgb, 27 67 50) / 0.88);
    line-height: 1.7;
    font-size: 1.0625rem;
  }

  .luxe-about-page__intro p {
    margin: 0 0 0.85rem;
  }

  .luxe-about-page__pillars {
    display: grid;
    gap: 0.85rem;
    margin: 0 0 1.5rem;
  }

  .luxe-about-page__pillar {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: start;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: #fff;
    border: 1px solid rgb(var(--luxe-jade-rgb, 27 67 50) / 0.1);
    box-shadow: var(--luxe-shadow-soft, 0 4px 16px rgb(27 67 50 / 0.06));
  }

  .luxe-about-page__pillar-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: rgb(var(--luxe-gold-rgb, 201 162 39) / 0.15);
    color: var(--luxe-jade, #1b4332);
  }

  .luxe-about-page__pillar strong {
    display: block;
    margin-bottom: 0.15rem;
    color: var(--luxe-jade, #1b4332);
    font-size: 0.875rem;
  }

  .luxe-about-page__pillar span {
    display: block;
    color: rgb(var(--luxe-jade-rgb, 27 67 50) / 0.78);
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .luxe-about-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 0.85rem;
  }

  .luxe-about-page__cta {
    background: var(--luxe-jade, #1b4332);
    border-color: var(--luxe-jade, #1b4332);
    min-height: 2.75rem;
    border-radius: 999px;
  }

  .luxe-about-page__cta-secondary {
    min-height: 2.75rem;
    border-radius: 999px;
  }

  .luxe-about-page__trust-line {
    margin: 0;
    font-size: 0.8125rem;
    letter-spacing: 0.03em;
    color: rgb(var(--luxe-jade-rgb, 27 67 50) / 0.65);
  }

  .luxe-about-page__visual {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: var(--luxe-shadow, 0 12px 40px rgb(27 67 50 / 0.14));
  }

  .luxe-about-page__image {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .luxe-about-page__badge {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgb(248 246 240 / 0.94);
    border: 1px solid rgb(var(--luxe-jade-rgb, 27 67 50) / 0.12);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--luxe-jade, #1b4332);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf about page hero",
  "tag": "section",
  "class": "luxe-about-page-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Welcome to our tea room"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The only place for premium loose leaf tea"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Luxe Leaf Tea is a boutique for people who want whole leaves, honest origins, and the feeling of shopping at a real tea counter — online, on your phone, packed fresh after you order.</p><p>We source from China's most respected gardens, label every lot clearly, and guide you from first sip to daily ritual.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button",
      "default": "Shop premium loose leaf tea"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button",
      "default": "Talk to our team"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    },
    {
      "type": "text",
      "id": "trust_line",
      "label": "Trust line",
      "default": "Whole leaves · Packed fresh to order · Free shipping over $50"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Image badge",
      "default": "Shop like you're at the counter"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Story pillar",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "cup", "label": "Cup" },
            { "value": "truck", "label": "Truck" },
            { "value": "lock", "label": "Lock" }
          ],
          "default": "leaf"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Origin you can trust"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Teas labeled by region, harvest, and style — never vague blends."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf about page hero",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "icon": "leaf",
            "title": "Origin you can trust",
            "text": "Teas labeled by region, harvest, and style — never vague blends."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "icon": "cup",
            "title": "Packed fresh to order",
            "text": "We seal after you buy — aroma stays vivid, cups taste alive."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "icon": "truck",
            "title": "Real-time boutique service",
            "text": "Chat with our Tea Guide, browse by type, add to bag without leaving."
          }
        }
      ]
    }
  ]
}
{% endschema %}
