
<section
  class="luxe-trust-bar section section--full-width"
  aria-label="Store benefits"
  style="background-color: #1b4332; color: #f8f6f0;"
>
  <div class="luxe-trust-bar__inner page-width">
    <ul class="luxe-trust-bar__list list-unstyled" role="list">
      <li class="luxe-trust-bar__item">
        {%- render 'luxe-leaf-icon', name: 'leaf', class: 'luxe-icon--sm' -%}
        <span>Premium loose leaf tea</span>
      </li>
      <li class="luxe-trust-bar__item">
        {%- render 'luxe-leaf-icon', name: 'cup', class: 'luxe-icon--sm' -%}
        <span>Packed fresh to order</span>
      </li>
      <li class="luxe-trust-bar__item luxe-trust-bar__item--hide-mobile">
        {%- render 'luxe-leaf-icon', name: 'lock', class: 'luxe-icon--sm' -%}
        <span>Secure checkout</span>
      </li>
      <li class="luxe-trust-bar__item">
        {%- render 'luxe-leaf-icon', name: 'truck', class: 'luxe-icon--sm' -%}
        <span class="luxe-trust-bar__label luxe-trust-bar__label--full">Free Canada-wide shipping over {{ settings.free_shipping_threshold | default: 5000 | money }}</span>
        <span class="luxe-trust-bar__label luxe-trust-bar__label--short">Free shipping over {{ settings.free_shipping_threshold | default: 5000 | money }}</span>
      </li>
    </ul>
  </div>
</section>

{% stylesheet %}
  .luxe-trust-bar {
    background: #1b4332 !important;
    color: #f8f6f0 !important;
    border-bottom: 1px solid rgb(201 162 39 / 0.25);
  }

  .luxe-trust-bar__item,
  .luxe-trust-bar__item span {
    color: inherit;
  }

  .luxe-trust-bar__inner {
    padding-block: 10px;
  }

  .luxe-trust-bar__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 28px;
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .luxe-trust-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .luxe-trust-bar__label--short {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .luxe-trust-bar__item--hide-mobile {
      display: none;
    }

    .luxe-trust-bar__list {
      gap: 10px 16px;
      font-size: 0.6875rem;
    }

    .luxe-trust-bar__label--full {
      display: none;
    }

    .luxe-trust-bar__label--short {
      display: inline;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf trust bar",
  "tag": "section",
  "class": "luxe-trust-bar-section",
  "enabled_on": {
    "templates": ["index", "collection", "search", "product", "page", "policy"]
  },
  "presets": [
    {
      "name": "Luxe Leaf trust bar"
    }
  ]
}
{% endschema %}
