{%- doc -%}
  Luxe Leaf Tea premium footer — mobile-first conversion, trust, and SEO.
{%- enddoc -%}

{%- unless settings.brand_navigation == false -%}
  {% render 'luxe-leaf-brand-footer-content',
    cta_heading: section.settings.cta_heading,
    cta_subhead: section.settings.cta_subhead,
    brand_blurb: section.settings.brand_blurb,
    response_time: section.settings.response_time,
    show_newsletter: section.settings.show_newsletter,
    instagram_url: section.settings.instagram_url,
    facebook_url: section.settings.facebook_url,
    secondary_label: section.settings.secondary_cta_label,
    secondary_url: section.settings.secondary_cta_link,
    newsletter_heading: section.settings.newsletter_heading,
    newsletter_copy: section.settings.newsletter_copy,
    newsletter_placeholder: section.settings.newsletter_placeholder,
    newsletter_button_label: section.settings.newsletter_button_label,
    newsletter_success_message: section.settings.newsletter_success_message
  %}
{%- endunless -%}

{% stylesheet %}
  .luxe-brand-footer__newsletter {
    padding: 1rem;
    border-radius: 0.625rem;
    background: rgb(13 40 24 / 0.92) !important;
    border: 1px solid rgb(248 246 240 / 0.12);
    color: #f8f6f0 !important;
  }

  .luxe-brand-footer__newsletter-heading,
  .luxe-brand-footer__newsletter-copy {
    color: #f8f6f0 !important;
  }

  .luxe-brand-footer__newsletter-copy {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    line-height: 1.55;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf footer",
  "tag": "section",
  "class": "luxe-brand-footer-section",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Conversion CTA"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "Headline",
      "default": "Ready for your next perfect cup?"
    },
    {
      "type": "textarea",
      "id": "cta_subhead",
      "label": "Subheading",
      "default": "Hand-selected whole leaves, packed fresh after you order — brighter aroma, clearer flavor, every steep."
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary button",
      "default": "Browse FAQ"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Brand & contact"
    },
    {
      "type": "textarea",
      "id": "brand_blurb",
      "label": "Brand story",
      "default": "Luxe Leaf Tea sources drinkable premium loose-leaf teas from China's most respected growing regions. Whole leaves, packed fresh to order — for a clearer, more aromatic cup at home."
    },
    {
      "type": "text",
      "id": "response_time",
      "label": "Support response time",
      "default": "We reply within 1 business day."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show email signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Signup heading",
      "default": "Join the Luxe Leaf list"
    },
    {
      "type": "text",
      "id": "newsletter_copy",
      "label": "Signup description",
      "default": "Get new harvest alerts, brewing tips, and exclusive offers on premium loose leaf tea."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "Your email for tea tips"
    },
    {
      "type": "text",
      "id": "newsletter_button_label",
      "label": "Subscribe button",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "newsletter_success_message",
      "label": "Success message",
      "default": "Welcome — check your inbox for brewing tips soon."
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf footer",
      "settings": {
        "secondary_cta_link": "/pages/faq"
      }
    }
  ]
}
{% endschema %}
