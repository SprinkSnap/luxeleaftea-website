{%- doc -%}
  About page journey — editorial garden-to-cup story with optional image.
{%- enddoc -%}

{%- capture luxe_scope_check -%}
  {%- render 'luxe-leaf-page-scope-check', page_scope: 'about' -%}
{%- endcapture -%}
{%- assign luxe_scope_check = luxe_scope_check | strip -%}
{%- if luxe_scope_check == 'show' -%}

{%- liquid
  assign shop_tea_url = routes.all_products_collection_url
  if collections.all != blank and collections.all.url != blank
    assign shop_tea_url = collections.all.url
  endif

  assign journey_image = section.settings.image
  if journey_image == blank
    assign journey_image_url = 'luxe-leaf-tea-liquor-product.png' | asset_url
    assign journey_alt = 'Premium loose leaf tea steeped in a cup — Luxe Leaf Tea'
  else
    assign journey_image_url = journey_image | image_url: width: 1000
    assign journey_alt = journey_image.alt | default: section.settings.heading
  endif
-%}

<section
  class="luxe-about-journey section section--page-width spacing-style"
  id="our-journey"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="luxe-about-journey__layout">
    <div class="luxe-about-journey__visual">
      {%- if journey_image != blank -%}
        {{
          journey_image
          | image_url: width: 1000
          | image_tag: loading: 'lazy', alt: journey_alt, class: 'luxe-about-journey__image', widths: '500, 750, 1000'
        }}
      {%- else -%}
        <img
          src="{{ journey_image_url }}"
          alt="{{ journey_alt | escape }}"
          width="1000"
          height="750"
          loading="lazy"
          class="luxe-about-journey__image"
        >
      {%- endif -%}
      {%- if section.settings.image_badge != blank -%}
        <div class="luxe-about-journey__badge">
          {%- render 'luxe-leaf-icon', name: 'leaf', class: 'luxe-icon--sm' -%}
          {{ section.settings.image_badge }}
        </div>
      {%- endif -%}
    </div>

    <div class="luxe-about-journey__copy">
      <p class="luxe-about-journey__eyebrow">
        {%- render 'luxe-leaf-icon', name: 'cup', class: 'luxe-icon--sm' -%}
        {{ section.settings.eyebrow }}
      </p>
      <h2 class="luxe-about-journey__heading">{{ section.settings.heading }}</h2>
      <div class="luxe-about-journey__intro rte">{{ section.settings.intro }}</div>

      <ol class="luxe-about-journey__steps list-unstyled" role="list">
        {%- for block in section.blocks -%}
          <li class="luxe-about-journey__step" {{ block.shopify_attributes }}>
            <span class="luxe-about-journey__step-num" aria-hidden="true">{{ forloop.index }}</span>
            <div>
              <strong>{{ block.settings.title }}</strong>
              <span>{{ block.settings.text }}</span>
            </div>
          </li>
        {%- endfor -%}
      </ol>

      {%- if section.settings.quote != blank -%}
        <blockquote class="luxe-about-journey__quote">
          <p>"{{ section.settings.quote }}"</p>
          {%- if section.settings.quote_attribution != blank -%}
            <footer>— {{ section.settings.quote_attribution }}</footer>
          {%- endif -%}
        </blockquote>
      {%- endif -%}

      <div class="luxe-about-journey__actions">
        <a href="{{ section.settings.primary_link | default: shop_tea_url }}" class="button luxe-about-journey__cta">
          {{ section.settings.primary_label }}
        </a>
        {%- if section.settings.secondary_label != blank -%}
          <button type="button" class="button button-secondary luxe-about-journey__chat button-unstyled" data-open-tea-guide>
            {{ section.settings.secondary_label }}
          </button>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.luxe-about-journey [data-open-tea-guide]').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelector('[data-chat-launcher]')?.click();
    });
  });
</script>
{%- endif -%}

{% stylesheet %}
  .luxe-about-journey {
    padding-block: 3rem 3.5rem;
    background: #fff;
  }

  .luxe-about-journey__layout {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }

  @media screen and (min-width: 900px) {
    .luxe-about-journey__layout {
      grid-template-columns: 0.95fr 1.05fr;
      gap: 3.5rem;
    }
  }

  .luxe-about-journey__visual {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: var(--luxe-shadow, 0 12px 40px rgb(27 67 50 / 0.14));
  }

  .luxe-about-journey__image {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .luxe-about-journey__badge {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgb(248 246 240 / 0.94);
    border: 1px solid rgb(var(--luxe-jade-rgb, 27 67 50) / 0.12);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--luxe-jade, #1b4332);
  }

  .luxe-about-journey__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 0.75rem;
    color: var(--luxe-gold, #c9a227);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .luxe-about-journey__heading {
    margin: 0 0 1rem;
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    line-height: 1.15;
    color: var(--luxe-jade, #1b4332);
  }

  .luxe-about-journey__intro {
    margin: 0 0 1.5rem;
    color: rgb(var(--luxe-jade-rgb, 27 67 50) / 0.88);
    line-height: 1.7;
    font-size: 1rem;
  }

  .luxe-about-journey__intro p {
    margin: 0 0 0.75rem;
  }

  .luxe-about-journey__steps {
    display: grid;
    gap: 1rem;
    margin: 0 0 1.5rem;
  }

  .luxe-about-journey__step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: start;
    padding: 0.9rem 1rem;
    border-radius: 0.75rem;
    background: var(--luxe-cream, #f8f6f0);
    border: 1px solid rgb(var(--luxe-jade-rgb, 27 67 50) / 0.08);
  }

  .luxe-about-journey__step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    background: var(--luxe-jade, #1b4332);
    color: #f8f6f0;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .luxe-about-journey__step strong {
    display: block;
    margin-bottom: 0.15rem;
    color: var(--luxe-jade, #1b4332);
    font-size: 0.9375rem;
  }

  .luxe-about-journey__step span {
    display: block;
    color: rgb(var(--luxe-jade-rgb, 27 67 50) / 0.78);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .luxe-about-journey__quote {
    margin: 0 0 1.5rem;
    padding: 1rem 1.15rem;
    border-left: 3px solid var(--luxe-gold, #c9a227);
    background: rgb(var(--luxe-gold-rgb, 201 162 39) / 0.08);
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .luxe-about-journey__quote p {
    margin: 0 0 0.35rem;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--luxe-jade, #1b4332);
    font-style: italic;
  }

  .luxe-about-journey__quote footer {
    font-size: 0.8125rem;
    color: rgb(var(--luxe-jade-rgb, 27 67 50) / 0.65);
  }

  .luxe-about-journey__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .luxe-about-journey__cta {
    background: var(--luxe-jade, #1b4332);
    border-color: var(--luxe-jade, #1b4332);
    min-height: 2.75rem;
    border-radius: 999px;
  }

  .luxe-about-journey__chat {
    min-height: 2.75rem;
    border-radius: 999px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf about journey",
  "tag": "section",
  "class": "luxe-about-journey-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How we work"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From China's finest gardens to your daily ritual"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Luxe Leaf Tea was built for people who want the honesty of a real tea counter — whole leaves you can see, origins you can trust, and guidance when you need it.</p><p>We travel China's most respected growing regions, cup every lot, and choose teas for how they taste in your mug or gaiwan — not how they look on a shelf.</p>"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Pull quote",
      "default": "Every cup should feel like someone poured it for you — warm, clear, and worth slowing down for."
    },
    {
      "type": "text",
      "id": "quote_attribution",
      "label": "Quote attribution",
      "default": "The Luxe Leaf Tea team"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button",
      "default": "Shop our collection"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button",
      "default": "Ask our Tea Guide"
    },
    {
      "type": "text",
      "id": "image_badge",
      "label": "Image badge",
      "default": "Sourced with care · Packed fresh"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Journey step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Source with intention"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "We partner with gardens in Zhejiang, Fujian, and Yunnan — regions celebrated for centuries of tea mastery."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf about journey",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Source with intention",
            "text": "We partner with gardens in Zhejiang, Fujian, and Yunnan — regions celebrated for centuries of tea mastery."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Cup every lot",
            "text": "Small batches, careful selection, and tasting notes you can trust — never mass-market blends."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Pack fresh to order",
            "text": "Your tea is sealed after you buy — aroma stays vivid, cups taste alive, never stale from a warehouse shelf."
          }
        }
      ]
    }
  ]
}
{% endschema %}
