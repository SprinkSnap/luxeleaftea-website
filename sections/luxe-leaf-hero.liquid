{%- doc -%}
  Premium tea shop hero with bundled product photography and conversion CTAs.
{%- enddoc -%}

{%- liquid
  if section.settings.image != blank
    assign hero_image = section.settings.image | image_url: width: 1600
    assign hero_alt = section.settings.image.alt | default: 'Premium loose leaf tea assortment'
  else
    assign hero_image = 'luxe-leaf-tea-assortment-hero.png' | asset_url
    assign hero_alt = 'Premium loose leaf tea assortment'
  endif
-%}

<section class="luxe-hero section section--full-width section--mobile-full-width" id="shop-hero">
  <div class="luxe-hero__media-wrap">
    <img
      src="{{ hero_image }}"
      alt="{{ hero_alt | escape }}"
      width="1600"
      height="1200"
      loading="eager"
      fetchpriority="high"
      class="luxe-hero__image"
    >
    <div class="luxe-hero__overlay"></div>
  </div>

  <div class="luxe-hero__content">
    <div class="luxe-hero__copy">
      <p class="luxe-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="luxe-hero__heading">{{ section.settings.heading }}</h1>
      <p class="luxe-hero__subhead">{{ section.settings.subhead }}</p>

      <div class="luxe-hero__actions">
        <a href="{{ section.settings.primary_link }}" class="button luxe-hero__button luxe-hero__button--primary">
          {{ section.settings.primary_label }}
        </a>
        {%- if section.settings.secondary_label != blank -%}
          <a href="{{ section.settings.secondary_link }}" class="button button-secondary luxe-hero__button luxe-hero__button--secondary">
            {{ section.settings.secondary_label }}
          </a>
        {%- endif -%}
      </div>

      <ul class="luxe-hero__highlights list-unstyled" role="list">
        <li>Whole leaves, brighter cups</li>
        <li>Packed fresh to order</li>
        <li>Free shipping over $50</li>
      </ul>
    </div>
  </div>
</section>

{% stylesheet %}
  .luxe-hero {
    position: relative;
    min-height: clamp(28rem, 72vh, 42rem);
    display: flex;
    align-items: center;
    width: 100%;
    max-width: none;
    margin-inline: 0;
    padding-inline: 0;
    overflow: hidden;
    color: #f8f6f0;
  }

  .luxe-hero__media-wrap {
    position: absolute;
    inset: 0;
    width: 100%;
  }

  .luxe-hero__image {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
  }

  .luxe-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, rgb(13 40 24 / 0.92) 0%, rgb(13 40 24 / 0.72) 45%, rgb(13 40 24 / 0.35) 100%);
  }

  .luxe-hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
    padding-block: 5rem 4rem;
    padding-inline: max(var(--page-margin, 1rem), env(safe-area-inset-left))
      max(var(--page-margin, 1rem), env(safe-area-inset-right));
  }

  .luxe-hero__copy {
    max-width: 36rem;
  }

  .luxe-hero__eyebrow {
    margin: 0 0 1rem;
    color: #c9a227;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .luxe-hero__heading {
    margin: 0 0 1rem;
    font-family: var(--font-heading--family), "Playfair Display", Georgia, serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #fff !important;
    text-shadow: 0 2px 24px rgb(0 0 0 / 0.55);
  }

  .luxe-hero__subhead {
    margin: 0 0 1.75rem;
    max-width: 32rem;
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.65;
    color: rgb(248 246 240 / 0.9);
  }

  .luxe-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  @media screen and (max-width: 749px) {
    .luxe-hero {
      min-height: clamp(22rem, 88svh, 36rem);
    }

    .luxe-hero__overlay {
      background: linear-gradient(
        180deg,
        rgb(13 40 24 / 0.88) 0%,
        rgb(13 40 24 / 0.72) 55%,
        rgb(13 40 24 / 0.45) 100%
      );
    }

    .luxe-hero__content {
      max-width: none;
      padding-block: clamp(3rem, 12vw, 4rem) clamp(2.5rem, 10vw, 3rem);
    }

    .luxe-hero__copy {
      max-width: none;
    }

    .luxe-hero__heading {
      font-size: clamp(2rem, 9vw, 2.75rem);
    }

    .luxe-hero__actions {
      flex-direction: column;
    }

    .luxe-hero__actions .button {
      width: 100%;
      min-height: 3rem;
      justify-content: center;
    }

    .luxe-hero__highlights {
      font-size: 0.75rem;
    }
  }

  .luxe-hero__button--primary {
    background: #c9a227;
    border-color: #c9a227;
    color: #1a1a1a;
  }

  .luxe-hero__button--secondary {
    border-color: #f8f6f0;
    color: #f8f6f0;
  }

  .luxe-hero__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    margin: 0;
    font-size: 0.8125rem;
    letter-spacing: 0.03em;
    color: rgb(248 246 240 / 0.85);
  }

  .luxe-hero__highlights li {
    display: inline;
  }

  .luxe-hero__highlights li:not(:last-child)::after {
    content: ' · ';
    opacity: 0.6;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf hero",
  "tag": "section",
  "class": "luxe-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Defaults to bundled tea assortment photography."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Premium loose leaf tea"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Steep. Sip. Savor."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subheading",
      "default": "Hand-selected whole leaves, packed fresh for a clearer, more aromatic cup."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button",
      "default": "Shop Premium Loose Leaf Tea"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button",
      "default": "Explore Tea Types"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf hero",
      "settings": {
        "primary_link": "shopify://collections/all",
        "secondary_link": "shopify://collections"
      }
    }
  ]
}
{% endschema %}
