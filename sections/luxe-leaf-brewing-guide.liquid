
<section
  class="luxe-brew section section--page-width spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="luxe-brew__header">
    <p class="luxe-brew__eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="luxe-brew__heading">{{ section.settings.heading }}</h2>
    <p class="luxe-brew__intro">{{ section.settings.intro }}</p>
  </div>

  <div class="luxe-brew__grid" role="list">
    {% for block in section.blocks %}
      <article class="luxe-brew__step" role="listitem" {{ block.shopify_attributes }}>
        <p class="luxe-brew__step-number">{{ forloop.index }}</p>
        <h3 class="luxe-brew__step-title">{{ block.settings.title }}</h3>
        <p class="luxe-brew__step-text">{{ block.settings.text }}</p>
      </article>
    {% endfor %}
  </div>

  {% if section.settings.button_label != blank %}
    <div class="luxe-brew__cta">
      <a href="{{ section.settings.button_link }}" class="button button-secondary luxe-brew__button">
        {{ section.settings.button_label }}
      </a>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .luxe-brew {
    padding-block: 48px;
    background: #f8f6f0;
  }

  .luxe-brew__header {
    max-width: 42rem;
    margin-bottom: 32px;
  }

  .luxe-brew__eyebrow {
    margin: 0 0 10px;
    color: #c9a227;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .luxe-brew__heading {
    margin: 0 0 12px;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
  }

  .luxe-brew__intro {
    margin: 0;
    color: rgb(27 67 50 / 0.88);
    line-height: 1.6;
  }

  .luxe-brew__grid {
    display: grid;
    gap: 16px;
  }

  @media screen and (min-width: 750px) {
    .luxe-brew__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .luxe-brew__step {
    padding: 24px;
    border-radius: 8px;
    background: #f8f6f0;
    border: 1px solid rgb(27 67 50 / 0.08);
  }

  .luxe-brew__step-number {
    margin: 0 0 12px;
    color: #c9a227;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }

  .luxe-brew__step-title {
    margin: 0 0 8px;
    font-size: 1rem;
  }

  .luxe-brew__step-text {
    margin: 0;
    color: rgb(27 67 50 / 0.88);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .luxe-brew__cta {
    margin-top: 28px;
  }

  .luxe-brew__button {
    border-color: #1b4332;
    color: #1b4332;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf brewing guide",
  "tag": "section",
  "class": "luxe-brew-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How to brew"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unlock the full flavor in every leaf"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Premium loose-leaf tea rewards a little care. Follow these simple steps for a clearer, more aromatic cup."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop premium teas"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Measure"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Use 3g of leaf per 150ml water for most Chinese greens and oolongs."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf brewing guide",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Measure",
            "text": "Use 3g of leaf per 150ml water for most Chinese greens and oolongs."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Water temperature",
            "text": "Green teas: 175–185°F. Oolongs: 195–205°F. Never boiling for delicate leaves."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Steep & re-steep",
            "text": "Steep 1–2 minutes, then pour. Quality loose leaf can be re-steeped 3–5 times."
          }
        }
      ]
    }
  ]
}
{% endschema %}
