{%- doc -%}
  In-store boutique experience section — sensory shopping for premium loose leaf tea.
{%- enddoc -%}

{%- liquid
  assign show_luxe_store = true
  if template.name == 'page'
    assign show_luxe_store = false
    if page.handle == 'about' or template.suffix == 'about'
      assign show_luxe_store = true
    endif
  endif
-%}

{%- if show_luxe_store -%}
<section class="luxe-store section section--page-width spacing-style" id="tea-store-experience">
  <div class="luxe-store__layout">
    <div class="luxe-store__copy">
      <p class="luxe-store__eyebrow">
        {%- render 'luxe-leaf-icon', name: 'cup', class: 'luxe-icon--sm' -%}
        {{ section.settings.eyebrow }}
      </p>
      <h2 class="luxe-store__heading">{{ section.settings.heading }}</h2>
      <p class="luxe-store__intro">{{ section.settings.intro }}</p>

      <ul class="luxe-store__steps list-unstyled" role="list">
        <li>
          <span class="luxe-store__step-num">1</span>
          <div>
            <strong>Smell &amp; choose</strong>
            <span>Browse whole-leaf teas by type — green, oolong, pu-erh, and black.</span>
          </div>
        </li>
        <li>
          <span class="luxe-store__step-num">2</span>
          <div>
            <strong>Weigh &amp; pack fresh</strong>
            <span>Every order is packed after you buy — never sitting on a shelf.</span>
          </div>
        </li>
        <li>
          <span class="luxe-store__step-num">3</span>
          <div>
            <strong>Steep at home</strong>
            <span>Follow our brew guide for a clearer, more aromatic cup.</span>
          </div>
        </li>
      </ul>

      <div class="luxe-store__actions">
        <a href="{{ section.settings.primary_link }}" class="button luxe-store__cta luxe-store__cta--primary">
          {{ section.settings.primary_label }}
        </a>
        <a href="{{ section.settings.secondary_link }}" class="button button-secondary luxe-store__cta">
          {{ section.settings.secondary_label }}
        </a>
      </div>
    </div>

    <div class="luxe-store__visual">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 900
          | image_tag: loading: 'lazy', alt: section.settings.image.alt | default: 'Premium loose leaf tea tasting', class: 'luxe-store__image'
        }}
      {%- else -%}
        <img
          src="{{ 'luxe-leaf-tea-liquor-product.png' | asset_url }}"
          alt="Premium loose leaf tea being poured — drinkable whole leaves"
          width="900"
          height="900"
          loading="lazy"
          class="luxe-store__image"
        >
      {%- endif -%}
      <div class="luxe-store__badge">
        {%- render 'luxe-leaf-icon', name: 'leaf', class: 'luxe-icon--sm' -%}
        Whole leaves · Packed fresh
      </div>
    </div>
  </div>
</section>
{%- endif -%}

{% stylesheet %}
  .luxe-store {
    padding-block: 56px;
    background: linear-gradient(180deg, #fff 0%, var(--luxe-cream) 100%);
  }

  .luxe-store__layout {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }

  @media screen and (min-width: 900px) {
    .luxe-store__layout {
      grid-template-columns: 1fr 1fr;
      gap: 3.5rem;
    }
  }

  .luxe-store__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 0.75rem;
    color: var(--luxe-gold);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .luxe-store__heading {
    margin: 0 0 1rem;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.12;
    color: var(--luxe-jade);
  }

  .luxe-store__intro {
    margin: 0 0 1.5rem;
    max-width: 34rem;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: rgb(var(--luxe-jade-rgb) / 0.88);
  }

  .luxe-store__steps {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0 0 1.75rem;
  }

  .luxe-store__steps li {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }

  .luxe-store__step-num {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--luxe-jade);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 700;
  }

  .luxe-store__steps strong {
    display: block;
    color: var(--luxe-jade);
    margin-bottom: 0.15rem;
  }

  .luxe-store__steps span {
    font-size: 0.9375rem;
    color: rgb(var(--luxe-jade-rgb) / 0.78);
    line-height: 1.5;
  }

  .luxe-store__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .luxe-store__cta--primary {
    background: var(--luxe-jade);
    border-color: var(--luxe-jade);
    color: #fff;
    min-height: 3rem;
    padding-inline: 1.5rem;
  }

  .luxe-store__visual {
    position: relative;
    border-radius: var(--luxe-radius-lg);
    overflow: hidden;
    box-shadow: var(--luxe-shadow);
  }

  .luxe-store__image {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .luxe-store__badge {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.94);
    color: var(--luxe-jade);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    box-shadow: var(--luxe-shadow-soft);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe store experience",
  "tag": "section",
  "class": "luxe-store-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop like you're in our tea room"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium loose leaf tea, picked for your cup"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Introduction",
      "default": "No guesswork — whole leaves you can see, smell, and steep. We pack every order fresh so your first sip tastes like it came straight from the counter."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button",
      "default": "Shop Premium Loose Leaf Tea"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button",
      "default": "Explore Tea Types"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link",
      "default": "/collections"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Store image"
    }
  ],
  "presets": [
    {
      "name": "Luxe store experience"
    }
  ]
}
{% endschema %}
