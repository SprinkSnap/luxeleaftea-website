{%- capture luxe_scope_check -%}
  {%- render 'luxe-leaf-page-scope-check', page_scope: section.settings.page_scope -%}
{%- endcapture -%}
{%- assign luxe_scope_check = luxe_scope_check | strip -%}
{%- if luxe_scope_check == 'show' -%}

<section
  class="luxe-shop-cta section section--full-width spacing-style"
  style="background: linear-gradient(135deg, #1b4332 0%, #0d2818 100%); color: #f8f6f0; {% render 'spacing-style', settings: section.settings %}"
>
  <div class="luxe-shop-cta__inner page-width">
    <p class="luxe-shop-cta__eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="luxe-shop-cta__heading">{{ section.settings.heading }}</h2>
    <div class="luxe-shop-cta__text" style="color: #f8f6f0 !important;">{{ section.settings.text }}</div>
    <div class="luxe-shop-cta__actions">
      <a href="{{ section.settings.primary_link }}" class="button luxe-shop-cta__button">
        {{ section.settings.primary_label }}
      </a>
      {%- if section.settings.secondary_label != blank -%}
        <a href="{{ section.settings.secondary_link }}" class="button button-secondary luxe-shop-cta__button-secondary">
          {{ section.settings.secondary_label }}
        </a>
      {%- endif -%}
    </div>
    <p class="luxe-shop-cta__note">{{ section.settings.note }}</p>
  </div>
</section>
{%- endif -%}

{% stylesheet %}
  .luxe-shop-cta {
    padding-block: 64px;
    background: linear-gradient(135deg, #1b4332 0%, #0d2818 100%) !important;
    color: #f8f6f0 !important;
    text-align: center;
  }

  .luxe-shop-cta__heading,
  .luxe-shop-cta__note {
    color: #f8f6f0 !important;
  }

  .luxe-shop-cta__text,
  .luxe-shop-cta__text * {
    color: #f8f6f0 !important;
  }

  .luxe-shop-cta__inner {
    max-width: 40rem;
    margin: 0 auto;
  }

  .luxe-shop-cta__eyebrow {
    margin: 0 0 12px;
    color: #c9a227;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .luxe-shop-cta__heading {
    margin: 0 0 16px;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.15;
    color: #f8f6f0 !important;
  }

  .luxe-shop-cta__text {
    margin: 0 0 28px;
    color: #f8f6f0 !important;
    line-height: 1.6;
  }

  .luxe-shop-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-bottom: 16px;
  }

  .luxe-shop-cta__button {
    background: #c9a227;
    border-color: #c9a227;
    color: #1a1a1a;
  }

  .luxe-shop-cta__button-secondary {
    border-color: #f8f6f0 !important;
    color: #f8f6f0 !important;
    background: transparent !important;
  }

  .luxe-shop-cta__note {
    margin: 0;
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: rgb(248 246 240 / 0.92);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf shop CTA",
  "tag": "section",
  "class": "luxe-shop-cta-section",
  "settings": [
    {
      "type": "select",
      "id": "page_scope",
      "label": "Show on",
      "options": [
        { "value": "any", "label": "Any page (homepage, etc.)" },
        { "value": "about", "label": "About page only" },
        { "value": "contact", "label": "Contact page only" },
        { "value": "faq", "label": "FAQ page only" },
        { "value": "about_or_contact", "label": "About or Contact page" },
        { "value": "general", "label": "Other pages only (not About/Contact/FAQ)" }
      ],
      "default": "any"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Start your ritual"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready for your next perfect cup?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Explore premium loose leaf tea — hand-selected, packed fresh to order, and ready for your next perfect cup."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button",
      "default": "Shop Premium Loose Leaf Tea"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button",
      "default": "Explore Tea Guides"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note",
      "default": "Free shipping over $50 · Packed fresh to order · Secure checkout"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf shop CTA",
      "settings": {
        "primary_link": "shopify://collections/all",
        "secondary_link": "/blogs/tea-guides"
      }
    }
  ]
}
{% endschema %}
