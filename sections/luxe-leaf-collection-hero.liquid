{%- doc -%}
  Collection hero with SEO-friendly copy keyed to tea type handles.
{%- enddoc -%}

{%- liquid
  assign handle = collection.handle
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading | default: collection.title
  assign description = section.settings.description
  assign image_file = section.settings.fallback_image

  case handle
    when 'green-tea'
      assign eyebrow = eyebrow | default: 'Premium loose leaf green tea'
      assign description = description | default: 'Bright, sweet, and refreshing premium loose leaf green teas — from classic Longjing-style needles to aromatic garden picks. Whole leaves selected for clarity in the cup.'
      assign image_file = image_file | default: 'luxe-leaf-green-tea-product.png'
    when 'oolong'
      assign eyebrow = eyebrow | default: 'Premium loose leaf oolong'
      assign description = description | default: 'Floral, layered, and beautifully balanced oolongs — rolled leaves that unfurl across multiple steeps. Perfect for slow sipping and re-steeping.'
      assign image_file = image_file | default: 'luxe-leaf-oolong-tea-product.png'
    when 'pu-erh'
      assign eyebrow = eyebrow | default: 'Premium loose leaf pu-erh'
      assign description = description | default: 'Deep, smooth, and satisfying pu-erh teas with the richness that improves across infusions. A favorite for daily ritual and mindful breaks.'
      assign image_file = image_file | default: 'luxe-leaf-puerh-tea-product.png'
    when 'black-tea'
      assign eyebrow = eyebrow | default: 'Premium loose leaf black tea'
      assign description = description | default: 'Full-bodied black loose leaf teas with malty depth and a polished cup. Ideal for morning rituals and afternoon resets.'
      assign image_file = image_file | default: 'luxe-leaf-black-tea-product.png'
    else
      assign eyebrow = eyebrow | default: 'Premium loose leaf tea'
      assign description = description | default: collection.description | default: 'Explore our curated premium loose leaf teas — packed fresh to order for aroma, clarity, and everyday ritual.'
      assign image_file = image_file | default: 'luxe-leaf-tea-assortment-hero.png'
  endcase
-%}

<section class="luxe-collection-hero section section--page-width spacing-style" style="{% render 'spacing-style', settings: section.settings %}">
  <div class="luxe-collection-hero__grid">
    <div class="luxe-collection-hero__content">
      <p class="luxe-collection-hero__eyebrow">{{ eyebrow }}</p>
      <h1 class="luxe-collection-hero__heading">{{ heading }}</h1>
      <div class="luxe-collection-hero__text rte">{{ description }}</div>
    </div>

    <div class="luxe-collection-hero__media">
      {%- if collection.featured_image -%}
        {{
          collection.featured_image
          | image_url: width: 1200
          | image_tag: loading: 'eager', fetchpriority: 'high', alt: heading, class: 'luxe-collection-hero__image'
        }}
      {%- else -%}
        <img
          src="{{ image_file | asset_url }}"
          alt="{{ heading | escape }} — premium loose leaf tea"
          width="1200"
          height="900"
          loading="eager"
          fetchpriority="high"
          class="luxe-collection-hero__image"
        >
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .luxe-collection-hero {
    padding-block: 40px 24px;
    background: #f8f6f0;
  }

  .luxe-collection-hero__grid {
    display: grid;
    gap: 28px;
    align-items: center;
  }

  @media screen and (min-width: 990px) {
    .luxe-collection-hero__grid {
      grid-template-columns: 1.05fr 0.95fr;
      gap: 48px;
    }
  }

  .luxe-collection-hero__eyebrow {
    margin: 0 0 10px;
    color: #c9a227;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .luxe-collection-hero__heading {
    margin: 0 0 16px;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
  }

  .luxe-collection-hero__text {
    color: rgb(27 67 50 / 0.88);
    line-height: 1.7;
  }

  .luxe-collection-hero__media {
    overflow: hidden;
    border-radius: 12px;
    background: #f8f6f0;
  }

  .luxe-collection-hero__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf collection hero",
  "tag": "section",
  "class": "luxe-collection-hero-section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow override"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading override"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description override"
    },
    {
      "type": "text",
      "id": "fallback_image",
      "label": "Fallback image filename",
      "default": "luxe-leaf-tea-assortment-hero.png"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf collection hero"
    }
  ]
}
{% endschema %}
