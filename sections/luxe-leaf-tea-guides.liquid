{%- doc -%}
  Tea Guides hub cards — live blog articles when published, else shop/FAQ fallbacks (no 404s).
{%- enddoc -%}

{%- liquid
  assign guides_blog = blogs['tea-guides']
  assign has_live_guides = false
  if guides_blog != blank and guides_blog.articles_count > 0
    assign has_live_guides = true
  endif

  assign faq_url = pages['faq'].url | default: '/pages/faq'
  assign green_url = collections['green-tea'].url | default: '/collections/green-tea'
  assign oolong_url = collections['oolong'].url | default: '/collections/oolong'
  assign all_url = routes.all_products_collection_url
  if collections.all != blank and collections.all.url != blank
    assign all_url = collections.all.url
  endif
-%}

<section
  class="luxe-guides section section--page-width spacing-style"
  id="tea-guides"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="luxe-guides__header">
    <p class="luxe-guides__eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="luxe-guides__heading">{{ section.settings.heading }}</h2>
    <p class="luxe-guides__intro">{{ section.settings.intro }}</p>
    {%- if has_live_guides -%}
      <a href="{{ guides_blog.url }}" class="luxe-guides__hub-link luxe-link-with-icon">
        Browse all Tea Guides
        {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
      </a>
    {%- endif -%}
  </div>

  <div class="luxe-guides__grid" role="list">
    {%- if has_live_guides -%}
      {%- for article in guides_blog.articles limit: 3 -%}
        <a class="luxe-guides__card" href="{{ article.url }}" role="listitem">
          <h3 class="luxe-guides__title">{{ article.title }}</h3>
          <p class="luxe-guides__text">
            {%- if article.excerpt != blank -%}
              {{ article.excerpt | strip_html | truncate: 110 }}
            {%- else -%}
              Expert tips to brew with confidence and get more flavor from every leaf.
            {%- endif -%}
          </p>
          <span class="luxe-guides__link luxe-link-with-icon">
            Read guide
            {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
          </span>
        </a>
      {%- endfor -%}
      <a class="luxe-guides__card" href="{{ green_url }}" role="listitem">
        <h3 class="luxe-guides__title">Shop Premium Green Tea</h3>
        <p class="luxe-guides__text">Bright, sweet loose leaf greens packed fresh to order.</p>
        <span class="luxe-guides__link luxe-link-with-icon">
          Shop green tea
          {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
        </span>
      </a>
    {%- else -%}
      <a class="luxe-guides__card" href="{{ faq_url }}" role="listitem">
        <h3 class="luxe-guides__title">Brewing tips &amp; tea FAQ</h3>
        <p class="luxe-guides__text">Temperature, timing, shipping, and first-order answers — shop with confidence.</p>
        <span class="luxe-guides__link luxe-link-with-icon">
          Read the FAQ
          {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
        </span>
      </a>
      <a class="luxe-guides__card" href="{{ oolong_url }}" role="listitem">
        <h3 class="luxe-guides__title">Best oolongs to start with</h3>
        <p class="luxe-guides__text">Floral, layered teas perfect for your first gaiwan or everyday steep.</p>
        <span class="luxe-guides__link luxe-link-with-icon">
          Shop oolong
          {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
        </span>
      </a>
      <a class="luxe-guides__card" href="{{ green_url }}" role="listitem">
        <h3 class="luxe-guides__title">Shop Premium Green Tea</h3>
        <p class="luxe-guides__text">Bright, sweet loose leaf greens packed fresh to order.</p>
        <span class="luxe-guides__link luxe-link-with-icon">
          Shop green tea
          {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
        </span>
      </a>
      <a class="luxe-guides__card" href="{{ all_url }}" role="listitem">
        <h3 class="luxe-guides__title">Shop all premium loose leaf</h3>
        <p class="luxe-guides__text">Whole leaves for a clearer, more aromatic cup — packed fresh to order.</p>
        <span class="luxe-guides__link luxe-link-with-icon">
          Shop all teas
          {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
        </span>
      </a>
    {%- endif -%}
  </div>

  {%- if has_live_guides -%}
    <div class="luxe-guides__latest">
      <h3 class="luxe-guides__latest-heading">Latest from Tea Guides</h3>
      <ul class="luxe-guides__latest-list list-unstyled">
        {%- for article in guides_blog.articles limit: 3 -%}
          <li><a href="{{ article.url }}">{{ article.title }}</a></li>
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .luxe-guides {
    padding-block: 56px;
    background: #f8f6f0;
  }

  .luxe-guides__header {
    max-width: 42rem;
    margin-bottom: 28px;
  }

  .luxe-guides__eyebrow {
    margin: 0 0 10px;
    color: #c9a227;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .luxe-guides__heading {
    margin: 0 0 12px;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
  }

  .luxe-guides__intro {
    margin: 0;
    color: rgb(27 67 50 / 0.88);
    line-height: 1.6;
  }

  .luxe-guides__hub-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 1rem;
    color: #1b4332;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
  }

  .luxe-guides__hub-link:hover {
    text-decoration: underline;
  }

  .luxe-guides__grid {
    display: grid;
    gap: 16px;
  }

  @media screen and (min-width: 750px) {
    .luxe-guides__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .luxe-guides__card {
    padding: 22px;
    border: 1px solid rgb(27 67 50 / 0.1);
    border-radius: 10px;
    background: #f8f6f0;
    color: inherit;
    text-decoration: none;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .luxe-guides__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgb(27 67 50 / 0.08);
  }

  .luxe-guides__title {
    margin: 0 0 8px;
    font-size: 1rem;
  }

  .luxe-guides__text {
    margin: 0 0 12px;
    color: rgb(27 67 50 / 0.88);
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .luxe-guides__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: #1b4332;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .luxe-guides__latest {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid rgb(27 67 50 / 0.1);
  }

  .luxe-guides__latest-heading {
    margin: 0 0 12px;
    font-size: 1rem;
  }

  .luxe-guides__latest-list li {
    margin-bottom: 8px;
  }

  .luxe-guides__latest-list a {
    color: #1b4332;
    text-decoration: none;
  }

  .luxe-guides__latest-list a:hover {
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf tea guides",
  "tag": "section",
  "class": "luxe-guides-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Uses live Tea Guides articles when the tea-guides blog has posts. Until then, cards link to FAQ and collections so nothing 404s."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Tea guides"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Learn to brew premium loose leaf tea"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Expert tips that help you shop with confidence — and get more flavor from every leaf."
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "Luxe Leaf tea guides"
    }
  ]
}
{% endschema %}
