{%- doc -%}
  Footer newsletter signup — high-contrast field, conversion + SEO.
{%- enddoc -%}

{%- form 'customer', id: 'LuxeFooterNewsletter', class: 'luxe-brand-footer__newsletter-form' -%}
  <input type="hidden" name="contact[tags]" value="newsletter, footer, luxe-leaf-list">

  <div class="luxe-brand-footer__newsletter-field">
    <label class="luxe-brand-footer__newsletter-label" for="LuxeFooterNewsletterEmail">
      Email
    </label>
    <input
      id="LuxeFooterNewsletterEmail"
      class="luxe-brand-footer__newsletter-input"
      type="email"
      name="contact[email]"
      value="{{ form.email }}"
      autocomplete="email"
      inputmode="email"
      enterkeyhint="send"
      autocapitalize="off"
      autocorrect="off"
      spellcheck="false"
      placeholder="{{ placeholder | default: 'you@email.com' }}"
      required
      aria-required="true"
      {% if form.errors %}
        aria-invalid="true"
        aria-describedby="LuxeFooterNewsletterHint LuxeFooterNewsletterError"
      {% elsif form.posted_successfully? %}
        aria-describedby="LuxeFooterNewsletterSuccess"
      {% else %}
        aria-describedby="LuxeFooterNewsletterHint"
      {% endif %}
    >
    <button
      type="submit"
      class="button luxe-brand-footer__newsletter-btn"
      title="Subscribe for harvest alerts and brewing tips"
    >
      {{ button_label | default: 'Subscribe' }}
    </button>
  </div>

  <p id="LuxeFooterNewsletterHint" class="luxe-brand-footer__newsletter-hint">
    Brewing tips, new harvests, and exclusive offers — unsubscribe anytime.
  </p>

  {%- if form.errors -%}
    <p id="LuxeFooterNewsletterError" class="luxe-brand-footer__newsletter-message luxe-brand-footer__newsletter-message--error" role="alert">
      {{ form.errors.translated_fields.email | capitalize }}
      {{ form.errors.messages.email }}
    </p>
  {%- elsif form.posted_successfully? -%}
    <p id="LuxeFooterNewsletterSuccess" class="luxe-brand-footer__newsletter-message luxe-brand-footer__newsletter-message--success" role="status">
      {{ success_message | default: 'Welcome — check your inbox for brewing tips soon.' }}
    </p>
  {%- endif -%}
{%- endform -%}
