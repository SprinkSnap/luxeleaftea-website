{%- doc -%}
  Renders the Luxe Leaf Tea horizontal brand logo from theme assets.

  @param {string} [class] - CSS class for the img element
  @param {string} [style] - Inline styles for the img element
  @param {string} [alt] - Alt text override
{%- enddoc -%}

{%- liquid
  assign logo_aspect_ratio = 4.52
  assign logo_height = settings.logo_height | default: 48
  assign logo_height_mobile = settings.logo_height_mobile | default: 36
  assign logo_width = logo_height | times: logo_aspect_ratio | round
  assign logo_width_mobile = logo_height_mobile | times: logo_aspect_ratio | round
  assign logo_alt = alt | default: 'Luxe Leaf Tea logo — premium Chinese loose-leaf tea'
  assign logo_class = class | default: 'header-logo__image'
-%}

<picture>
  <source
    type="image/webp"
    srcset="{{ 'luxe-leaf-tea-logo-header-sm.webp' | asset_url }} 1x, {{ 'luxe-leaf-tea-logo-header-sm-2x.webp' | asset_url }} 2x"
    media="(max-width: 749px)"
  >
  <source
    type="image/webp"
    srcset="{{ 'luxe-leaf-tea-logo-header.webp' | asset_url }} 1x, {{ 'luxe-leaf-tea-logo-header-2x.webp' | asset_url }} 2x"
  >
  <img
    src="{{ 'luxe-leaf-tea-logo-header.png' | asset_url }}"
    srcset="
      {{ 'luxe-leaf-tea-logo-header-sm.png' | asset_url }} {{ logo_width_mobile }}w,
      {{ 'luxe-leaf-tea-logo-header-sm-2x.png' | asset_url }} {{ logo_width_mobile | times: 2 }}w,
      {{ 'luxe-leaf-tea-logo-header.png' | asset_url }} {{ logo_width }}w,
      {{ 'luxe-leaf-tea-logo-header-2x.png' | asset_url }} {{ logo_width | times: 2 }}w
    "
    sizes="(max-width: 749px) {{ logo_width_mobile }}px, {{ logo_width }}px"
    width="{{ logo_width }}"
    height="{{ logo_height }}"
    alt="{{ logo_alt | escape }}"
    class="{{ logo_class }}"
    {% if style != blank %}
      style="{{ style }}"
    {% endif %}
    decoding="async"
    fetchpriority="high"
  >
</picture>
