{%- doc -%}
  Crisp Luxe Leaf Tea horizontal logo for the storefront header.
  Fixed intrinsic widths (162 / 325 / 217 / 434) so browsers pick sharp 1x/2x assets.
{%- enddoc -%}

{%- liquid
  assign logo_height = settings.logo_height | default: 38
  assign logo_height_mobile = settings.logo_height_mobile | default: 30
  assign logo_width = logo_height | times: 4.52 | round
  assign logo_width_mobile = logo_height_mobile | times: 4.52 | round
  assign logo_alt = alt | default: 'Luxe Leaf Tea — premium loose leaf tea'
  assign logo_class = class | default: 'header-logo__image'
-%}

<picture class="luxe-brand-logo__picture">
  <source
    type="image/webp"
    media="(max-width: 749px)"
    srcset="{{ 'luxe-leaf-tea-logo-header-sm.webp' | asset_url }} 162w, {{ 'luxe-leaf-tea-logo-header-sm-2x.webp' | asset_url }} 325w"
    sizes="{{ logo_width_mobile }}px"
  >
  <source
    type="image/webp"
    srcset="{{ 'luxe-leaf-tea-logo-header.webp' | asset_url }} 217w, {{ 'luxe-leaf-tea-logo-header-2x.webp' | asset_url }} 434w"
    sizes="{{ logo_width }}px"
  >
  <img
    src="{{ 'luxe-leaf-tea-logo-header.png' | asset_url }}"
    srcset="
      {{ 'luxe-leaf-tea-logo-header-sm.png' | asset_url }} 162w,
      {{ 'luxe-leaf-tea-logo-header-sm-2x.png' | asset_url }} 325w,
      {{ 'luxe-leaf-tea-logo-header.png' | asset_url }} 217w,
      {{ 'luxe-leaf-tea-logo-header-2x.png' | asset_url }} 434w
    "
    sizes="(max-width: 749px) {{ logo_width_mobile }}px, {{ logo_width }}px"
    width="{{ logo_width }}"
    height="{{ logo_height }}"
    alt="{{ logo_alt | escape }}"
    class="{{ logo_class }} luxe-brand-logo__image"
    {% if style != blank %}
      style="{{ style }}"
    {% endif %}
    decoding="async"
    fetchpriority="high"
  >
</picture>
