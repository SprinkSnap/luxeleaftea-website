{%- doc -%}
  Optional Canada tax estimate by province. Never blocks Pay — tax is finalized at checkout.
{%- enddoc -%}

{%- unless settings.brand_navigation == false or cart.empty? -%}
  <details class="luxe-ca-tax" data-ca-tax-selector>
    <summary class="luxe-ca-tax__summary">
      <span class="luxe-ca-tax__summary-label">Optional: estimate tax by province</span>
      <span class="luxe-ca-tax__summary-hint">Tax finalized at checkout</span>
    </summary>
    <div class="luxe-ca-tax__body">
      <label class="luxe-ca-tax__field">
        <span class="luxe-ca-tax__label">Province / territory</span>
        <select
          class="luxe-ca-tax__select"
          data-ca-province
          autocomplete="address-level1"
          aria-describedby="luxe-ca-tax-help-{{ city_list_id | default: 'default' }}"
        >
          <option value="">Select for estimate</option>
          <option value="AB">Alberta</option>
          <option value="BC">British Columbia</option>
          <option value="MB">Manitoba</option>
          <option value="NB">New Brunswick</option>
          <option value="NL">Newfoundland and Labrador</option>
          <option value="NS">Nova Scotia</option>
          <option value="NT">Northwest Territories</option>
          <option value="NU">Nunavut</option>
          <option value="ON">Ontario</option>
          <option value="PE">Prince Edward Island</option>
          <option value="QC">Quebec</option>
          <option value="SK">Saskatchewan</option>
          <option value="YT">Yukon</option>
        </select>
      </label>
      <p
        id="luxe-ca-tax-help-{{ city_list_id | default: 'default' }}"
        class="luxe-ca-tax__note"
        data-ca-tax-note
      >
        Skip this and tap Pay — Shopify checkout calculates exact tax from your address.
      </p>
      <p class="luxe-ca-tax__rate" data-ca-tax-rate hidden></p>
    </div>
  </details>
{%- endunless -%}
