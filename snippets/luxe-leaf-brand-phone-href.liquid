{%- liquid
  assign brand_phone = settings.brand_phone | strip
  if brand_phone == blank and shop.address.phone != blank
    assign brand_phone = shop.address.phone | strip
  endif

  if brand_phone != blank
    assign phone_digits = brand_phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' | remove: '.' | remove: '+' | remove: 'tel:' | remove: 'Tel:'

    if phone_digits.size == 11
      assign phone_leading = phone_digits | slice: 0, 1
      if phone_leading == '1'
        assign phone_digits = phone_digits | slice: 1, 10
      endif
    endif

    assign brand_phone = phone_digits
  endif
-%}{{- brand_phone -}}
