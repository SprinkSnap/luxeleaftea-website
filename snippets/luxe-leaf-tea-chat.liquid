{%- doc -%}
  Luxe Leaf Tea AI chat guide — human-feel assistant for loose leaf tea shoppers.
{%- enddoc -%}

{%- unless settings.tea_chat_enabled == false -%}
<script src="{{ 'luxe-leaf-tea-chat.js' | asset_url }}" defer></script>

<luxe-tea-chat
  class="luxe-tea-chat"
  data-agent-name="{{ settings.tea_chat_agent_name | default: 'Mei — Tea Guide' | escape }}"
  data-free-shipping="{{ settings.free_shipping_threshold | default: 5000 }}"
  data-shop-url="{{ routes.all_products_collection_url }}"
  data-faq-url="/pages/faq"
  data-about-url="/pages/about"
  data-contact-url="/pages/contact"
  hidden
>
  <button
    type="button"
    class="luxe-tea-chat__launcher"
    aria-label="Chat with our tea guide about premium loose leaf tea"
    aria-expanded="false"
    aria-controls="luxe-tea-chat-panel"
    data-chat-launcher
  >
    <span class="luxe-tea-chat__launcher-icon" aria-hidden="true">
      {%- render 'luxe-leaf-icon', name: 'cup', class: 'luxe-icon--md' -%}
    </span>
    <span class="luxe-tea-chat__launcher-text">Tea Guide</span>
  </button>

  <div
    id="luxe-tea-chat-panel"
    class="luxe-tea-chat__panel"
    role="dialog"
    aria-label="Luxe Leaf Tea guide chat"
    aria-modal="true"
    hidden
    data-chat-panel
  >
    <header class="luxe-tea-chat__header">
      <div class="luxe-tea-chat__header-copy">
        <p class="luxe-tea-chat__eyebrow">Premium loose leaf tea</p>
        <h2 class="luxe-tea-chat__title">{{ settings.tea_chat_agent_name | default: 'Mei — Tea Guide' }}</h2>
      </div>
      <button type="button" class="luxe-tea-chat__close button-unstyled" aria-label="Close chat" data-chat-close>
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
    </header>

    <div class="luxe-tea-chat__messages" data-chat-messages role="log" aria-live="polite"></div>

    <div class="luxe-tea-chat__quick-replies" data-chat-quick-replies role="group" aria-label="Quick questions"></div>

    <form class="luxe-tea-chat__form" data-chat-form>
      <label class="visually-hidden" for="luxe-tea-chat-input">Ask about our teas</label>
      <input
        id="luxe-tea-chat-input"
        class="luxe-tea-chat__input"
        type="text"
        name="message"
        placeholder="Ask about brewing, shipping, or which tea to try…"
        autocomplete="off"
        data-chat-input
      >
      <button type="submit" class="luxe-tea-chat__send button" aria-label="Send message">Send</button>
    </form>

    <p class="luxe-tea-chat__footer-note">
      Real tea guidance ·
      <button type="button" class="luxe-tea-chat__inbox-link button-unstyled" data-open-inbox>Talk to our team</button>
    </p>
  </div>
</luxe-tea-chat>

{% stylesheet %}
  .luxe-tea-chat {
    --chat-z: calc(var(--layer-menu-drawer) + 2);
    position: fixed;
    right: 1rem;
    bottom: calc(1rem + var(--luxe-mobile-bar-height, 0px));
    z-index: var(--chat-z);
  }

  .luxe-tea-chat__launcher {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem 0.75rem 0.85rem;
    border: none;
    border-radius: 999px;
    background: var(--luxe-jade);
    color: #fff;
    box-shadow: var(--luxe-shadow);
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .luxe-tea-chat__launcher:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 36px rgb(27 67 50 / 0.22);
  }

  .luxe-tea-chat__launcher-icon {
    display: inline-flex;
    color: var(--luxe-gold);
  }

  .luxe-tea-chat__launcher-text {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .luxe-tea-chat__launcher-text {
      display: inline;
    }
  }

  .luxe-tea-chat__panel {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.75rem);
    width: min(22rem, calc(100vw - 2rem));
    max-height: min(32rem, 70vh);
    display: flex;
    flex-direction: column;
    border-radius: var(--luxe-radius-lg);
    background: #fff;
    box-shadow: var(--luxe-shadow);
    overflow: hidden;
    border: 1px solid rgb(var(--luxe-jade-rgb) / 0.12);
  }

  .luxe-tea-chat__panel[hidden] {
    display: none !important;
  }

  .luxe-tea-chat__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem 1rem 0.75rem;
    background: linear-gradient(135deg, var(--luxe-jade), rgb(var(--luxe-jade-rgb) / 0.85));
    color: #fff;
  }

  .luxe-tea-chat__eyebrow {
    margin: 0 0 0.15rem;
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--luxe-gold);
  }

  .luxe-tea-chat__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
  }

  .luxe-tea-chat__close {
    color: #fff;
    padding: 0.25rem;
    cursor: pointer;
  }

  .luxe-tea-chat__close svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .luxe-tea-chat__messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--luxe-cream);
  }

  .luxe-tea-chat__bubble {
    max-width: 90%;
    padding: 0.65rem 0.85rem;
    border-radius: 1rem;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .luxe-tea-chat__bubble--agent {
    align-self: flex-start;
    background: #fff;
    color: rgb(var(--luxe-jade-rgb) / 0.95);
    border-bottom-left-radius: 0.25rem;
    box-shadow: var(--luxe-shadow-soft);
  }

  .luxe-tea-chat__bubble--user {
    align-self: flex-end;
    background: var(--luxe-jade);
    color: #fff;
    border-bottom-right-radius: 0.25rem;
  }

  .luxe-tea-chat__bubble a {
    color: inherit;
    font-weight: 600;
    text-decoration: underline;
  }

  .luxe-tea-chat__quick-replies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0 1rem 0.65rem;
    background: var(--luxe-cream);
  }

  .luxe-tea-chat__quick-replies button {
    padding: 0.35rem 0.65rem;
    border: 1px solid rgb(var(--luxe-jade-rgb) / 0.2);
    border-radius: 999px;
    background: #fff;
    color: var(--luxe-jade);
    font-size: 0.75rem;
    cursor: pointer;
  }

  .luxe-tea-chat__form {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid rgb(var(--luxe-jade-rgb) / 0.1);
    background: #fff;
  }

  .luxe-tea-chat__input {
    flex: 1;
    min-width: 0;
    padding: 0.55rem 0.75rem;
    border: 1px solid rgb(var(--luxe-jade-rgb) / 0.2);
    border-radius: var(--luxe-radius);
    font-size: 0.875rem;
  }

  .luxe-tea-chat__send {
    padding-inline: 1rem;
    background: var(--luxe-gold);
    border-color: var(--luxe-gold);
    color: var(--luxe-ink);
    white-space: nowrap;
  }

  .luxe-tea-chat__footer-note {
    margin: 0;
    padding: 0.5rem 1rem 0.75rem;
    font-size: 0.6875rem;
    text-align: center;
    color: rgb(var(--luxe-jade-rgb) / 0.65);
    background: #fff;
  }

  .luxe-tea-chat__inbox-link {
    color: var(--luxe-jade);
    text-decoration: underline;
    cursor: pointer;
  }

  @media screen and (max-width: 749px) {
    .luxe-tea-chat {
      right: 0.75rem;
      bottom: calc(0.75rem + var(--luxe-mobile-bar-height, 0px));
    }

    .luxe-tea-chat__panel {
      position: fixed;
      inset: auto 0 0 0;
      width: 100%;
      max-height: 85vh;
      border-radius: var(--luxe-radius-lg) var(--luxe-radius-lg) 0 0;
    }
  }
{% endstylesheet %}
{%- endunless -%}
