{% doc %}
  Chat Drawer

  Renders a theme-drawer host for `<shopify-chat>`. The markup is always
  present — when the Inbox app is installed it registers the custom element
  and the chat activates. Without Inbox the element is inert.

  @example
  {% render 'chat-drawer' %}
{% enddoc %}

<theme-drawer id="chat-drawer">
  <dialog
    ref="panel"
    class="theme-drawer__dialog chat-drawer"
  >
    <shopify-chat
      mode="standalone"
      mode-switch
    ></shopify-chat>
  </dialog>
</theme-drawer>

<script type="module">
  const chatDrawer = document.querySelector('#chat-drawer');
  const shopifyChat = document.querySelector('shopify-chat');

  document.addEventListener('theme-drawer:open', (event) => {
    if (/** @type {Element} */ (event.target).id !== 'chat-drawer') return;
    shopifyChat?.setAttribute('mode', 'managed');
  });

  document.addEventListener('theme-drawer:close', (event) => {
    if (/** @type {Element} */ (event.target).id !== 'chat-drawer') return;
    // If mode is still managed, this is a theme-initiated close (backdrop /
    // Escape) — close the chat so the FAB appears. If mode is already
    // standalone, the close was triggered by an undock (enter-standalone sets
    // mode before closing the drawer) — leave the chat open as a floating panel.
    if (shopifyChat?.getAttribute('mode') === 'managed') {
      shopifyChat?.removeAttribute('open');
    }
    shopifyChat?.setAttribute('mode', 'standalone');
  });

  document.addEventListener('shopify-chat:enter-managed', () => {
    // Captured at event-fire time — the dock-transition animation hint below
    // depends on state as it was when the event was dispatched.
    const isStandaloneAndOpen = shopifyChat?.hasAttribute('open') && shopifyChat?.getAttribute('mode') === 'standalone';

    // The activator-click path (FAB click on desktop with stored
    // preferredMode=managed) dispatches enter-managed *before* calling show(),
    // so the chat's `open` attribute at event time understates the imminent
    // outcome. Defer to a microtask: by then show() (if any) has run, and we
    // can distinguish the viewport-driven mobile→desktop transition that left
    // a minimized FAB (chat stays closed → don't open an empty drawer) from
    // an activator click (chat just opened → open the drawer).
    queueMicrotask(() => {
      if (!shopifyChat?.hasAttribute('open') && !chatDrawer?.hasAttribute('open')) {
        return;
      }
      chatDrawer?.open?.(isStandaloneAndOpen ? { enter: 'inline-start' } : undefined);
    });
  });

  document.addEventListener('shopify-chat:enter-standalone', () => {
    shopifyChat?.setAttribute('mode', 'standalone');
    chatDrawer?.close?.();
  });

  document.addEventListener('shopify-chat:close', () => {
    if (shopifyChat?.getAttribute('mode') === 'managed') {
      chatDrawer?.close?.();
    }
  });

  document.addEventListener('megaMenu:hover', () => {
    if (shopifyChat?.hasAttribute('open') && shopifyChat?.getAttribute('mode') === 'standalone') {
      shopifyChat?.removeAttribute('open');
    }
  });

  // After the chat upgrades it self-restores its preferred mode from
  // sessionStorage. Reconcile any mismatch with the theme-drawer's state
  // — the drawer is the source of truth for which mode the chat should
  // be in (open → managed, closed → standalone).
  customElements.whenDefined('shopify-chat').then(() => {
    const mode = chatDrawer?.hasAttribute('open') ? 'managed' : 'standalone';
    if (shopifyChat?.getAttribute('mode') !== mode) {
      // When switching managed → standalone (e.g. narrow viewport skipped
      // drawer restore), also close the chat so it renders as the FAB
      // rather than an open standalone panel.
      if (mode === 'standalone' && shopifyChat?.hasAttribute('open')) {
        shopifyChat?.removeAttribute('open');
      }
      shopifyChat?.setAttribute('mode', mode);
    }
  });
</script>

{%- unless settings.brand_navigation == false -%}
  {%- render 'luxe-leaf-shipping-nudge' -%}
  {%- liquid
    assign threshold = settings.free_shipping_threshold | default: 5000
    assign standard_rate = settings.standard_shipping_rate | default: 995
    if cart.total_price >= threshold
      assign mobile_shipping_cost = 0
    else
      assign mobile_shipping_cost = standard_rate
    endif
    assign mobile_estimated_total = cart.total_price | plus: mobile_shipping_cost
    assign is_pdp_buy_bar = false
    if request.page_type == 'product'
      assign is_pdp_buy_bar = true
    endif
  -%}
  <nav
    class="luxe-mobile-bar{% if cart.item_count > 0 %} luxe-mobile-bar--has-cart{% endif %}{% if is_pdp_buy_bar %} luxe-mobile-bar--pdp{% endif %}"
    aria-label="{% if is_pdp_buy_bar %}Product buy bar — add to bag and checkout{% else %}Quick shop navigation{% endif %}"
    data-mobile-shop-bar
    {% if is_pdp_buy_bar %}data-pdp-buy-bar{% endif %}
  >
    <button
      type="button"
      class="luxe-mobile-bar__menu button button-secondary"
      data-luxe-nav-toggle
      aria-label="Open menu — About, Contact, FAQ, and customer support"
      aria-controls="LuxeBrandMenuPanel"
      aria-expanded="false"
      data-mobile-menu-toggle
    >
      <span class="svg-wrapper luxe-mobile-bar__menu-icon" aria-hidden="true">
        {% render 'luxe-leaf-tea-menu-icon' %}
      </span>
      <span class="luxe-mobile-bar__menu-label">Menu</span>
    </button>

    {%- if is_pdp_buy_bar -%}
      <button
        type="button"
        class="luxe-mobile-bar__atc button"
        data-mobile-pdp-atc
        aria-label="{% if product %}Add {{ product.title | escape }} to bag{% else %}Add to bag{% endif %}"
      >
        <span class="luxe-mobile-bar__atc-label luxe-mobile-bar__atc-label--long" data-mobile-pdp-atc-label>
          Add to Bag
        </span>
        <span class="luxe-mobile-bar__atc-label luxe-mobile-bar__atc-label--short" aria-hidden="true" data-mobile-pdp-atc-short>
          Add
        </span>
      </button>
    {%- else -%}
      <a
        href="{{ routes.all_products_collection_url }}"
        class="luxe-mobile-bar__shop button"
        aria-label="Shop Tea — browse all premium loose leaf teas"
      >
        <span class="luxe-mobile-bar__shop-label luxe-mobile-bar__shop-label--long">Shop Tea</span>
        <span class="luxe-mobile-bar__shop-label luxe-mobile-bar__shop-label--short" aria-hidden="true">Shop</span>
      </a>
    {%- endif -%}

    {%- if settings.cart_type == 'drawer' -%}
      <button
        type="button"
        class="luxe-mobile-bar__cart button button-secondary"
        data-mobile-cart-toggle
        data-luxe-open-cart
        aria-label="View bag — {{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %}"
      >
        <span class="luxe-mobile-bar__cart-icon" aria-hidden="true">
          {%- render 'luxe-leaf-header-icon', name: 'cart' -%}
          <span class="luxe-mobile-bar__count" data-mobile-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>
            {{- cart.item_count -}}
          </span>
        </span>
        <span class="luxe-mobile-bar__cart-label" data-mobile-cart-label>Bag</span>
      </button>
    {%- else -%}
      <a href="{{ routes.cart_url }}" class="luxe-mobile-bar__cart button button-secondary" aria-label="View bag">
        {{- 'icon-cart.svg' | inline_asset_content -}}
        <span class="luxe-mobile-bar__cart-label">Bag</span>
      </a>
    {%- endif -%}

    <form action="{{ routes.cart_url }}" method="post" class="luxe-mobile-bar__checkout-form">
      <button
        type="button"
        class="luxe-mobile-bar__checkout button"
        data-mobile-checkout
        aria-label="Go to secure checkout"
        {% if cart.item_count == 0 %}hidden{% endif %}
      >
        Checkout
      </button>
    </form>
  </nav>

  {%- unless settings.tea_chat_enabled == false -%}
    {%- liquid
      assign chat_ship_cents = settings.free_shipping_threshold | default: 5000
      assign chat_ship_dollars = chat_ship_cents | divided_by: 100
    -%}
    <script src="{{ 'luxe-leaf-tea-chat.js' | asset_url }}" defer></script>
    {%- comment -%}
      No sitewide FAQPage / WebApplication JSON-LD here.
      FAQ rich results come only from visible FAQ sections (home + /pages/faq).
      Organization ContactPoint lives in luxe-leaf-footer-schema.
    {%- endcomment -%}
    <luxe-tea-chat
      class="luxe-tea-chat"
      data-agent-name="{{ settings.tea_chat_agent_name | default: 'Mei — Tea Guide' | escape }}"
      data-api-url="{{ settings.tea_chat_api_url | escape }}"
      data-free-shipping="{{ chat_ship_cents }}"
      data-standard-shipping="{{ settings.standard_shipping_rate | default: 995 }}"
      data-shop-url="{{ routes.all_products_collection_url }}"
      data-faq-url="/pages/faq"
      data-about-url="/pages/about"
      data-contact-url="/pages/contact"
      hidden
    >
      <button
        type="button"
        class="luxe-tea-chat__launcher"
        aria-label="Chat with our free tea guide — premium loose leaf tea recommendations, brewing tips, and free shipping help"
        aria-expanded="false"
        aria-controls="luxe-tea-chat-panel"
        data-chat-launcher
      >
        <span class="luxe-tea-chat__launcher-icon" aria-hidden="true">
          {{- 'icon-chat-bubble.svg' | inline_asset_content -}}
        </span>
        <span class="luxe-tea-chat__launcher-text">Ask Mei</span>
        <span class="luxe-tea-chat__launcher-badge" data-chat-badge hidden aria-hidden="true">1</span>
      </button>

      <button
        type="button"
        class="luxe-tea-chat__backdrop"
        aria-label="Minimize tea guide chat"
        tabindex="-1"
        hidden
        data-chat-backdrop
      ></button>

      <div
        id="luxe-tea-chat-panel"
        class="luxe-tea-chat__panel"
        role="dialog"
        aria-labelledby="luxe-tea-chat-title"
        aria-modal="true"
        hidden
        data-chat-panel
      >
        <div class="luxe-tea-chat__sheet-handle" data-chat-handle aria-hidden="true">
          <span class="luxe-tea-chat__sheet-handle-bar"></span>
        </div>

        <header class="luxe-tea-chat__header">
          <div class="luxe-tea-chat__header-copy">
            <p class="luxe-tea-chat__eyebrow">
              <span class="luxe-tea-chat__status-dot" aria-hidden="true"></span>
              Online · Free tea guide
            </p>
            <h2 class="luxe-tea-chat__title" id="luxe-tea-chat-title">
              {{ settings.tea_chat_agent_name | default: 'Mei — Tea Guide' }}
            </h2>
            <p class="luxe-tea-chat__subtitle">
              Premium loose leaf recommendations, brewing tips, and free Canada-wide shipping over ${{ chat_ship_dollars }}
            </p>
          </div>
          <div class="luxe-tea-chat__header-actions">
            <button
              type="button"
              class="luxe-tea-chat__header-shop button button-unstyled"
              data-chat-shop
              aria-label="Shop premium loose leaf tea collection"
            >
              Shop
            </button>
            <button
              type="button"
              class="luxe-tea-chat__clear-btn button-unstyled"
              aria-label="Clear conversation and start a new tea chat"
              title="Clears this conversation and starts fresh"
              data-chat-clear
            >
              <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none">
                <path d="M4 7h16M9 7V5h6v2M8 7l1 12h6l1-12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="luxe-tea-chat__clear-btn-label">New chat</span>
            </button>
            <button
              type="button"
              class="luxe-tea-chat__icon-btn luxe-tea-chat__minimize button-unstyled"
              aria-label="Minimize chat to the bubble"
              title="Minimize to chat bubble"
              data-chat-minimize
            >
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none">
                <path d="M6 10l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="luxe-tea-chat__icon-btn-label">Hide</span>
            </button>
            <button
              type="button"
              class="luxe-tea-chat__icon-btn luxe-tea-chat__close button-unstyled"
              aria-label="Close chat"
              title="Close chat"
              data-chat-close
            >
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none">
                <path d="M7 7l10 10M17 7 7 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              <span class="luxe-tea-chat__icon-btn-label">Close</span>
            </button>
          </div>
        </header>

        <p class="luxe-tea-chat__seo-copy">
          Use Luxe Leaf Tea’s free AI tea guide chat to get premium loose leaf tea recommendations, brewing tips,
          gift ideas, and free shipping details over ${{ chat_ship_dollars }}. Ask which green, oolong, black, or
          pu-erh tea to try first. Start a new chat anytime to reset the conversation, or minimize to keep shopping.
        </p>

        <div class="luxe-tea-chat__toast" data-chat-toast hidden role="status" aria-live="polite"></div>

        <div class="luxe-tea-chat__messages" data-chat-messages role="log" aria-live="polite" aria-relevant="additions"></div>

        <div class="luxe-tea-chat__composer">
          <div class="luxe-tea-chat__quick-replies" data-chat-quick-replies role="group" aria-label="Popular tea questions"></div>

          <div class="luxe-tea-chat__conversion" aria-label="Quick shopping actions">
            <button type="button" class="luxe-tea-chat__conversion-shop" data-chat-shop>
              Shop loose leaf tea
            </button>
            <button type="button" class="luxe-tea-chat__conversion-ship" data-chat-shipping-prompt>
              Free Canada-wide shipping ${{ chat_ship_dollars }}+
            </button>
          </div>

          <form class="luxe-tea-chat__form" data-chat-form>
            <label class="visually-hidden" for="luxe-tea-chat-input">
              Type your question about premium loose leaf tea, brewing, or shipping
            </label>
            <input
              id="luxe-tea-chat-input"
              class="luxe-tea-chat__input"
              type="text"
              name="message"
              placeholder="Ask about tea, brewing, or shipping…"
              autocomplete="off"
              enterkeyhint="send"
              maxlength="500"
              data-chat-input
              style="background:#ffffff;color:#14261d;-webkit-text-fill-color:#14261d;"
            >
            <button type="submit" class="luxe-tea-chat__send button" aria-label="Send tea question">
              <span class="luxe-tea-chat__send-label">Send</span>
              <svg class="luxe-tea-chat__send-icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none">
                <path d="M3.4 11.2 20.2 3.6c.7-.3 1.4.4 1.1 1.1L13.7 21.5c-.3.7-1.3.6-1.5-.2l-1.9-6.4-6.4-1.9c-.8-.2-.9-1.2-.5-1.8Z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
              </svg>
            </button>
          </form>

          <p class="luxe-tea-chat__footer-note">
            <button type="button" class="luxe-tea-chat__inbox-link button-unstyled" data-open-inbox>Talk to our team</button>
            <span aria-hidden="true"> · </span>
            <a href="{{ routes.all_products_collection_url }}" class="luxe-tea-chat__footer-shop">Shop premium loose leaf</a>
            <span class="luxe-tea-chat__footer-ship"> · Free Canada-wide shipping ${{ chat_ship_dollars }}+</span>
          </p>
        </div>
      </div>
    </luxe-tea-chat>
  {%- endunless -%}
{%- endunless -%}

{% stylesheet %}
  /* Pin the chat's mobile/desktop boundary so the theme and the chat agree
     on where standalone mode kicks in. Must stay in sync with the @media
     query below — @shopify/storefront-components reads this value once at
     init and uses it to decide when to force standalone mode. */
  shopify-chat {
    --shopify-chat-breakpoint: 768px;
  }

  shopify-chat[mode='managed'] {
    position: static;
    height: 100%;
  }

  .theme-drawer__dialog:has(shopify-chat[mode='standalone'][open]) {
    z-index: calc(var(--layer-menu-drawer) + 1);
  }

  /* Keep the panel rendered while closed so <shopify-chat>'s position-fixed
     "Ask anything" launcher stays visible. */
  .theme-drawer__dialog.chat-drawer:has(shopify-chat:defined) {
    display: flex;
  }
{% endstylesheet %}
