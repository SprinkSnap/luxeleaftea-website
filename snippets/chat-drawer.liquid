{% doc %}
  Chat Drawer

  Renders a theme-drawer host for `<shopify-chat>`. The markup is always
  present — when the Inbox app is installed it registers the custom element
  and the chat activates. Without Inbox the element is inert.

  @example
  {% render 'chat-drawer' %}
{% enddoc %}

<theme-drawer id="chat-drawer">
  <dialog
    ref="panel"
    class="theme-drawer__dialog chat-drawer"
  >
    <shopify-chat
      mode="standalone"
      mode-switch
    ></shopify-chat>
  </dialog>
</theme-drawer>

<script type="module">
  const chatDrawer = document.querySelector('#chat-drawer');
  const shopifyChat = document.querySelector('shopify-chat');

  document.addEventListener('theme-drawer:open', (event) => {
    if (/** @type {Element} */ (event.target).id !== 'chat-drawer') return;
    shopifyChat?.setAttribute('mode', 'managed');
  });

  document.addEventListener('theme-drawer:close', (event) => {
    if (/** @type {Element} */ (event.target).id !== 'chat-drawer') return;
    // If mode is still managed, this is a theme-initiated close (backdrop /
    // Escape) — close the chat so the FAB appears. If mode is already
    // standalone, the close was triggered by an undock (enter-standalone sets
    // mode before closing the drawer) — leave the chat open as a floating panel.
    if (shopifyChat?.getAttribute('mode') === 'managed') {
      shopifyChat?.removeAttribute('open');
    }
    shopifyChat?.setAttribute('mode', 'standalone');
  });

  document.addEventListener('shopify-chat:enter-managed', () => {
    // Captured at event-fire time — the dock-transition animation hint below
    // depends on state as it was when the event was dispatched.
    const isStandaloneAndOpen = shopifyChat?.hasAttribute('open') && shopifyChat?.getAttribute('mode') === 'standalone';

    // The activator-click path (FAB click on desktop with stored
    // preferredMode=managed) dispatches enter-managed *before* calling show(),
    // so the chat's `open` attribute at event time understates the imminent
    // outcome. Defer to a microtask: by then show() (if any) has run, and we
    // can distinguish the viewport-driven mobile→desktop transition that left
    // a minimized FAB (chat stays closed → don't open an empty drawer) from
    // an activator click (chat just opened → open the drawer).
    queueMicrotask(() => {
      if (!shopifyChat?.hasAttribute('open') && !chatDrawer?.hasAttribute('open')) {
        return;
      }
      chatDrawer?.open?.(isStandaloneAndOpen ? { enter: 'inline-start' } : undefined);
    });
  });

  document.addEventListener('shopify-chat:enter-standalone', () => {
    shopifyChat?.setAttribute('mode', 'standalone');
    chatDrawer?.close?.();
  });

  document.addEventListener('shopify-chat:close', () => {
    if (shopifyChat?.getAttribute('mode') === 'managed') {
      chatDrawer?.close?.();
    }
  });

  document.addEventListener('megaMenu:hover', () => {
    if (shopifyChat?.hasAttribute('open') && shopifyChat?.getAttribute('mode') === 'standalone') {
      shopifyChat?.removeAttribute('open');
    }
  });

  // After the chat upgrades it self-restores its preferred mode from
  // sessionStorage. Reconcile any mismatch with the theme-drawer's state
  // — the drawer is the source of truth for which mode the chat should
  // be in (open → managed, closed → standalone).
  customElements.whenDefined('shopify-chat').then(() => {
    const mode = chatDrawer?.hasAttribute('open') ? 'managed' : 'standalone';
    if (shopifyChat?.getAttribute('mode') !== mode) {
      // When switching managed → standalone (e.g. narrow viewport skipped
      // drawer restore), also close the chat so it renders as the FAB
      // rather than an open standalone panel.
      if (mode === 'standalone' && shopifyChat?.hasAttribute('open')) {
        shopifyChat?.removeAttribute('open');
      }
      shopifyChat?.setAttribute('mode', mode);
    }
  });
</script>

{%- unless settings.brand_navigation == false -%}
  {%- unless template.name == 'cart' -%}
    <script type="module" src="{{ 'luxe-leaf-mobile-commerce.js' | asset_url }}"></script>
    <nav
      class="luxe-mobile-bar{% if cart.item_count > 0 %} luxe-mobile-bar--has-cart{% endif %}"
      aria-label="Quick shop navigation"
      data-mobile-shop-bar
    >
      <button
        type="button"
        class="luxe-mobile-bar__menu button button-secondary"
        data-luxe-nav-toggle
        aria-label="Open menu — Home, Shop Tea, About, Contact"
        aria-controls="LuxeBrandMenuPanel"
        aria-expanded="false"
        data-mobile-menu-toggle
      >
        Menu
      </button>
      <a href="{{ routes.all_products_collection_url }}" class="luxe-mobile-bar__shop button">
        Shop Tea
      </a>
      <a
        href="/checkout"
        class="luxe-mobile-bar__checkout button"
        data-mobile-checkout
        {% if cart.item_count == 0 %}hidden{% endif %}
      >
        Checkout · {{ cart.total_price | money }}
      </a>
      {%- if settings.cart_type == 'drawer' -%}
        <button
          type="button"
          class="luxe-mobile-bar__cart button button-secondary"
          data-mobile-cart-toggle
          on:click="#cart-drawer/toggle"
          aria-label="Open cart — premium loose leaf tea"
          {% if cart.item_count > 0 %}hidden{% endif %}
        >
          {%- render 'luxe-leaf-header-icon', name: 'cart' -%}
          <span>{{ 'content.cart_title' | t }}</span>
          <span class="luxe-mobile-bar__count" data-mobile-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
        </button>
      {%- else -%}
        <a href="{{ routes.cart_url }}" class="luxe-mobile-bar__cart button button-secondary" aria-label="View cart">
          {{- 'icon-cart.svg' | inline_asset_content -}}
          <span>{{ 'content.cart_title' | t }}</span>
        </a>
      {%- endif -%}
    </nav>
  {%- endunless -%}

  {%- unless settings.tea_chat_enabled == false -%}
    <script src="{{ 'luxe-leaf-tea-chat.js' | asset_url }}" defer></script>
    <luxe-tea-chat
      class="luxe-tea-chat"
      data-agent-name="{{ settings.tea_chat_agent_name | default: 'Mei — Tea Guide' | escape }}"
      data-api-url="{{ settings.tea_chat_api_url | escape }}"
      data-free-shipping="{{ settings.free_shipping_threshold | default: 5000 }}"
      data-shop-url="{{ routes.all_products_collection_url }}"
      data-faq-url="/pages/faq"
      data-about-url="/pages/about"
      data-contact-url="/pages/contact"
      hidden
    >
      <button
        type="button"
        class="luxe-tea-chat__launcher"
        aria-label="Chat with our tea guide about premium loose leaf tea"
        aria-expanded="false"
        aria-controls="luxe-tea-chat-panel"
        data-chat-launcher
      >
        <span class="luxe-tea-chat__launcher-icon" aria-hidden="true">
          {%- render 'luxe-leaf-icon', name: 'cup', class: 'luxe-icon--md' -%}
        </span>
        <span class="luxe-tea-chat__launcher-text">Tea Guide</span>
      </button>

      <div
        id="luxe-tea-chat-panel"
        class="luxe-tea-chat__panel"
        role="dialog"
        aria-label="Luxe Leaf Tea guide chat"
        aria-modal="true"
        hidden
        data-chat-panel
      >
        <header class="luxe-tea-chat__header">
          <div class="luxe-tea-chat__header-copy">
            <p class="luxe-tea-chat__eyebrow">Premium loose leaf tea</p>
            <h2 class="luxe-tea-chat__title">{{ settings.tea_chat_agent_name | default: 'Mei — Tea Guide' }}</h2>
          </div>
          <button type="button" class="luxe-tea-chat__close button-unstyled" aria-label="Close chat" data-chat-close>
            {{- 'icon-close.svg' | inline_asset_content -}}
          </button>
        </header>

        <div class="luxe-tea-chat__messages" data-chat-messages role="log" aria-live="polite"></div>
        <div class="luxe-tea-chat__quick-replies" data-chat-quick-replies role="group" aria-label="Quick questions"></div>

        <form class="luxe-tea-chat__form" data-chat-form>
          <label class="visually-hidden" for="luxe-tea-chat-input">Ask about our teas</label>
          <input
            id="luxe-tea-chat-input"
            class="luxe-tea-chat__input"
            type="text"
            name="message"
            placeholder="Ask about brewing, shipping, or which tea to try…"
            autocomplete="off"
            data-chat-input
          >
          <button type="submit" class="luxe-tea-chat__send button" aria-label="Send message">Send</button>
        </form>

        <p class="luxe-tea-chat__footer-note">
          Real tea guidance ·
          <button type="button" class="luxe-tea-chat__inbox-link button-unstyled" data-open-inbox>Talk to our team</button>
        </p>
      </div>
    </luxe-tea-chat>
  {%- endunless -%}
{%- endunless -%}

{% stylesheet %}
  /* Pin the chat's mobile/desktop boundary so the theme and the chat agree
     on where standalone mode kicks in. Must stay in sync with the @media
     query below — @shopify/storefront-components reads this value once at
     init and uses it to decide when to force standalone mode. */
  shopify-chat {
    --shopify-chat-breakpoint: 768px;
  }

  shopify-chat[mode='managed'] {
    position: static;
    height: 100%;
  }

  .theme-drawer__dialog:has(shopify-chat[mode='standalone'][open]) {
    z-index: calc(var(--layer-menu-drawer) + 1);
  }

  /* Keep the panel rendered while closed so <shopify-chat>'s position-fixed
     "Ask anything" launcher stays visible. */
  .theme-drawer__dialog.chat-drawer:has(shopify-chat:defined) {
    display: flex;
  }
{% endstylesheet %}
