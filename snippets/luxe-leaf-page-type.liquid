{%- doc -%}
  Returns page type token for Luxe Leaf page templates: about, contact, faq, or default.
{%- enddoc -%}

{%- liquid
  assign luxe_page_type = 'default'

  if request.page_type == 'page' and page != blank
    assign tpl = template | downcase
    assign suffix = template.suffix | downcase
    assign handle = page.handle | downcase

    if suffix == 'contact' or tpl == 'page.contact' or tpl contains '.contact' or handle == 'contact' or handle == 'contact-us' or handle == 'get-in-touch'
      assign luxe_page_type = 'contact'
    elsif suffix == 'about' or tpl == 'page.about' or tpl contains '.about' or handle == 'about' or handle == 'about-us' or handle == 'our-story'
      assign luxe_page_type = 'about'
    elsif suffix == 'faq' or tpl == 'page.faq' or tpl contains '.faq' or handle == 'faq'
      assign luxe_page_type = 'faq'
    endif
  endif
-%}{{- luxe_page_type -}}
