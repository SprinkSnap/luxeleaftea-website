{%- doc -%}
  Shoppable empty state when collection/search filters return zero products.

  @param {string} clear_url - URL that clears active filters (collection URL or search URL)
{%- enddoc -%}

{%- liquid
  assign shop_url = routes.all_products_collection_url
  if collections.all != blank and collections.all.url != blank
    assign shop_url = collections.all.url
  endif

  assign free_ship_label = settings.free_shipping_threshold | default: 5000 | money

  if clear_url == blank
    if request.page_type == 'search'
      assign clear_url = routes.search_url
      if search.terms != blank
        assign clear_url = clear_url | append: '?type=product&q=' | append: search.terms
      endif
    elsif collection != blank and collection.url != blank
      assign clear_url = collection.url
    else
      assign clear_url = shop_url
    endif
  endif
-%}

<div class="luxe-filter-empty" data-testid="filter-empty-state">
  <div class="luxe-filter-empty__inner">
    <p class="luxe-filter-empty__eyebrow">
      {%- render 'luxe-leaf-icon', name: 'leaf', class: 'luxe-icon--sm' -%}
      {{ 'content.filter_empty_eyebrow' | t }}
    </p>
    <h2 class="luxe-filter-empty__heading">
      {{ 'content.filter_empty_heading' | t }}
    </h2>
    <p class="luxe-filter-empty__message">
      {{ 'content.filter_empty_message' | t }}
    </p>

    <div class="luxe-filter-empty__actions">
      <a
        href="{{ clear_url }}"
        class="button luxe-filter-empty__cta luxe-filter-empty__cta--primary"
        title="{{ 'content.filter_empty_clear_cta' | t | escape }}"
      >
        {{ 'content.filter_empty_clear_cta' | t }}
      </a>
      <a
        href="{{ shop_url }}"
        class="button luxe-filter-empty__cta luxe-filter-empty__cta--shop"
        title="{{ 'content.filter_empty_shop_cta' | t | escape }} — free Canada-wide shipping over {{ free_ship_label }}"
      >
        {{ 'content.filter_empty_shop_cta' | t }}
        {%- render 'luxe-leaf-icon', name: 'arrow', class: 'luxe-icon--sm' -%}
      </a>
    </div>

    <div class="luxe-filter-empty__chips" role="list" aria-label="{{ 'content.filter_empty_browse_label' | t }}">
      {%- assign types = 'green-tea|Green Tea,oolong|Oolong,pu-erh|Pu-erh,black-tea|Black Tea' | split: ',' -%}
      {%- for entry in types -%}
        {%- assign parts = entry | split: '|' -%}
        {%- assign handle = parts[0] -%}
        {%- assign title = parts[1] -%}
        {%- assign type_collection = collections[handle] -%}
        {%- if type_collection.url != blank -%}
          {%- assign url = type_collection.url -%}
        {%- else -%}
          {%- assign url = '/collections/' | append: handle -%}
        {%- endif -%}
        <a class="luxe-filter-empty__chip" href="{{ url }}" role="listitem">
          {{ title }}
        </a>
      {%- endfor -%}
    </div>

    <a href="/pages/faq" class="luxe-filter-empty__link">
      {{ 'content.filter_empty_faq_link' | t }}
    </a>
  </div>
</div>

{% stylesheet %}
  .luxe-filter-empty {
    padding-block: var(--padding-6xl);
    padding-inline: var(--page-margin);
  }

  .luxe-filter-empty__inner {
    max-width: 36rem;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  .luxe-filter-empty__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0;
    color: #1b4332;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .luxe-filter-empty__heading {
    margin: 0;
    color: #0d2818;
    font-family: var(--font-heading--family), "Playfair Display", Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    line-height: 1.2;
    text-wrap: balance;
  }

  .luxe-filter-empty__message {
    margin: 0;
    color: #2d4a3e;
    font-size: 1.0625rem;
    line-height: 1.55;
    max-width: 32rem;
  }

  .luxe-filter-empty__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    width: 100%;
    margin-top: 4px;
  }

  .luxe-filter-empty__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-width: min(100%, 12.5rem);
    padding: 14px 24px;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .luxe-filter-empty__cta--primary {
    border: 1px solid #1b4332;
    background: #fff;
    color: #1b4332 !important;
  }

  .luxe-filter-empty__cta--primary:hover,
  .luxe-filter-empty__cta--primary:focus-visible {
    background: #f8f6f0;
    transform: translateY(-1px);
    color: #0d2818 !important;
  }

  .luxe-filter-empty__cta--shop {
    border: none;
    background: linear-gradient(135deg, #f3d56a 0%, #c9a227 100%);
    color: #0d2818 !important;
    box-shadow: 0 4px 16px rgb(201 162 39 / 0.35);
  }

  .luxe-filter-empty__cta--shop:hover,
  .luxe-filter-empty__cta--shop:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgb(201 162 39 / 0.45);
    color: #0d2818 !important;
  }

  .luxe-filter-empty__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    width: 100%;
    margin-top: 6px;
  }

  .luxe-filter-empty__chip {
    display: inline-flex;
    align-items: center;
    padding: 10px 18px;
    border: 1px solid rgb(27 67 50 / 0.18);
    border-radius: 999px;
    background: #fff;
    color: #1b4332;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .luxe-filter-empty__chip:hover,
  .luxe-filter-empty__chip:focus-visible {
    background: #f8f6f0;
    border-color: #1b4332;
    transform: translateY(-1px);
  }

  .luxe-filter-empty__link {
    color: #1b4332;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .luxe-filter-empty__link:hover,
  .luxe-filter-empty__link:focus-visible {
    color: #0d2818;
  }
{% endstylesheet %}
