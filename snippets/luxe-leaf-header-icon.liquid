{%- doc -%}
  Premium tea shop header icons for navigation, search, account, and cart.
  menu — hamburger lines + tea leaf (mobile nav)
  @param {string} name - menu, search, account, cart
{%- enddoc -%}

{%- case name -%}
  {%- when 'menu' -%}
    {% render 'luxe-leaf-tea-menu-icon' %}
  {%- when 'search' -%}
    {{- 'icon-tea-search.svg' | inline_asset_content -}}
  {%- when 'account' -%}
    {{- 'icon-tea-account.svg' | inline_asset_content -}}
  {%- when 'cart' -%}
    {{- 'icon-tea-cart.svg' | inline_asset_content -}}
{%- endcase -%}
