{%- doc -%}
  Enhanced SEO meta tags with premium loose leaf tea defaults and page-type fallbacks.
{%- enddoc -%}

<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1,viewport-fit=cover"
>
<meta name="format-detection" content="telephone=yes">
<meta
  name="theme-color"
  content="#1B4332"
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign brand_default_description = 'Shop premium loose leaf tea from Luxe Leaf Tea. Hand-selected green, oolong, pu-erh, and black teas — packed fresh to order.'
  assign meta_description = page_description | default: shop.description | default: brand_default_description
  assign og_description = meta_description
  assign free_ship_threshold = settings.free_shipping_threshold | default: 5000
  assign free_ship_label = free_ship_threshold | money
  assign standard_ship_label = settings.standard_shipping_rate | default: 595 | money

  if request.page_type == 'index'
    assign og_title = 'Premium Loose Leaf Tea | ' | append: shop.name
    assign meta_description = brand_default_description
    assign og_description = meta_description
  elsif request.page_type == 'collection' and collection
    case collection.handle
      when 'green-tea'
        assign meta_description = 'Shop premium loose leaf green tea — bright, sweet whole-leaf selections packed fresh to order. Free shipping over ' | append: free_ship_label | append: '.'
      when 'oolong'
        assign meta_description = 'Explore premium loose leaf oolong tea — floral, layered, and perfect for multiple steeps. Packed fresh to order.'
      when 'pu-erh'
        assign meta_description = 'Premium loose leaf pu-erh tea — deep, smooth, and ideal for re-steeping. Shop Luxe Leaf Tea.'
      when 'black-tea'
        assign meta_description = 'Shop premium loose leaf black tea — rich, malty, and full-bodied. Packed fresh to order.'
    endcase
    if collection.description != blank
      assign meta_description = collection.description | strip_html | truncate: 155
    endif
    assign og_description = meta_description
  elsif request.page_type == 'product' and product
    assign meta_description = product.description | strip_html | truncate: 155
    if meta_description == blank
      assign meta_description = 'Shop ' | append: product.title | append: ' — premium loose leaf tea packed fresh to order from Luxe Leaf Tea.'
    endif
    assign og_description = meta_description
  elsif request.page_type == 'article' and article
    assign meta_description = article.excerpt | default: article.content | strip_html | truncate: 155
    assign og_description = meta_description
  elsif request.page_type == 'blog'
    assign meta_description = 'Tea guides and brewing tips for premium loose leaf tea — learn, brew, and shop with confidence.'
    assign og_description = meta_description
  elsif request.page_type == 'page' and page.handle == 'faq'
    assign og_title = 'FAQ | Premium Loose Leaf Tea — Brewing, Shipping & Checkout | ' | append: shop.name
    assign meta_description = 'Premium loose leaf tea FAQ — brewing tips, secure checkout, standard shipping ' | append: standard_ship_label | append: ', free shipping over ' | append: free_ship_label | append: ', freshness guarantee, and how to choose green, oolong, pu-erh, and black teas. Shop without leaving the page.'
    assign og_description = meta_description
  elsif request.page_type == 'page' and page.handle == 'about'
    assign og_title = 'About Luxe Leaf Tea | Premium Loose Leaf Tea Boutique'
    assign meta_description = "Discover Luxe Leaf Tea — a boutique for premium Chinese loose leaf tea. Whole leaves, honest origins, packed fresh to order. Shop green, oolong, pu-erh, and black teas without leaving the page."
    assign og_description = meta_description
  elsif request.page_type == 'page' and page.handle == 'contact'
    assign og_title = 'Contact Luxe Leaf Tea | Call, Email, or Chat With Our Tea Team'
    assign meta_description = 'Contact Luxe Leaf Tea — call, email, or chat with our Tea Guide for help choosing premium loose leaf tea, orders, brewing tips, and shipping questions. We reply within one business day.'
    assign og_description = meta_description
  elsif request.page_type == 'page' and page.handle == 'terms-of-service'
    assign og_title = 'Terms of Service | ' | append: shop.name
    assign meta_description = 'Terms of Service for shopping premium loose leaf tea at ' | append: shop.name | append: ' — orders, secure payment, fresh packing, pricing, and acceptable use.'
    assign og_description = meta_description
  elsif request.page_type == 'page' and page.handle == 'refund-policy'
    assign og_title = 'Refund Policy | ' | append: shop.name
    assign meta_description = 'Refund Policy for ' | append: shop.name | append: ' — 14-day freshness guarantee, eligible returns, refund timing, and how to contact support.'
    assign og_description = meta_description
  elsif request.page_type == 'page' and page.handle == 'shipping-policy'
    assign og_title = 'Shipping Policy | ' | append: shop.name
    assign meta_description = 'Shipping Policy for ' | append: shop.name | append: ' — free shipping over ' | append: free_ship_label | append: ', standard shipping from ' | append: standard_ship_label | append: ', processing in 1–2 business days, and tracking.'
    assign og_description = meta_description
  elsif request.page_type == 'page' and page.handle == 'privacy-policy'
    assign og_title = 'Privacy Policy | ' | append: shop.name
    assign meta_description = 'Privacy Policy for ' | append: shop.name | append: ' — how we collect, use, and protect your information when you shop premium loose leaf tea online.'
    assign og_description = meta_description
  elsif request.page_type == 'page' and page.handle == 'legal'
    assign og_title = 'Legal Policies | ' | append: shop.name
    assign meta_description = 'Privacy, Terms of Service, Refund Policy, and Shipping Policy for ' | append: shop.name | append: ' — shop premium loose leaf tea with confidence.'
    assign og_description = meta_description
  elsif request.page_type == 'policy' and policy
    if policy == shop.terms_of_service
      assign og_title = 'Terms of Service | ' | append: shop.name
      assign meta_description = 'Terms of Service for shopping premium loose leaf tea at ' | append: shop.name | append: ' — orders, secure payment, fresh packing, pricing, and acceptable use.'
    elsif policy == shop.refund_policy
      assign og_title = 'Refund Policy | ' | append: shop.name
      assign meta_description = 'Refund Policy for ' | append: shop.name | append: ' — 14-day freshness guarantee, eligible returns, refund timing, and how to contact support.'
    elsif policy == shop.shipping_policy
      assign og_title = 'Shipping Policy | ' | append: shop.name
      assign meta_description = 'Shipping Policy for ' | append: shop.name | append: ' — free shipping over ' | append: free_ship_label | append: ', standard shipping from ' | append: standard_ship_label | append: ', processing in 1–2 business days, and tracking.'
    elsif policy == shop.privacy_policy
      assign og_title = 'Privacy Policy | ' | append: shop.name
      assign meta_description = 'Privacy Policy for ' | append: shop.name | append: ' — how we collect, use, and protect your information when you shop premium loose leaf tea online.'
    else
      assign meta_description = policy.title | append: ' — ' | append: shop.name
    endif
    assign og_description = meta_description
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="http:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- else -%}
  <meta
    property="og:image"
    content="https:{{ 'luxe-leaf-tea-logo-og.png' | asset_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ 'luxe-leaf-tea-logo-og.png' | asset_url }}"
  >
  <meta
    property="og:image:width"
    content="1200"
  >
  <meta
    property="og:image:height"
    content="630"
  >
  <meta
    property="og:image:alt"
    content="Luxe Leaf Tea — premium loose leaf tea"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
  <meta
    property="product:brand"
    content="{{ shop.name | escape }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>
{%- if page_image -%}
  <meta
    name="twitter:image"
    content="https:{{ page_image | image_url }}"
  >
{%- else -%}
  <meta
    name="twitter:image"
    content="https:{{ 'luxe-leaf-tea-logo-og.png' | asset_url }}"
  >
{%- endif -%}

<title>
  {{ page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
</title>

<link
  rel="canonical"
  href="{{ canonical_url }}"
>

{%- if meta_description != blank -%}
  <meta
    name="description"
    content="{{ meta_description | escape }}"
  >
{%- endif -%}
