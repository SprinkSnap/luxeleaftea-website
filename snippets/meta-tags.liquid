{%- doc -%}
  Enhanced SEO meta tags with premium loose leaf tea defaults and page-type fallbacks.
{%- enddoc -%}

<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="theme-color"
  content="#1B4332"
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign brand_default_description = 'Shop premium loose leaf tea from Luxe Leaf Tea. Hand-selected green, oolong, pu-erh, and black teas — packed fresh to order.'
  assign meta_description = page_description | default: shop.description | default: brand_default_description
  assign og_description = meta_description

  if request.page_type == 'index'
    assign og_title = 'Premium Loose Leaf Tea | ' | append: shop.name
    assign meta_description = brand_default_description
    assign og_description = meta_description
  elsif request.page_type == 'collection' and collection
    case collection.handle
      when 'green-tea'
        assign meta_description = 'Shop premium loose leaf green tea — bright, sweet whole-leaf selections packed fresh to order. Free shipping over $50.'
      when 'oolong'
        assign meta_description = 'Explore premium loose leaf oolong tea — floral, layered, and perfect for multiple steeps. Packed fresh to order.'
      when 'pu-erh'
        assign meta_description = 'Premium loose leaf pu-erh tea — deep, smooth, and ideal for re-steeping. Shop Luxe Leaf Tea.'
      when 'black-tea'
        assign meta_description = 'Shop premium loose leaf black tea — rich, malty, and full-bodied. Packed fresh to order.'
    endcase
    if collection.description != blank
      assign meta_description = collection.description | strip_html | truncate: 155
    endif
    assign og_description = meta_description
  elsif request.page_type == 'product' and product
    assign meta_description = product.description | strip_html | truncate: 155
    if meta_description == blank
      assign meta_description = 'Shop ' | append: product.title | append: ' — premium loose leaf tea packed fresh to order from Luxe Leaf Tea.'
    endif
    assign og_description = meta_description
  elsif request.page_type == 'article' and article
    assign meta_description = article.excerpt | default: article.content | strip_html | truncate: 155
    assign og_description = meta_description
  elsif request.page_type == 'blog'
    assign meta_description = 'Tea guides and brewing tips for premium loose leaf tea — learn, brew, and shop with confidence.'
    assign og_description = meta_description
  elsif request.page_type == 'page' and page.handle == 'faq'
    assign meta_description = 'FAQ about premium loose leaf tea — brewing tips, shipping, freshness, and how to choose green, oolong, pu-erh, and black teas.'
    assign og_description = meta_description
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="http:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- else -%}
  <meta
    property="og:image"
    content="https:{{ 'luxe-leaf-tea-logo-og.png' | asset_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ 'luxe-leaf-tea-logo-og.png' | asset_url }}"
  >
  <meta
    property="og:image:width"
    content="1200"
  >
  <meta
    property="og:image:height"
    content="630"
  >
  <meta
    property="og:image:alt"
    content="Luxe Leaf Tea — premium loose leaf tea"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
  <meta
    property="product:brand"
    content="{{ shop.name | escape }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>
{%- if page_image -%}
  <meta
    name="twitter:image"
    content="https:{{ page_image | image_url }}"
  >
{%- else -%}
  <meta
    name="twitter:image"
    content="https:{{ 'luxe-leaf-tea-logo-og.png' | asset_url }}"
  >
{%- endif -%}

<title>
  {{ page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
</title>

<link
  rel="canonical"
  href="{{ canonical_url }}"
>

{%- if meta_description != blank -%}
  <meta
    name="description"
    content="{{ meta_description | escape }}"
  >
{%- endif -%}

{%- if settings.google_site_verification != blank -%}
  <meta name="google-site-verification" content="{{ settings.google_site_verification | escape }}">
{%- endif -%}

{%- if settings.ga4_measurement_id != blank -%}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.ga4_measurement_id | escape }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', {{ settings.ga4_measurement_id | json }});
  </script>
{%- endif -%}

{%- liquid
  assign schema_shop_url = shop.url | default: request.origin
  assign schema_logo_url = 'luxe-leaf-tea-logo.png' | asset_url | prepend: 'https:'
  if settings.logo != blank
    assign schema_logo_url = settings.logo | image_url: width: 500 | prepend: 'https:'
  endif

  assign org_same_as = ''
  if settings.social_facebook_link != blank
    assign org_same_as = org_same_as | append: settings.social_facebook_link | append: '||'
  endif
  if settings.social_instagram_link != blank
    assign org_same_as = org_same_as | append: settings.social_instagram_link | append: '||'
  endif
  if settings.social_youtube_link != blank
    assign org_same_as = org_same_as | append: settings.social_youtube_link | append: '||'
  endif
  assign org_same_as_list = org_same_as | split: '||'
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": {{ schema_shop_url | append: '/#organization' | json }},
      "name": {{ shop.name | json }},
      "url": {{ schema_shop_url | json }},
      "logo": {{ schema_logo_url | json }},
      "description": "Premium loose leaf tea sourced from trusted gardens. Hand-selected leaves packed fresh to order."
      {%- if org_same_as != blank -%}
      ,"sameAs": [
        {%- for url in org_same_as_list -%}
          {%- if url != blank -%}
            {%- unless forloop.first -%},{%- endunless -%}
            {{ url | json }}
          {%- endif -%}
        {%- endfor -%}
      ]
      {%- endif -%}
    },
    {
      "@type": "WebSite",
      "@id": {{ schema_shop_url | append: '/#website' | json }},
      "url": {{ schema_shop_url | json }},
      "name": {{ shop.name | json }},
      "description": "Shop premium loose leaf tea — green, oolong, pu-erh, and black teas packed fresh to order.",
      "publisher": { "@id": {{ schema_shop_url | append: '/#organization' | json }} },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": {{ schema_shop_url | append: '/search?q={search_term_string}' | json }}
        },
        "query-input": "required name=search_term_string"
      }
    }
    {%- if request.page_type == 'index' -%}
    ,{
      "@type": "FAQPage",
      "@id": {{ schema_shop_url | append: '/#faq' | json }},
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much loose leaf tea should I use per cup?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For most premium loose leaf teas, use about 3 grams of leaf per 150ml of water. Oolongs and pu-erh may use slightly more for a richer cup."
          }
        },
        {
          "@type": "Question",
          "name": "What water temperature is best for loose leaf green tea?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Premium loose leaf green tea brews best at 175–185°F (80–85°C). Avoid boiling water, which can make delicate leaves taste bitter."
          }
        },
        {
          "@type": "Question",
          "name": "Can you re-steep premium loose leaf tea?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Quality whole-leaf teas can be re-steeped multiple times. Green teas often yield 3–4 infusions; oolongs and pu-erh can offer 4–8."
          }
        },
        {
          "@type": "Question",
          "name": "Why choose loose leaf tea over tea bags?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Loose leaf tea uses whole or large leaves that unfurl in water, releasing more aroma and flavor. Premium loose leaf also re-steeps better and offers clearer origin and quality."
          }
        }
      ]
    }
    {%- endif -%}
    {%- if request.page_type == 'collection' and collection -%}
    ,{
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ schema_shop_url | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": {{ schema_shop_url | append: collection.url | json }}
        }
      ]
    },
    {
      "@type": "CollectionPage",
      "name": {{ collection.title | json }},
      "description": {{ collection.description | strip_html | truncate: 300 | default: 'Shop premium loose leaf tea from Luxe Leaf Tea.' | json }},
      "url": {{ schema_shop_url | append: collection.url | json }}
    }
    {%- endif -%}
    {%- if request.page_type == 'product' and product -%}
    ,{
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ schema_shop_url | json }}
        }
        {%- if collection -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": {{ schema_shop_url | append: collection.url | json }}
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ product.title | json }},
          "item": {{ canonical_url | json }}
        }
        {%- else -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ product.title | json }},
          "item": {{ canonical_url | json }}
        }
        {%- endif -%}
      ]
    }
    {%- endif -%}
    {%- if request.page_type == 'article' and article -%}
    ,{
      "@type": "BlogPosting",
      "headline": {{ article.title | json }},
      "description": {{ article.excerpt | default: article.content | strip_html | truncate: 300 | json }},
      "datePublished": {{ article.published_at | date: '%Y-%m-%d' | json }},
      "dateModified": {{ article.updated_at | date: '%Y-%m-%d' | json }},
      "author": {
        "@type": "Organization",
        "name": {{ shop.name | json }}
      },
      "publisher": { "@id": {{ schema_shop_url | append: '/#organization' | json }} },
      "mainEntityOfPage": {{ canonical_url | json }},
      "url": {{ canonical_url | json }}
      {%- if article.image -%}
      ,"image": {{ article.image | image_url: width: 1200 | prepend: 'https:' | json }}
      {%- endif -%}
    }
    {%- endif -%}
  ]
}
</script>
