{%- doc -%}
  Stock badge for product cards and PDP — uses Shopify inventory tracking.
  @param {object} product - Product object
  @param {object} [variant] - Optional variant; defaults to selected/first available
  @param {string} [class] - Extra CSS classes
  @param {string} [placement] - inline | card-meta | pdp (default: inline)
{%- enddoc -%}

{%- liquid
  assign v = variant | default: product.selected_or_first_available_variant
  assign threshold = settings.low_stock_threshold | default: 10
  assign show_badge = false
  assign badge_class = ''
  assign badge_text = ''

  if v.inventory_management == 'shopify'
    if v.inventory_quantity <= 0 and v.inventory_policy == 'deny'
      assign show_badge = true
      assign badge_class = 'luxe-stock-badge--sold-out'
      assign badge_text = 'Sold out'
    elsif v.inventory_quantity > 0 and v.inventory_quantity <= threshold
      assign show_badge = true
      assign badge_class = 'luxe-stock-badge--low'
      assign badge_text = 'Only ' | append: v.inventory_quantity | append: ' left'
    elsif v.available
      assign show_badge = true
      assign badge_class = 'luxe-stock-badge--in-stock'
      assign badge_text = 'In stock — ships fresh'
    endif
  elsif product.available
    assign show_badge = true
    assign badge_class = 'luxe-stock-badge--in-stock'
    assign badge_text = 'In stock — ships fresh'
  endif
-%}

{%- liquid
  assign badge_placement = placement | default: 'inline'
  assign placement_class = 'luxe-stock-badge--' | append: badge_placement
-%}

{%- if show_badge -%}
  <span
    class="luxe-stock-badge {{ badge_class }} {{ placement_class }}{% if class != blank %} {{ class }}{% endif %}"
    role="status"
  >
    {{ badge_text }}
  </span>
{%- endif -%}

{% stylesheet %}
  .luxe-stock-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .luxe-stock-badge--in-stock {
    background: rgb(var(--luxe-jade-rgb) / 0.1);
    color: var(--luxe-jade);
  }

  .luxe-stock-badge--low {
    background: rgb(var(--luxe-gold-rgb) / 0.2);
    color: #7a5c00;
  }

  .luxe-stock-badge--sold-out {
    background: rgb(0 0 0 / 0.08);
    color: rgb(0 0 0 / 0.55);
  }

  .luxe-stock-badge--card-meta {
    align-self: flex-start;
    margin-block: 0.15rem 0;
  }

  .luxe-stock-badge--pdp {
    font-size: 0.75rem;
    padding: 0.35rem 0.65rem;
  }

  .luxe-stock-badge-row {
    margin-block-start: 0.35rem;
  }
{% endstylesheet %}
