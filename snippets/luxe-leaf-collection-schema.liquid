{%- doc -%}
  CollectionPage + BreadcrumbList JSON-LD for collection SEO.
  @param {object} collection - The collection object
{%- enddoc -%}

{%- if collection != blank -%}
  {%- liquid
    assign collection_url = shop.url | append: collection.url
    assign collection_desc = collection.description | strip_html | truncate: 300
    if collection_desc == blank
      assign collection_desc = 'Shop premium loose leaf ' | append: collection.title | append: ' — packed fresh to order.'
    endif
  -%}

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": {{ collection.title | json }},
      "description": {{ collection_desc | json }},
      "url": {{ collection_url | json }},
      "isPartOf": {
        "@type": "WebSite",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | json }}
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": {{ shop.url | append: routes.root_url | json }}
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": {{ collection_url | json }}
          }
        ]
      }
    }
  </script>
{%- endif -%}
