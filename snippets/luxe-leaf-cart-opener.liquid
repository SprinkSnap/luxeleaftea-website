{%- doc -%}
  Cart drawer open/close bridge — reliable single-tap open even if theme-drawer.js is slow.
  Render once near end of layout/theme.liquid (after cart-drawer markup).
{%- enddoc -%}

{%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
  <script>
    (function () {
      if (window.__luxeCartDrawerBridgeInit) return;
      window.__luxeCartDrawerBridgeInit = true;

      var OPEN_TRIGGER =
        '[data-luxe-open-cart],[data-testid="cart-drawer-trigger"],a[aria-controls="cart-drawer"],button[aria-controls="cart-drawer"],[data-mobile-cart-toggle],[data-shipping-nudge-cart]';
      var CLOSE_TRIGGER = '#cart-drawer .theme-drawer__close-button, #cart-drawer .luxe-cart-drawer__continue';
      var opening = false;
      var ignoreClickUntil = 0;

      function syncDrawerChrome(isOpen) {
        document.documentElement.classList.toggle('luxe-cart-drawer-open', isOpen);

        var nudge = document.querySelector('[data-shipping-nudge]');
        var bar = document.querySelector('[data-mobile-shop-bar]');
        if (nudge) nudge.toggleAttribute('data-drawer-open', isOpen);
        if (bar) bar.toggleAttribute('data-drawer-open', isOpen);

        document.querySelectorAll('[aria-controls="cart-drawer"]').forEach(function (trigger) {
          trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });
      }

      function clearStuckLock() {
        document.documentElement.removeAttribute('scroll-lock');
        document.documentElement.classList.remove('luxe-cart-drawer-open');
      }

      function isDrawerOpen(drawer) {
        if (!drawer) return false;
        return drawer.hasAttribute('open') || Boolean(drawer.querySelector('dialog[open]'));
      }

      function upgradeDrawer(drawer) {
        if (drawer && window.customElements && window.customElements.get('theme-drawer')) {
          window.customElements.upgrade(drawer);
        }
      }

      function sleep(ms) {
        return new Promise(function (resolve) {
          window.setTimeout(resolve, ms);
        });
      }

      function ensureDrawer() {
        var drawer = document.getElementById('cart-drawer');
        if (!drawer) return Promise.resolve(null);

        if (!window.customElements || !window.customElements.whenDefined) {
          return Promise.resolve(drawer);
        }

        if (window.customElements.get('theme-drawer')) {
          upgradeDrawer(drawer);
          return Promise.resolve(drawer);
        }

        return window.customElements.whenDefined('theme-drawer').then(function () {
          upgradeDrawer(drawer);
          return drawer;
        });
      }

      function openDialogFallback(drawer) {
        var dialog = drawer && drawer.querySelector('dialog');
        if (!dialog) return false;

        try {
          clearStuckLock();
          drawer.setAttribute('open', '');
          var modal = window.matchMedia('(max-width: 989px)').matches;
          if (modal) {
            if (!dialog.open) dialog.showModal();
          } else if (!dialog.open) {
            dialog.show();
          }
          dialog.classList.remove('theme-drawer__dialog--closing');
          dialog.classList.add('theme-drawer__dialog--opening');
          window.setTimeout(function () {
            dialog.classList.remove('theme-drawer__dialog--opening');
          }, 400);
          drawer.dispatchEvent(new CustomEvent('theme-drawer:open', { bubbles: true }));
          syncDrawerChrome(true);
          return isDrawerOpen(drawer);
        } catch (e) {
          return false;
        }
      }

      function forceOpenDrawerSync(drawer) {
        if (!drawer) return false;

        clearStuckLock();
        upgradeDrawer(drawer);

        try {
          if (typeof drawer.open === 'function') {
            drawer.open();
            if (isDrawerOpen(drawer)) {
              syncDrawerChrome(true);
              return true;
            }
          }
        } catch (e) {}

        return openDialogFallback(drawer);
      }

      function forceCloseDrawer() {
        var drawer = document.getElementById('cart-drawer');
        clearStuckLock();
        syncDrawerChrome(false);

        if (!drawer || !isDrawerOpen(drawer)) return true;

        try {
          upgradeDrawer(drawer);
          if (typeof drawer.close === 'function') {
            drawer.close();
            if (!isDrawerOpen(drawer)) return true;
          }
        } catch (e) {}

        var dialog = drawer.querySelector('dialog');
        if (!dialog) return false;

        try {
          if (dialog.open) dialog.close();
          drawer.removeAttribute('open');
          dialog.classList.remove('theme-drawer__dialog--closing', 'theme-drawer__dialog--opening');
          drawer.dispatchEvent(new CustomEvent('theme-drawer:close', { bubbles: true }));
          syncDrawerChrome(false);
          clearStuckLock();
          return true;
        } catch (e) {
          clearStuckLock();
          return false;
        }
      }

      async function openCartDrawer(evt) {
        if (opening) return;
        opening = true;

        if (evt) {
          evt.preventDefault();
          if (evt.stopPropagation) evt.stopPropagation();
          if (evt.stopImmediatePropagation) evt.stopImmediatePropagation();
        }

        // Suppress the synthetic click that follows touch/pointer on the bag icon
        ignoreClickUntil = Date.now() + 600;

        try {
          clearStuckLock();
          var drawer = await ensureDrawer();

          if (!drawer) return;

          // If a close animation is in progress, ThemeDrawer.open() only defers —
          // retry briefly instead of navigating away (which freezes on first tap).
          for (var attempt = 0; attempt < 8; attempt++) {
            if (forceOpenDrawerSync(drawer)) return;
            await sleep(40);
          }

          // Last resort: hard reset dialog state, then open once more
          var dialog = drawer.querySelector('dialog');
          if (dialog) {
            try {
              if (dialog.open) dialog.close();
            } catch (e) {}
            drawer.removeAttribute('open');
            dialog.classList.remove('theme-drawer__dialog--closing', 'theme-drawer__dialog--opening');
            clearStuckLock();
            await sleep(30);
            forceOpenDrawerSync(drawer);
          }
        } finally {
          opening = false;
        }
      }

      function closeCartDrawer(evt) {
        if (evt) {
          evt.preventDefault();
          if (evt.stopPropagation) evt.stopPropagation();
        }
        forceCloseDrawer();
      }

      function onDocumentIntent(evt) {
        // Ghost click after pointer/touch open — ignore so double-fire can't stuck-lock
        if (evt.type === 'click' && Date.now() < ignoreClickUntil) {
          var maybeTrigger = evt.target instanceof Element ? evt.target.closest(OPEN_TRIGGER) : null;
          if (maybeTrigger) {
            evt.preventDefault();
            if (evt.stopPropagation) evt.stopPropagation();
            return;
          }
        }

        var target = evt.target;
        if (!(target instanceof Element)) return;

        if (target.closest(CLOSE_TRIGGER)) {
          closeCartDrawer(evt);
          return;
        }

        var drawer = document.getElementById('cart-drawer');
        if (drawer && isDrawerOpen(drawer) && evt.type === 'click') {
          var dialog = drawer.querySelector('dialog');
          if (dialog && evt.target === dialog && window.matchMedia('(max-width: 989px)').matches) {
            closeCartDrawer(evt);
            return;
          }
        }

        var trigger = target.closest(OPEN_TRIGGER);
        if (!trigger || trigger.hidden || trigger.getAttribute('aria-disabled') === 'true') return;

        openCartDrawer(evt);
      }

      // Single input path (click covers mouse + tap). Removed capture touchend —
      // it raced click, set a 450ms lock, and fell back to /cart when open deferred mid-close.
      document.addEventListener('click', onDocumentIntent, true);

      document.addEventListener('keydown', function (evt) {
        if (evt.key !== 'Escape') return;
        var drawer = document.getElementById('cart-drawer');
        if (!drawer || !isDrawerOpen(drawer)) return;
        if (evt.defaultPrevented) return;
        closeCartDrawer(evt);
      });

      /* Swipe drawer to the right to close (same intent as the X). */
      (function initSwipeToClose() {
        var startX = 0;
        var startY = 0;
        var tracking = false;
        var decided = false;
        var horizontal = false;

        function onTouchStart(evt) {
          var drawer = document.getElementById('cart-drawer');
          if (!drawer || !isDrawerOpen(drawer) || !evt.touches || !evt.touches[0]) return;

          var target = evt.target;
          if (!(target instanceof Element)) return;
          if (target.closest(OPEN_TRIGGER)) return;
          if (target.closest('input, textarea, select, [contenteditable="true"]')) return;

          var dialog = drawer.querySelector('dialog');
          if (!dialog || !dialog.contains(target)) return;

          startX = evt.touches[0].clientX;
          startY = evt.touches[0].clientY;
          tracking = true;
          decided = false;
          horizontal = false;
        }

        function onTouchMove(evt) {
          if (!tracking || !evt.touches || !evt.touches[0]) return;

          var dx = evt.touches[0].clientX - startX;
          var dy = evt.touches[0].clientY - startY;

          if (!decided) {
            if (Math.abs(dx) < 14 && Math.abs(dy) < 14) return;
            decided = true;
            horizontal = Math.abs(dx) > Math.abs(dy) * 1.25;
          }

          if (horizontal && dx > 80) {
            tracking = false;
            forceCloseDrawer();
          }
        }

        function onTouchEnd() {
          tracking = false;
          decided = false;
          horizontal = false;
        }

        document.addEventListener('touchstart', onTouchStart, { passive: true, capture: true });
        document.addEventListener('touchmove', onTouchMove, { passive: true, capture: true });
        document.addEventListener('touchend', onTouchEnd, { passive: true, capture: true });
        document.addEventListener('touchcancel', onTouchEnd, { passive: true, capture: true });
      })();

      window.addEventListener('pagehide', function () {
        forceCloseDrawer();
        clearStuckLock();
      });

      document.addEventListener('theme-drawer:open', function (evt) {
        if (/** @type {Element} */ (evt.target).id === 'cart-drawer') syncDrawerChrome(true);
      });
      document.addEventListener('theme-drawer:close', function (evt) {
        if (/** @type {Element} */ (evt.target).id === 'cart-drawer') {
          syncDrawerChrome(false);
          clearStuckLock();
        }
      });

      window.LuxeLeaf = window.LuxeLeaf || {};
      window.LuxeLeaf.openCart = openCartDrawer;
      window.LuxeLeaf.closeCart = closeCartDrawer;
    })();
  </script>
{%- endif -%}
