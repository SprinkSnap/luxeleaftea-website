{%- doc -%}
  Cart drawer open/close bridge — single-tap bag open that cannot hang.
  Render once near end of layout/theme.liquid (after cart-drawer markup).
{%- enddoc -%}

{%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
  <script>
    (function () {
      if (window.__luxeCartDrawerBridgeInit) return;
      window.__luxeCartDrawerBridgeInit = true;

      var OPEN_TRIGGER =
        '[data-luxe-open-cart],[data-testid="cart-drawer-trigger"],a[aria-controls="cart-drawer"],button[aria-controls="cart-drawer"],[data-mobile-cart-toggle],[data-shipping-nudge-cart]';
      var CLOSE_TRIGGER = '#cart-drawer .theme-drawer__close-button, #cart-drawer .luxe-cart-drawer__continue';
      var opening = false;
      var openStartedAt = 0;

      function getDrawer() {
        return document.getElementById('cart-drawer');
      }

      function isDrawerOpen(drawer) {
        if (!drawer) return false;
        var dialog = drawer.querySelector('dialog');
        return drawer.hasAttribute('open') || Boolean(dialog && dialog.open);
      }

      function hardUnlockScroll() {
        if (typeof window.__themeForceUnlockScroll === 'function') {
          window.__themeForceUnlockScroll();
        } else {
          document.documentElement.removeAttribute('scroll-lock');
        }
      }

      function reconcileDrawerChrome() {
        var drawer = getDrawer();
        var open = isDrawerOpen(drawer);

        document.documentElement.classList.toggle('luxe-cart-drawer-open', open);

        var nudge = document.querySelector('[data-shipping-nudge]');
        var bar = document.querySelector('[data-mobile-shop-bar]');
        if (nudge) nudge.toggleAttribute('data-drawer-open', open);
        if (bar) bar.toggleAttribute('data-drawer-open', open);

        document.querySelectorAll('[aria-controls="cart-drawer"]').forEach(function (trigger) {
          trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
        });

        if (!open) hardUnlockScroll();
      }

      function upgradeDrawer(drawer) {
        try {
          if (drawer && window.customElements && window.customElements.get('theme-drawer')) {
            window.customElements.upgrade(drawer);
          }
        } catch (e) {}
      }

      /**
       * Open the cart dialog directly. Prefer ThemeDrawer.open when available,
       * but never depend on it — showModal/show is enough for a working bag tap.
       */
      function forceOpenDrawer(drawer) {
        if (!drawer) return false;

        var dialog = drawer.querySelector('dialog');
        if (!dialog) return false;

        upgradeDrawer(drawer);

        // ThemeDrawer path (keeps squeeze / focus trap in sync when upgraded)
        try {
          if (typeof drawer.open === 'function' && window.customElements.get('theme-drawer')) {
            drawer.open();
            if (isDrawerOpen(drawer)) {
              reconcileDrawerChrome();
              return true;
            }
          }
        } catch (e) {}

        // Direct dialog path — always works even if the custom element is slow/broken
        try {
          dialog.classList.remove('theme-drawer__dialog--closing');
          drawer.setAttribute('open', '');

          var modal = window.matchMedia('(max-width: 989px)').matches;
          if (modal) {
            if (!dialog.open) dialog.showModal();
          } else if (!dialog.open) {
            dialog.show();
          }

          dialog.classList.add('theme-drawer__dialog--opening');
          window.setTimeout(function () {
            dialog.classList.remove('theme-drawer__dialog--opening');
          }, 400);

          try {
            drawer.dispatchEvent(new CustomEvent('theme-drawer:open', { bubbles: true }));
          } catch (e2) {}

          reconcileDrawerChrome();
          return isDrawerOpen(drawer);
        } catch (e3) {
          reconcileDrawerChrome();
          return false;
        }
      }

      function forceCloseDrawer() {
        var drawer = getDrawer();
        if (drawer) {
          try {
            upgradeDrawer(drawer);
            if (typeof drawer.close === 'function' && window.customElements.get('theme-drawer')) {
              drawer.close();
            }
          } catch (e) {}

          var dialog = drawer.querySelector('dialog');
          if (dialog) {
            try {
              if (dialog.open) dialog.close();
            } catch (e2) {}
            drawer.removeAttribute('open');
            dialog.classList.remove('theme-drawer__dialog--closing', 'theme-drawer__dialog--opening');
            try {
              drawer.dispatchEvent(new CustomEvent('theme-drawer:close', { bubbles: true }));
            } catch (e3) {}
          }
        }

        hardUnlockScroll();
        reconcileDrawerChrome();
        return true;
      }

      function openCartDrawer(evt) {
        // Allow retry if a previous open hung (>1.5s)
        if (opening && Date.now() - openStartedAt < 1500) return;
        opening = true;
        openStartedAt = Date.now();

        if (evt) {
          evt.preventDefault();
          if (evt.stopPropagation) evt.stopPropagation();
        }

        var drawer = getDrawer();
        if (!drawer) {
          opening = false;
          return;
        }

        // Fast path — open immediately without waiting for modules
        if (forceOpenDrawer(drawer)) {
          opening = false;
          return;
        }

        // Retry briefly while theme-drawer.js upgrades (never hang forever)
        var tries = 0;
        var timer = window.setInterval(function () {
          tries += 1;
          upgradeDrawer(drawer);
          var done = forceOpenDrawer(drawer) || tries >= 12;
          if (done) {
            window.clearInterval(timer);
            opening = false;
            reconcileDrawerChrome();
          }
        }, 50);
      }

      function closeCartDrawer(evt) {
        if (evt) {
          evt.preventDefault();
          if (evt.stopPropagation) evt.stopPropagation();
        }
        opening = false;
        forceCloseDrawer();
      }

      function onDocumentIntent(evt) {
        var target = evt.target;
        if (!(target instanceof Element)) return;

        if (target.closest(CLOSE_TRIGGER)) {
          closeCartDrawer(evt);
          return;
        }

        var drawer = getDrawer();
        if (drawer && isDrawerOpen(drawer) && evt.type === 'click') {
          var dialog = drawer.querySelector('dialog');
          if (dialog && evt.target === dialog && window.matchMedia('(max-width: 989px)').matches) {
            closeCartDrawer(evt);
            return;
          }
        }

        var trigger = target.closest(OPEN_TRIGGER);
        if (!trigger || trigger.hidden || trigger.getAttribute('aria-disabled') === 'true') return;
        if (trigger.getAttribute('aria-disabled') === 'true') return;

        openCartDrawer(evt);
      }

      // Bubble + capture so bag taps are not missed by other handlers
      document.addEventListener('click', onDocumentIntent, true);

      // Direct bind on bag controls (survives if document capture is stopped elsewhere)
      function bindDirectTriggers() {
        document.querySelectorAll(OPEN_TRIGGER).forEach(function (el) {
          if (el.dataset.luxeCartBound === '1') return;
          el.dataset.luxeCartBound = '1';
          el.addEventListener('click', function (evt) {
            openCartDrawer(evt);
          });
        });
      }
      bindDirectTriggers();
      document.addEventListener('DOMContentLoaded', bindDirectTriggers);
      window.setTimeout(bindDirectTriggers, 500);

      document.addEventListener('keydown', function (evt) {
        if (evt.key !== 'Escape') return;
        var drawer = getDrawer();
        if (!drawer || !isDrawerOpen(drawer)) return;
        if (evt.defaultPrevented) return;
        closeCartDrawer(evt);
      });

      function recoverIfStuck() {
        var drawer = getDrawer();
        if (isDrawerOpen(drawer)) return;
        if (
          document.documentElement.classList.contains('luxe-cart-drawer-open') ||
          document.documentElement.hasAttribute('scroll-lock')
        ) {
          hardUnlockScroll();
          reconcileDrawerChrome();
        }
        // Never leave the open-guard stuck
        if (opening && Date.now() - openStartedAt > 1500) opening = false;
      }

      document.addEventListener('touchstart', recoverIfStuck, { passive: true, capture: true });
      window.addEventListener('pageshow', function () {
        opening = false;
        hardUnlockScroll();
        reconcileDrawerChrome();
        bindDirectTriggers();
      });
      document.addEventListener('visibilitychange', function () {
        if (document.visibilityState === 'visible') recoverIfStuck();
      });
      window.addEventListener('pagehide', function () {
        opening = false;
        forceCloseDrawer();
      });

      document.addEventListener('theme-drawer:open', function (evt) {
        if (/** @type {Element} */ (evt.target).id === 'cart-drawer') {
          opening = false;
          reconcileDrawerChrome();
        }
      });
      document.addEventListener('theme-drawer:close', function (evt) {
        if (/** @type {Element} */ (evt.target).id === 'cart-drawer') {
          opening = false;
          hardUnlockScroll();
          reconcileDrawerChrome();
        }
      });

      reconcileDrawerChrome();

      window.LuxeLeaf = window.LuxeLeaf || {};
      window.LuxeLeaf.openCart = openCartDrawer;
      window.LuxeLeaf.closeCart = closeCartDrawer;
      window.LuxeLeaf.reconcileCartDrawer = reconcileDrawerChrome;
    })();
  </script>
{%- endif -%}
