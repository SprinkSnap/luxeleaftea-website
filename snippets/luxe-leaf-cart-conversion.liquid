{%- doc -%}
  Cart drawer conversion layer: free-shipping progress, trust, and checkout urgency.
{%- enddoc -%}

{%- liquid
  assign threshold = settings.free_shipping_threshold | default: 5000
  assign threshold_money = threshold | money
  assign cart_total = cart.total_price
  assign remaining = threshold | minus: cart_total
  assign progress = cart_total | times: 100 | divided_by: threshold
  if progress > 100
    assign progress = 100
  endif
-%}

{%- unless cart.empty? -%}
  <div class="luxe-cart-conversion" data-cart-conversion>
    {%- if cart_total >= threshold -%}
      <p class="luxe-cart-conversion__message luxe-cart-conversion__message--success">
        {%- render 'luxe-leaf-icon', name: 'truck', class: 'luxe-icon--sm' -%}
        You've unlocked <strong>free shipping</strong> on premium loose leaf tea!
      </p>
    {%- else -%}
      <p class="luxe-cart-conversion__message">
        Add <strong>{{ remaining | money }}</strong> more for free shipping over {{ threshold_money }}
      </p>
      <div
        class="luxe-cart-conversion__progress"
        role="progressbar"
        aria-valuenow="{{ progress }}"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-label="Free shipping progress"
      >
        <span class="luxe-cart-conversion__progress-bar" style="width: {{ progress }}%;"></span>
      </div>
    {%- endif -%}

    <ul class="luxe-cart-conversion__trust list-unstyled" role="list">
      <li>{%- render 'luxe-leaf-icon', name: 'leaf', class: 'luxe-icon--sm' -%} Packed fresh to order</li>
      <li>{%- render 'luxe-leaf-icon', name: 'lock', class: 'luxe-icon--sm' -%} Secure checkout</li>
      <li>{%- render 'luxe-leaf-icon', name: 'cup', class: 'luxe-icon--sm' -%} Whole-leaf quality</li>
    </ul>
  </div>
{%- endunless -%}

{% stylesheet %}
  .luxe-cart-conversion {
    padding: 1rem var(--cart-drawer-padding, 1.25rem) 0.75rem;
    border-bottom: 1px solid rgb(var(--luxe-jade-rgb) / 0.1);
    background: linear-gradient(180deg, rgb(var(--luxe-gold-rgb) / 0.08) 0%, transparent 100%);
  }

  .luxe-cart-conversion__message {
    margin: 0 0 0.65rem;
    font-size: 0.8125rem;
    line-height: 1.45;
    color: rgb(var(--luxe-jade-rgb) / 0.92);
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .luxe-cart-conversion__message--success {
    color: var(--luxe-jade);
    font-weight: 500;
  }

  .luxe-cart-conversion__progress {
    height: 0.4rem;
    border-radius: 999px;
    background: rgb(var(--luxe-jade-rgb) / 0.12);
    overflow: hidden;
    margin-bottom: 0.85rem;
  }

  .luxe-cart-conversion__progress-bar {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--luxe-jade), var(--luxe-gold));
    transition: width 0.35s ease;
  }

  .luxe-cart-conversion__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.85rem;
    margin: 0;
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: rgb(var(--luxe-jade-rgb) / 0.72);
  }

  .luxe-cart-conversion__trust li {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
{% endstylesheet %}
