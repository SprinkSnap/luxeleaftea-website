{%- doc -%}
  Cart drawer conversion layer: free-shipping progress, trust, and checkout urgency.
{%- enddoc -%}

{% render 'luxe-leaf-shipping-estimate', variant: 'drawer-banner' %}

{% stylesheet %}
  .luxe-cart-conversion {
    padding: 1rem var(--cart-drawer-padding, 1.25rem) 0.75rem;
    border-bottom: 1px solid rgb(var(--luxe-jade-rgb) / 0.1);
    background: linear-gradient(180deg, rgb(var(--luxe-gold-rgb) / 0.08) 0%, transparent 100%);
  }

  .luxe-cart-conversion__message {
    margin: 0 0 0.65rem;
    font-size: 0.8125rem;
    line-height: 1.45;
    color: rgb(var(--luxe-jade-rgb) / 0.92);
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .luxe-cart-conversion__message--success {
    color: var(--luxe-jade);
    font-weight: 500;
  }

  .luxe-cart-conversion__progress {
    height: 0.4rem;
    border-radius: 999px;
    background: rgb(var(--luxe-jade-rgb) / 0.12);
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  .luxe-cart-conversion__progress--complete {
    margin-bottom: 0.65rem;
  }

  .luxe-cart-conversion__progress-bar {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--luxe-jade), var(--luxe-gold));
    transition: width 0.35s ease;
  }

  .luxe-cart-conversion__shipping {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.15rem 0.65rem;
    align-items: baseline;
    margin-bottom: 0.75rem;
    padding: 0.55rem 0.65rem;
    border-radius: 0.5rem;
    background: rgb(var(--luxe-jade-rgb) / 0.06);
    border: 1px solid rgb(var(--luxe-jade-rgb) / 0.1);
  }

  .luxe-cart-conversion__shipping-label {
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgb(var(--luxe-jade-rgb) / 0.72);
  }

  .luxe-cart-conversion__shipping-value {
    font-size: 0.8125rem;
    text-align: right;
    color: var(--luxe-jade);
  }

  .luxe-cart-conversion__shipping-total {
    grid-column: 1 / -1;
    font-size: 0.8125rem;
    color: rgb(var(--luxe-jade-rgb) / 0.88);
  }

  .luxe-cart-conversion__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.85rem;
    margin: 0;
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: rgb(var(--luxe-jade-rgb) / 0.72);
  }

  .luxe-cart-conversion__trust li {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
{% endstylesheet %}
