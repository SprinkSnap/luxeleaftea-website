{%- doc -%}
  Sticky free-shipping progress nudge — encourages keep browsing and adding without leaving.
{%- enddoc -%}

{%- unless settings.brand_navigation == false -%}
  {%- liquid
    assign threshold = settings.free_shipping_threshold | default: 5000
    assign standard_rate = settings.standard_shipping_rate | default: 595
    assign threshold_money = threshold | money
    assign standard_rate_money = standard_rate | money
    assign cart_total = cart.total_price
    assign remaining = threshold | minus: cart_total
    if remaining < 0
      assign remaining = 0
    endif
    if cart_total >= threshold
      assign shipping_cost = 0
    else
      assign shipping_cost = standard_rate
    endif
    assign estimated_total = cart_total | plus: shipping_cost
  -%}

  <aside
    class="luxe-shipping-nudge"
    data-shipping-nudge
    {% render 'luxe-leaf-shipping-estimate', variant: 'nudge-meta' %}
    data-shop-url="{{ routes.all_products_collection_url | escape }}"
    hidden
    aria-live="polite"
  >
    <div class="luxe-shipping-nudge__inner page-width">
      <div class="luxe-shipping-nudge__copy">
        <p class="luxe-shipping-nudge__text" data-shipping-nudge-text>
          Add more for free shipping over {{ threshold_money }}
        </p>
        <p class="luxe-shipping-nudge__rate" data-shipping-nudge-rate>
          Standard shipping {{ standard_rate_money }} · Pay {{ estimated_total | money }} total
        </p>
        <div
          class="luxe-shipping-nudge__progress"
          role="progressbar"
          aria-valuemin="0"
          aria-valuemax="100"
          aria-valuenow="0"
          data-shipping-nudge-progress
        >
          <span class="luxe-shipping-nudge__bar" data-shipping-nudge-bar style="width: 0%;"></span>
        </div>
      </div>
      <div class="luxe-shipping-nudge__actions">
        <button type="button" class="luxe-shipping-nudge__explore button button-secondary" data-shipping-nudge-explore>
          Keep exploring
        </button>
        <a
          href="{{ routes.cart_url }}"
          class="luxe-shipping-nudge__cart button button-secondary"
          data-shipping-nudge-cart
          role="button"
        >
          View bag
        </a>
        <button
          type="button"
          class="luxe-shipping-nudge__checkout button"
          data-shipping-nudge-checkout
          {% unless cart.item_count > 0 %}hidden{% endunless %}
        >
          Pay · {{ estimated_total | money }}
        </button>
      </div>
    </div>
  </aside>
{%- endunless -%}
