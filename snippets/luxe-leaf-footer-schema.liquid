{%- doc -%}
  Footer SEO — Organization, SiteNavigationElement, and contact schema.
{%- enddoc -%}

{%- unless settings.brand_navigation == false -%}
  {%- liquid
    assign shop_tea_url = routes.all_products_collection_url
    if collections.all != blank and collections.all.url != blank
      assign shop_tea_url = collections.all.url
    endif

    capture brand_phone
      render 'luxe-leaf-brand-phone-value'
    endcapture
    assign brand_phone = brand_phone | strip

    assign brand_email = settings.brand_email
    if brand_email == blank
      assign brand_email = shop.email
    endif

    assign home_abs = shop.url | append: routes.root_url
    assign shop_abs = shop.url | append: shop_tea_url
    assign guides_abs = shop.url | append: '/blogs/tea-guides'
    assign faq_abs = shop.url | append: '/pages/faq'
    assign about_abs = shop.url | append: '/pages/about'
    assign contact_abs = shop.url | append: '/pages/contact'

    capture privacy_url_resolved
      render 'luxe-leaf-policy-url', which: 'privacy'
    endcapture
    capture terms_url_resolved
      render 'luxe-leaf-policy-url', which: 'terms'
    endcapture
    capture refund_url_resolved
      render 'luxe-leaf-policy-url', which: 'refund'
    endcapture
    capture shipping_url_resolved
      render 'luxe-leaf-policy-url', which: 'shipping'
    endcapture

    assign privacy_abs = shop.url | append: privacy_url_resolved | strip
    assign terms_abs = shop.url | append: terms_url_resolved | strip
    assign refund_abs = shop.url | append: refund_url_resolved | strip
    assign shipping_abs = shop.url | append: shipping_url_resolved | strip
    assign free_ship_threshold = settings.free_shipping_threshold | default: 5000
    assign standard_shipping_rate = settings.standard_shipping_rate | default: 595
    assign free_ship_money = free_ship_threshold | money
    assign standard_ship_money = standard_shipping_rate | money
    assign free_ship_schema = free_ship_threshold | divided_by: 100.0
    assign standard_ship_schema = standard_shipping_rate | divided_by: 100.0
    if settings.logo != blank
      assign org_logo_url = settings.logo | image_url: width: 434
    else
      assign org_logo_url = 'luxe-leaf-tea-logo-header.png' | asset_url
    endif
  -%}

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "logo": {
        "@type": "ImageObject",
        "url": {{ org_logo_url | json }},
        "width": 434,
        "height": 96
      },
      "description": {{ brand_blurb | default: 'Premium loose leaf tea — whole leaves packed fresh to order.' | json }}{%- if instagram_url != blank or facebook_url != blank -%},
      "sameAs": [
        {%- if instagram_url != blank -%}
          {{ instagram_url | json }}{%- if facebook_url != blank -%},{%- endif -%}
        {%- endif -%}
        {%- if facebook_url != blank -%}
          {{ facebook_url | json }}
        {%- endif -%}
      ]{%- endif -%}{%- if brand_phone != blank or brand_email != blank -%},
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "availableLanguage": ["English"]{%- if brand_phone != blank -%},
        "telephone": {{ brand_phone | json }}{%- endif -%}{%- if brand_email != blank -%},
        "email": {{ brand_email | json }}{%- endif -%}
      }{%- endif -%},
      "makesOffer": {
        "@type": "Offer",
        "name": "Standard shipping",
        "price": {{ standard_ship_schema | json }},
        "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }},
        "description": {{ 'Standard shipping ' | append: standard_ship_money | append: '. Free shipping on orders over ' | append: free_ship_money | append: '.' | json }},
        "eligibleTransactionVolume": {
          "@type": "PriceSpecification",
          "minPrice": {{ free_ship_schema | json }},
          "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }}
        }
      }
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SiteNavigationElement",
      "name": ["Home", "Shop All Tea", "Green Tea", "Oolong Tea", "Tea Guides", "FAQ", "About", "Contact", "Privacy Policy", "Terms of Service", "Refund Policy", "Shipping Policy"],
      "url": [
        {{ home_abs | json }},
        {{ shop_abs | json }},
        {{ shop.url | append: '/collections/green-tea' | json }},
        {{ shop.url | append: '/collections/oolong' | json }},
        {{ guides_abs | json }},
        {{ faq_abs | json }},
        {{ about_abs | json }},
        {{ contact_abs | json }},
        {{ privacy_abs | json }},
        {{ terms_abs | json }},
        {{ refund_abs | json }},
        {{ shipping_abs | json }}
      ]
    }
  </script>
{%- endunless -%}
