{%- doc -%}
  Shared premium tea shop styles for Luxe Leaf sections.
{%- enddoc -%}

{% stylesheet %}
  .luxe-icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    color: #c9a227;
  }

  .luxe-icon svg {
    width: 100%;
    height: 100%;
  }

  .luxe-icon--sm {
    width: 0.875rem;
    height: 0.875rem;
  }

  .luxe-icon--md {
    width: 1.125rem;
    height: 1.125rem;
  }

  .luxe-link-with-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .luxe-stars {
    display: inline-flex;
    gap: 0.15rem;
    color: #c9a227;
  }
{% endstylesheet %}
