{%- doc -%}
  Recommended phone placement: mobile menu "Need help?" card (tap-to-call).
  Always visible — uses theme setting, store phone, or Contact page fallback.
{%- enddoc -%}

{%- liquid
  capture brand_phone
    render 'luxe-leaf-brand-phone-value'
  endcapture
  assign brand_phone = brand_phone | strip
  capture brand_phone_href
    render 'luxe-leaf-brand-phone-href'
  endcapture
  assign brand_phone_href = brand_phone_href | strip
  assign contact_url = pages['contact'].url | default: '/pages/contact'

  assign brand_email = settings.brand_email
  if brand_email == blank
    assign brand_email = shop.email
  endif
-%}

<div class="luxe-brand-menu__contact">
  <p class="luxe-brand-menu__contact-heading">Need help?</p>

  {%- if brand_phone != blank -%}
    <a
      class="luxe-brand-menu__contact-link luxe-brand-menu__contact-link--phone luxe-brand-menu__contact-link--primary"
      href="tel:{{ brand_phone_href | escape }}"
      title="Call Luxe Leaf Tea customer service"
    >
      <span class="luxe-brand-menu__contact-label">Phone</span>
      <span class="luxe-brand-menu__contact-value">{{ brand_phone }}</span>
    </a>
  {%- else -%}
    <a
      class="luxe-brand-menu__contact-link luxe-brand-menu__contact-link--phone luxe-brand-menu__contact-link--primary"
      href="{{ contact_url }}"
      title="View Luxe Leaf Tea phone and contact details"
    >
      <span class="luxe-brand-menu__contact-label">Phone</span>
      <span class="luxe-brand-menu__contact-value">View contact details</span>
    </a>
  {%- endif -%}

  {%- if brand_email != blank -%}
    <a
      class="luxe-brand-menu__contact-link luxe-brand-menu__contact-link--email"
      href="mailto:{{ brand_email | escape }}"
      title="Email Luxe Leaf Tea customer service"
    >
      <span class="luxe-brand-menu__contact-label">Email</span>
      <span class="luxe-brand-menu__contact-value">{{ brand_email }}</span>
    </a>
  {%- endif -%}

  <p class="luxe-brand-menu__trust">Free shipping on orders $50+</p>
</div>
