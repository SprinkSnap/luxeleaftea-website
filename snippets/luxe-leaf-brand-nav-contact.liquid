{%- doc -%}
  Email support block for nav menu footer (phone shown in nav links).
{%- enddoc -%}

{%- liquid
  assign brand_email = settings.brand_email
  if brand_email == blank
    assign brand_email = shop.email
  endif
-%}

<div class="luxe-brand-menu__contact">
  <p class="luxe-brand-menu__contact-heading">Need help?</p>

  {%- if brand_email != blank -%}
    <a
      class="luxe-brand-menu__contact-link luxe-brand-menu__contact-link--email"
      href="mailto:{{ brand_email | escape }}"
      title="Email Luxe Leaf Tea customer service"
    >
      <span class="luxe-brand-menu__contact-label">Email</span>
      <span class="luxe-brand-menu__contact-value">{{ brand_email }}</span>
    </a>
  {%- endif -%}

  <p class="luxe-brand-menu__trust">Free shipping on orders $50+</p>
</div>
