{%- doc -%}
  Product JSON-LD for PDP SEO — brand, SKU, offers (Canada shipping + returns), and image
  (theme fallback when placeholders remain).

  @param {product} product
{%- enddoc -%}

{%- if product != blank -%}
  {%- liquid
    assign schema_variant = product.selected_or_first_available_variant
    assign product_url = shop.url | append: product.url
    assign variant_url = product_url
    if schema_variant != blank and schema_variant.url != blank
      assign variant_url = shop.url | append: schema_variant.url
    endif

    assign product_brand = shop.name
    if product.vendor != blank
      assign product_brand = product.vendor
    endif

    assign product_desc = product.description | strip_html | truncate: 5000
    if product_desc == blank
      assign product_desc = 'Shop ' | append: product.title | append: ' — premium loose leaf tea packed fresh to order from ' | append: shop.name | append: '.'
    endif

    capture fallback_asset
      render 'luxe-leaf-product-image-fallback', product: product
    endcapture
    assign fallback_asset = fallback_asset | strip

    assign schema_image = blank
    if fallback_asset != blank
      assign schema_image = fallback_asset | asset_url | prepend: 'https:'
    elsif product.featured_media != blank and product.featured_media.preview_image != blank
      assign schema_image = product.featured_media.preview_image | image_url: width: 1200 | prepend: 'https:'
    elsif product.featured_image != blank
      assign schema_image = product.featured_image | image_url: width: 1200 | prepend: 'https:'
    endif

    assign currency_code = cart.currency.iso_code | default: shop.currency
    assign offer_price = 0
    assign offer_availability = 'https://schema.org/OutOfStock'
    assign offer_sku = blank
    if schema_variant != blank
      assign offer_price = schema_variant.price | divided_by: 100.0
      if schema_variant.available
        assign offer_availability = 'https://schema.org/InStock'
      endif
      if schema_variant.sku != blank
        assign offer_sku = schema_variant.sku
      endif
    endif

    assign free_ship_cents = settings.free_shipping_threshold | default: 5000
    assign standard_ship_cents = settings.standard_shipping_rate | default: 995
    assign free_ship_schema = free_ship_cents | divided_by: 100.0
    assign standard_ship_schema = standard_ship_cents | divided_by: 100.0

    capture refund_url_resolved
      render 'luxe-leaf-policy-url', which: 'refund'
    endcapture
    capture shipping_url_resolved
      render 'luxe-leaf-policy-url', which: 'shipping'
    endcapture
    assign refund_abs = shop.url | append: refund_url_resolved | strip
    assign shipping_abs = shop.url | append: shipping_url_resolved | strip
  -%}

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product_desc | json }},
      "url": {{ product_url | json }},
      "brand": {
        "@type": "Brand",
        "name": {{ product_brand | json }}
      }{%- if offer_sku != blank -%},
      "sku": {{ offer_sku | json }}{%- endif -%}{%- if product.type != blank -%},
      "category": {{ product.type | json }}{%- endif -%}{%- if schema_image != blank -%},
      "image": [
        {{ schema_image | json }}
      ]{%- endif -%}{%- if schema_variant != blank -%},
      "offers": {
        "@type": "Offer",
        "url": {{ variant_url | json }},
        "priceCurrency": {{ currency_code | json }},
        "price": {{ offer_price | json }},
        "availability": {{ offer_availability | json }},
        "itemCondition": "https://schema.org/NewCondition",
        "seller": {
          "@type": "Organization",
          "name": {{ shop.name | json }}
        },
        "hasMerchantReturnPolicy": {
          "@type": "MerchantReturnPolicy",
          "name": "Refund Policy",
          "url": {{ refund_abs | json }},
          "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
          "merchantReturnDays": 14,
          "returnMethod": "https://schema.org/ReturnByMail",
          "returnFees": "https://schema.org/ReturnFeesCustomerResponsibility",
          "applicableCountry": "CA",
          "merchantReturnLink": {{ refund_abs | json }}
        },
        "shippingDetails": [
          {
            "@type": "OfferShippingDetails",
            "name": "Free Canada-wide shipping",
            "url": {{ shipping_abs | json }},
            "shippingRate": {
              "@type": "MonetaryAmount",
              "value": 0,
              "currency": {{ currency_code | json }}
            },
            "shippingDestination": {
              "@type": "DefinedRegion",
              "addressCountry": "CA"
            },
            "deliveryTime": {
              "@type": "ShippingDeliveryTime",
              "handlingTime": {
                "@type": "QuantitativeValue",
                "minValue": 1,
                "maxValue": 2,
                "unitCode": "DAY"
              },
              "transitTime": {
                "@type": "QuantitativeValue",
                "minValue": 3,
                "maxValue": 8,
                "unitCode": "DAY"
              }
            },
            "eligibleTransactionVolume": {
              "@type": "PriceSpecification",
              "minPrice": {{ free_ship_schema | json }},
              "priceCurrency": {{ currency_code | json }}
            },
            "doesNotShip": false
          },
          {
            "@type": "OfferShippingDetails",
            "name": "Standard Canada-wide shipping",
            "url": {{ shipping_abs | json }},
            "shippingRate": {
              "@type": "MonetaryAmount",
              "value": {{ standard_ship_schema | json }},
              "currency": {{ currency_code | json }}
            },
            "shippingDestination": {
              "@type": "DefinedRegion",
              "addressCountry": "CA"
            },
            "deliveryTime": {
              "@type": "ShippingDeliveryTime",
              "handlingTime": {
                "@type": "QuantitativeValue",
                "minValue": 1,
                "maxValue": 2,
                "unitCode": "DAY"
              },
              "transitTime": {
                "@type": "QuantitativeValue",
                "minValue": 3,
                "maxValue": 8,
                "unitCode": "DAY"
              }
            },
            "doesNotShip": false
          }
        ]
      }{%- endif -%}
    }
  </script>
{%- endif -%}
