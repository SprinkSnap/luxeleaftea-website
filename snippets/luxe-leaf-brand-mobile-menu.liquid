{%- doc -%}
  Lightweight brand mobile menu — hamburger overlay, no duplicate Shop CTA.
{%- enddoc -%}

<div class="luxe-brand-menu" data-luxe-brand-menu>
  <button
    type="button"
    class="header__icon header__icon--menu luxe-brand-menu__toggle"
    aria-label="Open menu — About, Contact, FAQ, and customer support"
    aria-expanded="false"
    aria-controls="LuxeBrandMenuPanel"
    data-luxe-nav-toggle
  >
    <span class="svg-wrapper luxe-brand-menu__icon" aria-hidden="true">
      {{- 'icon-hamburger.svg' | inline_asset_content -}}
    </span>
  </button>

  <div
    id="LuxeBrandMenuPanel"
    class="luxe-brand-menu__panel"
    hidden
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Site menu"
  >
    <button
      type="button"
      class="luxe-brand-menu__backdrop"
      data-luxe-nav-close
      aria-label="Close menu"
      tabindex="-1"
    ></button>

    <div class="luxe-brand-menu__sheet">
      <div class="luxe-brand-menu__header">
        <p class="luxe-brand-menu__eyebrow">Luxe Leaf Tea</p>
        <button
          type="button"
          class="luxe-brand-menu__close button-unstyled"
          data-luxe-nav-close
          aria-label="Close menu"
        >
          <span class="svg-wrapper" aria-hidden="true">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>

      <nav class="luxe-brand-menu__nav" aria-label="Company pages">
        <ul class="luxe-brand-menu__list list-unstyled" role="list">
          {% render 'luxe-leaf-brand-nav-links', variant: 'panel' %}
        </ul>
      </nav>

      <div class="luxe-brand-menu__footer">
        {% render 'luxe-leaf-brand-nav-contact' %}
      </div>
    </div>
  </div>
</div>
