{%- doc -%}
  Lightweight brand mobile menu — tea leaf menu icon and full-screen overlay with Shop Tea CTA.
{%- enddoc -%}

{%- liquid
  assign shop_tea_url = routes.all_products_collection_url
  if collections.all != blank and collections.all.url != blank
    assign shop_tea_url = collections.all.url
  endif
-%}

<div class="luxe-brand-menu" data-luxe-brand-menu>
  <button
    type="button"
    class="header__icon header__icon--menu luxe-brand-menu__toggle"
    aria-label="Open tea shop menu — Shop Tea, phone support, policies, About, Contact, and FAQ"
    aria-expanded="false"
    aria-controls="LuxeBrandMenuPanel"
    data-luxe-nav-toggle
  >
    <span class="svg-wrapper luxe-brand-menu__icon luxe-brand-menu__icon--tea" aria-hidden="true">
      {% render 'luxe-leaf-tea-menu-icon' %}
    </span>
  </button>

  <div
    id="LuxeBrandMenuPanel"
    class="luxe-brand-menu__panel"
    hidden
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Site menu"
  >
    <button
      type="button"
      class="luxe-brand-menu__backdrop"
      data-luxe-nav-close
      aria-label="Close menu"
      tabindex="-1"
    ></button>

    <div class="luxe-brand-menu__sheet">
      <div class="luxe-brand-menu__header">
        <p class="luxe-brand-menu__eyebrow">Luxe Leaf Tea</p>
        <button
          type="button"
          class="luxe-brand-menu__close button-unstyled"
          data-luxe-nav-close
          aria-label="Close menu"
        >
          <span class="svg-wrapper" aria-hidden="true">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>

      <div class="luxe-brand-menu__scroll">
        <a
          href="{{ shop_tea_url }}"
          class="button luxe-brand-menu__shop-cta"
          title="Shop premium loose leaf tea — green, oolong, pu-erh, and black"
        >
          Shop Tea
        </a>

        <a
          href="{{ routes.search_url }}"
          class="luxe-brand-menu__search"
          title="Search premium loose leaf tea"
        >
          Search teas
        </a>

        <div class="luxe-brand-menu__help">
          {% render 'luxe-leaf-brand-nav-contact' %}
        </div>

        <nav class="luxe-brand-menu__nav" aria-label="Company pages">
          <ul class="luxe-brand-menu__list list-unstyled" role="list">
            {% render 'luxe-leaf-brand-nav-links', variant: 'panel' %}
          </ul>
        </nav>

        <nav class="luxe-brand-menu__legal" aria-label="Legal policies">
          <p class="luxe-brand-menu__legal-label">Policies</p>
          {% render 'luxe-leaf-policy-links', variant: 'list' %}
        </nav>
      </div>
    </div>
  </div>
</div>
