      "settings": {
        "eyebrow": "Welcome to our tea room",
        "heading": "The boutique for premium loose leaf tea",
        "intro": "<p>Luxe Leaf Tea is for people who want whole leaves, honest origins, and the feeling of shopping at a real tea counter — online, on your phone, packed fresh after you order.</p><p>We source from China's most respected gardens, label every lot clearly, and guide you from first sip to daily ritual. Add to bag without leaving the page — your next perfect cup is a tap away.</p>",
        "primary_label": "Shop premium loose leaf tea",
        "primary_link": "shopify://collections/all",
        "secondary_label": "Talk to our team",
        "secondary_link": "shopify://pages/contact",
        "trust_line": "Whole leaves · Packed fresh to order · Free shipping over $50",
        "badge_text": "Shop like you're at the counter",
        "show_jump_nav": true,
        "jump_shop_label": "Shop bestsellers",
