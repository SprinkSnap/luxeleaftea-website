    "faq_page": {
      "type": "luxe-leaf-faq-page",
      "blocks": {
        "choose_1": {
          "type": "faq",
          "settings": {
            "category": "choosing",
            "question": "How do I choose my first premium loose leaf tea?",
            "answer": "<p>Start with what you already enjoy \u2014 bright and sweet? Try a green like Longjing. Something floral and layered? An oolong. Rich and malty? Black tea. Every tea includes brewing notes, and our Tea Guide can recommend a first cup in one chat.</p>"
          }
        },
        "choose_2": {
          "type": "faq",
          "settings": {
            "category": "choosing",
            "question": "What's the difference between green, oolong, pu-erh, and black tea?",
            "answer": "<p><strong>Green</strong> \u2014 bright, sweet, grassy. <strong>Oolong</strong> \u2014 floral, layered, re-steeps beautifully. <strong>Pu-erh</strong> \u2014 deep, smooth, earthy. <strong>Black</strong> \u2014 rich, malty, full-bodied. All are whole-leaf premium loose leaf teas \u2014 browse by type and add to bag without leaving the site.</p>"
          }
        },
        "choose_3": {
          "type": "faq",
          "settings": {
            "category": "choosing",
            "question": "I'm new to loose leaf \u2014 how much should I buy to start?",
            "answer": "<p>Most drinkers start with 50\u2013100g \u2014 enough for two to four weeks of daily cups. Our bestsellers below are a great first order; one tap adds to bag and opens the cart drawer so you keep browsing.</p>"
          }
        },
        "brew_1": {
          "type": "faq",
          "settings": {
            "category": "brewing",
            "question": "How much loose leaf tea should I use per cup?",
            "answer": "<p>For most premium loose leaf teas, use about <strong>3 grams per 150ml</strong> of water (roughly one heaping teaspoon). Oolongs and pu-erh can use slightly more for a richer cup. Every tea ships with specific gram and timing guidance.</p>"
          }
        },
        "brew_2": {
          "type": "faq",
          "settings": {
            "category": "brewing",
            "question": "What water temperature is best for green tea vs oolong?",
            "answer": "<p><strong>Green tea:</strong> 175\u2013185\u00b0F (80\u201385\u00b0C) \u2014 never boiling. <strong>Oolong:</strong> 195\u2013205\u00b0F (90\u201396\u00b0C). <strong>Black & pu-erh:</strong> just off boil, around 205\u2013212\u00b0F. Cooler water keeps delicate greens sweet, not bitter.</p>"
          }
        },
        "brew_3": {
          "type": "faq",
          "settings": {
            "category": "brewing",
            "question": "Can I re-steep premium loose leaf tea?",
            "answer": "<p>Yes \u2014 that's one of the best reasons to choose whole leaves. Greens often yield 3\u20134 infusions; oolongs and pu-erh can offer 4\u20138. Add 30\u201360 seconds each re-steep, or use slightly hotter water on later rounds.</p>"
          }
        },
        "brew_4": {
          "type": "faq",
          "settings": {
            "category": "brewing",
            "question": "Do I need special equipment to brew loose leaf tea?",
            "answer": "<p>No. A mug with an infuser basket works perfectly for your first cup. Want to go deeper? A gaiwan or small teapot unlocks even more flavor \u2014 but premium loose leaf tastes exceptional in a simple infuser mug.</p>"
          }
        },
        "order_1": {
          "type": "faq",
          "settings": {
            "category": "orders",
            "question": "How do I add to bag without leaving the page?",
            "answer": "<p>Tap <strong>Add to Bag</strong> on any product card or bestseller below \u2014 your cart drawer opens instantly, no page reload. Keep browsing FAQs, collections, or tea guides, then checkout when you're ready.</p>"
          }
        },
        "order_2": {
          "type": "faq",
          "settings": {
            "category": "orders",
            "question": "Is checkout secure? What payment methods do you accept?",
            "answer": "<p>Yes \u2014 Shopify secure checkout with SSL encryption. We accept major credit and debit cards, Apple Pay, Google Pay, Shop Pay, and other trusted payment methods shown at checkout. Your payment details are never stored on our servers.</p>"
          }
        },
        "order_3": {
          "type": "faq",
          "settings": {
            "category": "orders",
            "question": "Can I change or cancel my order after placing it?",
            "answer": "<p>Contact us as soon as possible \u2014 call, email, or chat with our Tea Guide. If your order hasn't been packed yet, we'll do our best to update or cancel it. Once packed fresh to order, changes may not be possible.</p>"
          }
        },
        "ship_1": {
          "type": "faq",
          "settings": {
            "category": "shipping",
            "question": "Do you offer free shipping?",
            "answer": "<p>Yes — <strong>free Canada-wide shipping on orders over $50</strong>. Orders under $50 ship Canada-wide from <strong>$9.95</strong> with tracking — confirmed at checkout before you pay. Typical delivery is 3–8 business days after packing.</p>"
          }
        },
        "ship_2": {
          "type": "faq",
          "settings": {
            "category": "shipping",
            "question": "How long does shipping take?",
            "answer": "<p>Most orders are packed within 1\u20132 business days. Canada-wide delivery is typically <strong>3\u20138 business days</strong> after shipment depending on your province or territory. You'll receive tracking as soon as your tea leaves our tea room.</p>"
          }
        },
        "ship_3": {
          "type": "faq",
          "settings": {
            "category": "shipping",
            "question": "How fresh is the tea when it arrives?",
            "answer": "<p>Every order is <strong>packed fresh after you purchase</strong> \u2014 not pulled from a long-term warehouse shelf. Sealed packaging protects aroma and flavor until you open your pouch or tin.</p>"
          }
        },
        "qual_1": {
          "type": "faq",
          "settings": {
            "category": "quality",
            "question": "Why choose loose leaf tea over tea bags?",
            "answer": "<p>Whole leaves unfurl in water \u2014 more aroma, clearer flavor, and better re-steeps. Premium loose leaf is labeled by origin and style, so you know exactly what you're drinking. No dusty fannings, no mystery blends.</p>"
          }
        },
        "qual_2": {
          "type": "faq",
          "settings": {
            "category": "quality",
            "question": "Is your tea really packed fresh to order?",
            "answer": "<p>Yes. We seal your tea after you buy \u2014 not weeks or months ahead. That's why Luxe Leaf cups taste vivid and alive, not flat like grocery-store tea sitting on a shelf.</p>"
          }
        },
        "qual_3": {
          "type": "faq",
          "settings": {
            "category": "quality",
            "question": "What if I'm not happy with my tea?",
            "answer": "<p>Reach out \u2014 we want every cup to feel worth slowing down for. Contact our tea team and we'll help you find a better match or resolve any issue with your order. We stand behind every lot we sell.</p>"
          }
        }
      },
