

{% liquid
  assign block_settings = block.settings
  assign use_inverse_logo = false

  if section.settings.enable_transparent_header_home and template.name == 'index' and section.settings.home_inverse_logo == true
    assign use_inverse_logo = true
  elsif section.settings.enable_transparent_header_product and template.name == 'product' and section.settings.product_inverse_logo == true
    assign use_inverse_logo = true
  elsif section.settings.enable_transparent_header_collection and template.name == 'collection' and section.settings.collection_inverse_logo == true
    assign use_inverse_logo = true
  endif

  if use_inverse_logo
    if settings.logo_inverse != blank
      assign inverse_logo = settings.logo_inverse
    else
      assign inverse_logo = settings.logo
    endif
  endif

  assign alt_text_fallback = 'accessibility.home_logo_alt' | t: store_name: shop.name

  assign brand_logo_height = 56
  assign brand_logo_height_mobile = 48
  assign logo_height = settings.logo_height | default: brand_logo_height
  assign logo_height_mobile = settings.logo_height_mobile | default: brand_logo_height_mobile

  unless settings.brand_navigation == false
    assign logo_height = brand_logo_height
    assign logo_height_mobile = brand_logo_height_mobile
  endunless
%}

{% comment %}
  Output all logo variants, use CSS to hide/show the appropriate one
  based on the .header[transparent] selector
{% endcomment %}
<a
  {% if template.name == 'index' and block_settings.hide_logo_on_home_page %}
    data-hidden-on-home-page
  {% endif %}
  href="{{ routes.root_url }}"
  class="size-style spacing-style header-logo{% unless settings.brand_navigation == false %} header-logo--brand{% endunless %}"
  aria-label="{{ shop.name | escape }} — home"
  style="
    {% render 'size-style', settings: block_settings %}
    {% render 'spacing-style', settings: block_settings %}
    --font-family: var(--font-body--family);
    --font-style: var(--font-body--style);
    --font-weight: 600;
    --header-logo-image-height: {{ logo_height }}px;
    --header-logo-image-height-mobile: {{ logo_height_mobile }}px;
  "
  {{ block.shopify_attributes }}
>
  {% liquid
    assign brand_logo_aspect_ratio = 4.52

    if settings.logo != blank and settings.brand_navigation == false
      assign logo_width = logo_height | times: settings.logo.aspect_ratio | ceil
      assign logo_width_mobile = logo_height_mobile | times: settings.logo.aspect_ratio | ceil
    else
      assign logo_width = logo_height | times: brand_logo_aspect_ratio | round
      assign logo_width_mobile = logo_height_mobile | times: brand_logo_aspect_ratio | round
    endif

    if use_inverse_logo and inverse_logo != blank
      assign inverse_logo_width = logo_height | times: inverse_logo.aspect_ratio | ceil
      assign inverse_logo_width_mobile = logo_height_mobile | times: inverse_logo.aspect_ratio | ceil
      assign inverse_logo_style = '--header-logo-image-width: ' | append: inverse_logo_width | append: 'px;' | append: '--header-logo-image-width-mobile: ' | append: inverse_logo_width_mobile | append: 'px; --header-logo-image-height: ' | append: logo_height | append: 'px; --header-logo-image-height-mobile: ' | append: logo_height_mobile | append: 'px;'
    endif

    assign logo_style = '--header-logo-image-width: ' | append: logo_width | append: 'px;' | append: '--header-logo-image-width-mobile: ' | append: logo_width_mobile | append: 'px; --header-logo-image-height: ' | append: logo_height | append: 'px; --header-logo-image-height-mobile: ' | append: logo_height_mobile | append: 'px;'
  %}

  <span
    class="header-logo__image-container header-logo__image-container--original"
    data-testid="header-logo"
  >
    {% if settings.logo != blank and settings.brand_navigation == false %}
      {% render 'image',
        image: settings.logo,
        class: 'header-logo__image',
        height: logo_height,
        alt_text_fallback: alt_text_fallback,
        text_fallback: shop.name,
        style: logo_style
      %}
    {% else %}
      {% render 'luxe-leaf-tea-logo',
        style: logo_style,
        class: 'header-logo__image',
        alt: alt_text_fallback,
        logo_height: logo_height,
        logo_height_mobile: logo_height_mobile
      %}
    {% endif %}
  </span>

  {% if use_inverse_logo %}
    <span
      class="header-logo__image-container header-logo__image-container--inverse"
      data-testid="header-logo-inverse"
    >
      {% render 'image',
        image: inverse_logo,
        class: 'header-logo__image',
        height: logo_height,
        alt_text_fallback: alt_text_fallback,
        text_fallback: shop.name,
        style: inverse_logo_style
      %}
    </span>
  {% endif %}
</a>

{% stylesheet %}
  .header-logo {
    display: flex;
    height: 100%;
    max-width: min(16rem, 72vw);
    overflow: visible;
    flex: 0 1 auto;
    font-size: var(--font-size--md);
    font-family: var(--font-family);
    font-weight: var(--font-weight);
    font-style: var(--font-style);
    color: var(--color-foreground);
    justify-content: center;
    align-items: center;
    text-decoration: none;

    &[data-hidden-on-home-page] {
      display: none;

      #header-component:is(
          [sticky='always']:not([data-scroll-direction='none']),
          [sticky='scroll-up'][data-scroll-direction='up']
        )
        & {
        display: flex;
      }
    }

    @media screen and (max-width: 749px) {
      padding: 0;
    }

    @media screen and (min-width: 750px) {
      flex-shrink: 0;
      max-width: 18rem;
    }

    &:hover {
      text-decoration: none;
    }
  }

  .header-logo__image-container,
  .luxe-brand-logo__picture {
    display: flex;
    align-items: center;
    line-height: 0;
  }

  .header-logo__image,
  .luxe-brand-logo__image {
    object-fit: contain;
    object-position: left center;
    max-width: 100%;
    width: auto !important;
    height: var(--luxe-header-logo-height-mobile, 48px) !important;
    max-height: none;

    @media screen and (min-width: 750px) {
      object-position: center;
      height: var(--luxe-header-logo-height-desktop, 56px) !important;
    }
  }

  .header-logo--brand {
    max-width: var(--luxe-mobile-logo-max-width, calc(100vw - 10.5rem));

    @media screen and (min-width: 750px) {
      max-width: 18rem;
      margin-inline: 0;
      padding-inline-end: 0;
    }
  }

  .header-logo:has(.header-logo__image-container--inverse) .header-logo__image-container--original {
    display: var(--header-logo-display, block);
  }

  .header-logo__image-container--inverse {
    display: var(--header-logo-inverse-display, none);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.logo",
  "tag": null,
  "class": "header-logo",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.edit_logo_in_theme_settings"
    },
    {
      "type": "header",
      "content": "t:content.visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_logo_on_home_page",
      "label": "t:settings.hide_logo_on_home_page",
      "info": "t:info.hide_logo_on_home_page_help"
    },
    {
      "type": "header",
      "content": "t:content.padding_desktop"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
