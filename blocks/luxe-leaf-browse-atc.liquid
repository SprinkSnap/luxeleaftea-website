{%- doc -%}
  Product card block — inline browse add-to-cart (collection/search grids).
{%- enddoc -%}

<div {{ block.shopify_attributes }}>
  {%- if request.page_type == 'cart' -%}
    {% render 'luxe-leaf-cart-recommendation-atc', product: closest.product %}
  {%- else -%}
    {% render 'luxe-leaf-browse-atc-inline', product: closest.product %}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Luxe Leaf browse add to bag",
  "tag": null,
  "settings": []
}
{% endschema %}
