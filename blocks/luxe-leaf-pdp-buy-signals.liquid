{%- doc -%}
  PDP buy-box decision cues — taste line, cart-aware free-shipping callout, and trust.
{%- enddoc -%}

{%- liquid
  assign cue_product = closest.product | default: product
  assign threshold = settings.free_shipping_threshold | default: 5000
  assign free_ship_label = threshold | money
  assign show_taste = block.settings.show_taste
  if show_taste == blank
    assign show_taste = true
  endif
  assign show_trust = block.settings.show_trust
  if show_trust == blank
    assign show_trust = true
  endif
  assign show_cart_free_ship = block.settings.show_cart_free_ship
  if show_cart_free_ship == blank
    assign show_cart_free_ship = true
  endif

  assign cart_total = cart.total_price
  assign remaining = threshold | minus: cart_total
  if remaining < 0
    assign remaining = 0
  endif

  assign variant = cue_product.selected_or_first_available_variant
  assign variant_price = 0
  if variant != blank
    assign variant_price = variant.price
  endif

  assign projected_total = cart_total | plus: variant_price
  assign after_remaining = threshold | minus: projected_total
  if after_remaining < 0
    assign after_remaining = 0
  endif

  assign ship_state = 'threshold'
  assign ship_message = 'Free Canada-wide shipping over ' | append: free_ship_label

  if show_cart_free_ship
    if cart_total >= threshold
      assign ship_state = 'unlocked'
      assign ship_message = "You've unlocked free Canada-wide shipping"
    elsif remaining > 0 and variant_price >= remaining
      assign ship_state = 'unlocks'
      assign ship_message = 'This tea unlocks free Canada-wide shipping'
    elsif remaining > 0 and after_remaining > 0
      assign ship_state = 'closer'
      assign after_money = after_remaining | money
      assign ship_message = 'After this, ' | append: after_money | append: ' to free Canada-wide shipping'
    elsif remaining > 0
      assign ship_state = 'unlocks'
      assign ship_message = 'This tea unlocks free Canada-wide shipping'
    endif
  endif
-%}

{%- if cue_product != blank -%}
  <div
    class="luxe-pdp-buy-signals{% if show_taste and show_trust == false and show_cart_free_ship == false %} luxe-pdp-buy-signals--taste{% endif %}"
    {{ block.shopify_attributes }}
  >
    {%- if show_taste -%}
      {% render 'luxe-leaf-pdp-taste-cue', product: cue_product %}
    {%- endif -%}

    {%- if show_cart_free_ship -%}
      <p
        class="luxe-pdp-buy-signals__ship luxe-pdp-buy-signals__ship--{{ ship_state }}"
        data-pdp-free-ship
        data-threshold="{{ threshold }}"
        data-cart-total="{{ cart_total }}"
        data-variant-price="{{ variant_price }}"
        data-threshold-label="{{ free_ship_label | escape }}"
        role="status"
        aria-live="polite"
      >
        {%- render 'luxe-leaf-icon', name: 'truck', class: 'luxe-icon--sm' -%}
        <span data-pdp-free-ship-text>{{ ship_message }}</span>
      </p>
    {%- endif -%}

    {%- if show_trust -%}
      <ul class="luxe-pdp-buy-signals__trust list-unstyled" role="list" aria-label="Shopping confidence">
        <li>
          {%- render 'luxe-leaf-icon', name: 'leaf', class: 'luxe-icon--sm' -%}
          <span>Packed fresh to order</span>
        </li>
        {%- unless show_cart_free_ship -%}
          <li>
            {%- render 'luxe-leaf-icon', name: 'truck', class: 'luxe-icon--sm' -%}
            <span>Free Canada-wide shipping over {{ free_ship_label }}</span>
          </li>
        {%- endunless -%}
        <li>
          {%- render 'luxe-leaf-icon', name: 'lock', class: 'luxe-icon--sm' -%}
          <span>Secure guest checkout</span>
        </li>
      </ul>
    {%- endif -%}
  </div>
{%- endif -%}

{% stylesheet %}
  .luxe-pdp-buy-signals {
    display: grid;
    gap: 0.75rem;
    width: 100%;
  }

  .luxe-pdp-buy-signals__taste {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.45rem;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: rgb(27 67 50 / 0.88);
  }

  .luxe-pdp-buy-signals__type {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c9a227;
  }

  .luxe-pdp-buy-signals__sep {
    color: rgb(27 67 50 / 0.35);
  }

  .luxe-pdp-buy-signals__cue {
    font-weight: 500;
  }

  .luxe-pdp-buy-signals__ship {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin: 0;
    padding: 0.7rem 0.85rem;
    border-radius: 0.75rem;
    border: 1px solid rgb(201 162 39 / 0.35);
    background:
      radial-gradient(120% 120% at 0% 0%, rgb(201 162 39 / 0.16), transparent 55%),
      #fff;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.4;
    color: #1b4332;
  }

  .luxe-pdp-buy-signals__ship .luxe-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: #1b4332;
  }

  .luxe-pdp-buy-signals__ship--unlocks,
  .luxe-pdp-buy-signals__ship--unlocked {
    border-color: rgb(27 67 50 / 0.22);
    background:
      radial-gradient(120% 120% at 0% 0%, rgb(27 67 50 / 0.1), transparent 55%),
      rgb(248 246 240 / 0.95);
  }

  .luxe-pdp-buy-signals__ship--closer {
    border-color: rgb(201 162 39 / 0.45);
  }

  .luxe-pdp-buy-signals__trust {
    display: grid;
    gap: 0.4rem;
    margin: 0;
    padding: 0.75rem 0.85rem;
    border-radius: 0.75rem;
    border: 1px solid rgb(27 67 50 / 0.1);
    background:
      radial-gradient(120% 120% at 0% 0%, rgb(201 162 39 / 0.1), transparent 55%),
      rgb(248 246 240 / 0.85);
  }

  .luxe-pdp-buy-signals__trust li {
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: rgb(27 67 50 / 0.9);
  }

  .luxe-pdp-buy-signals__trust .luxe-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: #1b4332;
  }

  @media screen and (max-width: 749px) {
    .luxe-pdp-buy-signals__ship {
      font-size: 0.8125rem;
      padding: 0.65rem 0.75rem;
    }
  }

  @media screen and (min-width: 750px) {
    .luxe-pdp-buy-signals__taste {
      font-size: 1rem;
    }

    .luxe-pdp-buy-signals__ship {
      font-size: 0.9375rem;
    }

    .luxe-pdp-buy-signals__trust {
      gap: 0.45rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf buy signals",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_taste",
      "label": "Show taste cue",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart_free_ship",
      "label": "Show cart-aware free shipping line",
      "default": true,
      "info": "Shows whether this tea unlocks free shipping or how much would remain after adding it."
    },
    {
      "type": "checkbox",
      "id": "show_trust",
      "label": "Show trust signals",
      "default": true
    }
  ]
}
{% endschema %}
