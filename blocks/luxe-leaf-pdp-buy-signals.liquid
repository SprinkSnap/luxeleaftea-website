{%- doc -%}
  PDP buy-box decision cues — taste line and free-shipping trust tied to settings.
{%- enddoc -%}

{%- liquid
  assign cue_product = closest.product | default: product
  assign free_ship_label = settings.free_shipping_threshold | default: 5000 | money
  assign show_taste = block.settings.show_taste
  if show_taste == blank
    assign show_taste = true
  endif
  assign show_trust = block.settings.show_trust
  if show_trust == blank
    assign show_trust = true
  endif
-%}

{%- if cue_product != blank -%}
  <div
    class="luxe-pdp-buy-signals{% if show_taste and show_trust == false %} luxe-pdp-buy-signals--taste{% endif %}{% if show_trust and show_taste == false %} luxe-pdp-buy-signals--trust{% endif %}"
    {{ block.shopify_attributes }}
  >
    {%- if show_taste -%}
      {% render 'luxe-leaf-pdp-taste-cue', product: cue_product %}
    {%- endif -%}

    {%- if show_trust -%}
      <ul class="luxe-pdp-buy-signals__trust list-unstyled" role="list" aria-label="Shopping confidence">
        <li>
          {%- render 'luxe-leaf-icon', name: 'leaf', class: 'luxe-icon--sm' -%}
          <span>Packed fresh to order</span>
        </li>
        <li>
          {%- render 'luxe-leaf-icon', name: 'truck', class: 'luxe-icon--sm' -%}
          <span>Free Canada-wide shipping over {{ free_ship_label }}</span>
        </li>
        <li>
          {%- render 'luxe-leaf-icon', name: 'lock', class: 'luxe-icon--sm' -%}
          <span>Secure guest checkout</span>
        </li>
      </ul>
    {%- endif -%}
  </div>
{%- endif -%}

{% stylesheet %}
  .luxe-pdp-buy-signals {
    display: grid;
    gap: 0.75rem;
    width: 100%;
  }

  .luxe-pdp-buy-signals__taste {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.45rem;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: rgb(27 67 50 / 0.88);
  }

  .luxe-pdp-buy-signals__type {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c9a227;
  }

  .luxe-pdp-buy-signals__sep {
    color: rgb(27 67 50 / 0.35);
  }

  .luxe-pdp-buy-signals__cue {
    font-weight: 500;
  }

  .luxe-pdp-buy-signals__trust {
    display: grid;
    gap: 0.4rem;
    margin: 0;
    padding: 0.75rem 0.85rem;
    border-radius: 0.75rem;
    border: 1px solid rgb(27 67 50 / 0.1);
    background:
      radial-gradient(120% 120% at 0% 0%, rgb(201 162 39 / 0.1), transparent 55%),
      rgb(248 246 240 / 0.85);
  }

  .luxe-pdp-buy-signals__trust li {
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: rgb(27 67 50 / 0.9);
  }

  .luxe-pdp-buy-signals__trust .luxe-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: #1b4332;
  }

  @media screen and (min-width: 750px) {
    .luxe-pdp-buy-signals__taste {
      font-size: 1rem;
    }

    .luxe-pdp-buy-signals__trust {
      gap: 0.45rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Luxe Leaf buy signals",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_taste",
      "label": "Show taste cue",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_trust",
      "label": "Show trust / free shipping",
      "default": true
    }
  ]
}
{% endschema %}
