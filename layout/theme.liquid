<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.brand_navigation != false -%}
      <link
        rel="icon"
        type="image/png"
        sizes="32x32"
        href="{{ 'luxe-leaf-tea-favicon-32.png' | asset_url }}"
      >
      <link
        rel="icon"
        type="image/png"
        sizes="16x16"
        href="{{ 'luxe-leaf-tea-favicon-16.png' | asset_url }}"
      >
      <link
        rel="apple-touch-icon"
        sizes="180x180"
        href="{{ 'luxe-leaf-tea-apple-touch-icon.png' | asset_url }}"
      >
    {%- elsif settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- else -%}
      <link
        rel="icon"
        type="image/png"
        sizes="32x32"
        href="{{ 'luxe-leaf-tea-favicon-32.png' | asset_url }}"
      >
      <link
        rel="icon"
        type="image/png"
        sizes="16x16"
        href="{{ 'luxe-leaf-tea-favicon-16.png' | asset_url }}"
      >
      <link
        rel="apple-touch-icon"
        sizes="180x180"
        href="{{ 'luxe-leaf-tea-apple-touch-icon.png' | asset_url }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'luxe-leaf-view-transition-gate' -%}
    {%- render 'luxe-leaf-brand-styles' -%}
    {%- render 'luxe-leaf-design-system' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-palette' -%}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Source+Sans+3:wght@400;600;700&display=swap"
      rel="stylesheet"
    >
    {{ 'luxe-leaf-theme.css' | asset_url | stylesheet_tag }}
    <script type="module" src="{{ 'luxe-leaf-brand-nav.js' | asset_url }}"></script>
    {%- unless settings.brand_navigation == false -%}
      <script src="{{ 'luxe-leaf-canada-tax.js' | asset_url }}" defer></script>
      <script type="module" src="{{ 'luxe-leaf-mobile-commerce.js' | asset_url }}"></script>
      <script type="module" src="{{ 'luxe-leaf-browse-atc.js' | asset_url }}"></script>
    {%- endunless -%}
    {%- render 'luxe-leaf-nav-schema' -%}
    {%- render 'luxe-leaf-site-schema' -%}

    {% style %}
      body {
        background: #f8f6f0 !important;
        color: #1b4332 !important;
        font-family: 'Source Sans 3', var(--font-body--family), sans-serif !important;
      }

      h1, h2, h3, h4, .h1, .h2, .h3, .h4 {
        font-family: 'Playfair Display', var(--font-heading--family), Georgia, serif !important;
        color: #1b4332 !important;
      }

      .luxe-hero h1,
      .luxe-hero__heading,
      .luxe-hero .luxe-hero__eyebrow {
        color: #fff !important;
        text-shadow: 0 2px 24px rgb(0 0 0 / 0.55);
      }

      .luxe-hero .luxe-hero__eyebrow {
        color: #e8c547 !important;
        text-shadow: 0 1px 8px rgb(0 0 0 / 0.45);
      }

      /* Dark CTA surfaces — cream text (loads after luxe-leaf-theme.css; must live here) */
      .luxe-shop-cta,
      .luxe-shop-cta h2,
      .luxe-shop-cta p,
      .luxe-faq-page__cta,
      .luxe-faq-page__cta p,
      .luxe-policy-page__cta,
      .luxe-policy-page__cta p,
      .luxe-brand-footer,
      .luxe-brand-footer h2,
      .luxe-brand-footer h3,
      .luxe-brand-footer p,
      .luxe-brand-footer__subhead,
      .luxe-brand-footer__newsletter,
      .luxe-brand-footer__newsletter-heading,
      .luxe-brand-footer__newsletter-copy,
      .luxe-shop-cta__text,
      .luxe-shop-cta__text * {
        color: #f8f6f0 !important;
      }

      .luxe-shop-cta.section,
      .luxe-brand-footer__cta.section {
        background: linear-gradient(135deg, #1b4332 0%, #0d2818 100%) !important;
      }

      .luxe-shop-cta__button-secondary,
      .luxe-brand-footer__secondary-btn,
      .luxe-faq-page__cta-secondary,
      .luxe-policy-page__cta-secondary {
        color: #f8f6f0 !important;
        border-color: rgb(248 246 240 / 0.85) !important;
        background: transparent !important;
      }

      /* Shop CTAs must pop — gold on dark, never jade-on-jade */
      body.luxe-leaf-theme .luxe-policy-page__cta-primary,
      body.luxe-leaf-theme .luxe-policy-page__ship-cta-btn,
      body.luxe-leaf-theme .luxe-policy-page__sidebar-shop,
      body.luxe-leaf-theme .luxe-shop-cta__button,
      body.luxe-leaf-theme .luxe-collection-cta__button,
      body.luxe-leaf-theme .luxe-keep-exploring__view-all--cta,
      body.luxe-leaf-theme .luxe-featured__view-all--cta,
      body.luxe-leaf-theme .luxe-faq-page__cta-primary,
      body.luxe-leaf-theme .luxe-faq-page__help-shop,
      body.luxe-leaf-theme .luxe-article-cta__button,
      body.luxe-leaf-theme .luxe-guides__hub-link,
      .luxe-policy-page__cta-primary,
      .luxe-policy-page__ship-cta-btn,
      .luxe-policy-page__sidebar-shop,
      .luxe-shop-cta__button,
      .luxe-collection-cta__button,
      .luxe-keep-exploring__view-all--cta,
      .luxe-featured__view-all--cta,
      .luxe-faq-page__cta-primary,
      .luxe-faq-page__help-shop,
      .luxe-article-cta__button,
      .luxe-guides__hub-link {
        background: linear-gradient(135deg, #f0d56a 0%, #c9a227 48%, #b8921f 100%) !important;
        border: 2px solid #f3d56a !important;
        color: #141414 !important;
        -webkit-text-fill-color: #141414 !important;
      }

      #header-group .header-announcements,
      .announcement-bar {
        background: #1a1a1a !important;
        color: #faf8f2 !important;
      }

      footer .section,
      footer .footer,
      .footer-utilities {
        background: #0d2818 !important;
        color: #f8f6f0 !important;
      }

      body.luxe-leaf-theme #header-component .header-logo__image,
      body.luxe-leaf-theme #header-component .luxe-brand-logo__image {
        height: 48px !important;
        max-height: none !important;
        width: auto !important;
        object-position: center;
      }

      body.luxe-leaf-theme #header-component .header-logo--brand .header-logo__image,
      body.luxe-leaf-theme #header-component .header-logo--brand .luxe-brand-logo__image {
        max-width: min(11.25rem, calc(100vw - 11rem));
      }

      body.luxe-leaf-theme #header-component .header-logo--brand {
        max-width: min(11.25rem, calc(100vw - 11rem));
      }

      body.luxe-leaf-theme #header-component header-actions {
        grid-column: 4 / 6;
        width: 5.5rem;
        min-width: 5.5rem;
        z-index: 6;
      }

      @media screen and (min-width: 750px) {
        body.luxe-leaf-theme #header-component .header-logo__image,
        body.luxe-leaf-theme #header-component .luxe-brand-logo__image {
          height: 56px !important;
          object-position: center;
        }
      }

      body.luxe-leaf-theme #header-component .header__row--top {
        min-height: 3.75rem;
      }

      /* Footer newsletter signup copy — must beat global jade body/heading rules */
      body.luxe-leaf-theme .luxe-brand-footer-section p.luxe-brand-footer__newsletter-copy,
      body.luxe-leaf-theme .luxe-brand-footer .luxe-brand-footer__newsletter-copy.luxe-text-cream {
        color: #f8f6f0 !important;
      }

      /* Newsletter email field: never inherit cream-on-white from footer color rules */
      body.luxe-leaf-theme .luxe-brand-footer .luxe-brand-footer__newsletter-input,
      body.luxe-leaf-theme .luxe-brand-footer input.luxe-brand-footer__newsletter-input {
        background: #faf7ef !important;
        background-color: #faf7ef !important;
        color: #1a1a1a !important;
        -webkit-text-fill-color: #1a1a1a !important;
        caret-color: #1a1a1a !important;
        border-color: rgb(201 162 39 / 0.5) !important;
      }

      body.luxe-leaf-theme .luxe-brand-footer .luxe-brand-footer__newsletter-input::placeholder {
        color: rgb(26 26 26 / 0.55) !important;
        -webkit-text-fill-color: rgb(26 26 26 / 0.55) !important;
        opacity: 1 !important;
      }

      body.luxe-leaf-theme .luxe-brand-footer .luxe-brand-footer__newsletter-label {
        color: #e4c76b !important;
      }

      body.luxe-leaf-theme .luxe-brand-footer .luxe-brand-footer__newsletter-hint {
        color: rgb(248 246 240 / 0.68) !important;
      }

      .luxe-brand-footer__policy-link,
      .luxe-brand-footer__policy-grid-link,
      .luxe-brand-footer__policy-list a {
        color: #f8f6f0 !important;
      }
    {% endstyle %}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
  </head>

  <body
    class="page-width-wide card-hover-effect-lift luxe-leaf-theme"
    data-free-shipping-threshold="{{ settings.free_shipping_threshold | default: 5000 }}"
    data-standard-shipping-rate="{{ settings.standard_shipping_rate | default: 995 }}"
    data-free-shipping-threshold-label="{{ settings.free_shipping_threshold | default: 5000 | money | escape }}"
    data-standard-shipping-rate-label="{{ settings.standard_shipping_rate | default: 995 | money | escape }}"
  >
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}

    {% render 'chat-drawer' %}

    <div class="page-wrapper">
      <div id="header-group">
        {% sections 'header-group' %}
      </div>

      <script>
        // Inline header height and menu style calculations to prevent layout shift
        // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
        (function setHeaderHeighCustomProperties() {
          /*
           * Header calculation functions for maintaining CSS variables
           * Mimic calculateHeaderGroupHeight() in utilities.js
           */
          const header = document.querySelector('header-component');
          const headerGroup = document.querySelector('#header-group');
          const hasHeaderSection = headerGroup?.querySelector('.header-section');

          if (!header || !headerGroup) return;

          const headerTopRow = header.querySelector('.header__row--top');
          const headerHeight = header.offsetHeight;

          // Calculate the total height of the header group
          let headerGroupHeight = 0;
          const children = headerGroup.children;
          for (let i = 0; i < children.length; i++) {
            const element = children[i];
            if (element === header || !(element instanceof HTMLElement)) continue;
            headerGroupHeight += element.offsetHeight;
          }

          // Check for transparent header special case
          if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
            headerGroupHeight += headerHeight;
          }

          // Set CSS variables
          document.body.style.setProperty('--header-height', `${headerHeight}px`);
          document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

          if (headerTopRow) {
            window.requestAnimationFrame(function () {
              document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
            });
          }

          /**
           * Updates CSS custom properties for transparent header offset calculation
           * Mimic updateTransparentHeaderOffset() in utilities.js
           */

          if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
            document.body.style.setProperty('--transparent-header-offset-boolean', '0');
            return;
          }

          const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

          const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
          document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
        })();

        (function setHeaderMenuStyle() {
          const headerComponent = document.querySelector('#header-component');
          if (!headerComponent) return;

          const isDesktop = window.matchMedia('(min-width: 750px)').matches;
          const isBrandTheme = document.body.classList.contains('luxe-leaf-theme');

          if (isBrandTheme && isDesktop) {
            headerComponent.dataset.menuStyle = 'menu';
            return;
          }

          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        })();
      </script>

      <main
        id="MainContent"
        class="content-for-layout"
        role="main"
        data-page-transition-enabled="{{ settings.page_transition_enabled }}"
        data-product-transition="{{ settings.transition_to_main_product }}"
        data-template="{{ template }}"
      >
        {{ content_for_layout }}
      </main>

      <footer>
        {%- comment -%}
          Force Luxe Leaf footer when brand navigation is on — bypasses footer-group.json
          so Shopify theme-editor syncs cannot revert to Horizon's default footer.
          Uses a snippet (not {% section %}) because Horizon footer sections must load via section groups.
        {%- endcomment -%}
        {%- if settings.brand_navigation != false -%}
          <div class="luxe-brand-footer-section">
            {% render 'luxe-leaf-brand-footer-content' %}
          </div>
        {%- else -%}
          {% sections 'footer-group' %}
        {%- endif -%}
      </footer>
    </div>

    {% render 'cart-drawer', render_wrapper: true %}
    {% render 'theme-drawer' %}
    {% render 'luxe-leaf-cart-opener' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
